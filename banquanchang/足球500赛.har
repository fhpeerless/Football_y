          "content": {
            "size": 8883,
            "mimeType": "application/x-javascript",
            "text": "/**\n * 在移动端打开PC页面，弹窗提示 \n * 弹出逻辑：1、每日一次（自然日） 2、最高权重，与其他弹窗/广告冲突时，优先展示（在最上层显示 z-index:10000）\n * 下载App：调用 ////www.500cache.com/public/js/download500app.js(版本号)，使用 DownLoad500App() 方法\n * 不再显示：第二次弹出时显示，默认不选中，勾选后，不再弹出该弹窗，cookie记录\n * */\n (function() {\n    // 引用静态文件方法（此方法并不是固定的，可以根据具体项目，按需修改）\n    function insertStaticFile(type, src, callback) {\n        var verTxt = new Date().getTime();\n        if (src && src.indexOf('www.500cache.com') > -1 && window && window.WWW500CACHE_STATIC_VERSION) {\n            verTxt = window.WWW500CACHE_STATIC_VERSION;\n        }\n        if (src && src.indexOf('trade.500cache.com') > -1 && window && window.TRADE500CACHE_STATIC_VERSION) {\n            verTxt = window.TRADE500CACHE_STATIC_VERSION;\n        }\n        if (src && src.indexOf('www.500cache.com') === -1 && src.indexOf('trade.500cache.com') === -1) {\n            verTxt = 'default';\n        }\n        var head = document.getElementsByTagName('head').item(0);\n        var srcUrl = src + '?v=' + verTxt;\n        if (type === 'js' || type === 'js-gbk' || type === 'js-utf8') {\n            var script_dom = document.createElement('script');\n            script_dom.language = 'javascript';\n            script_dom.type = 'text/javascript';\n            script_dom.async = false;\n            if (type === 'js-gbk') {\n                script_dom.charset = 'gbk';\n            }\n            if (type === 'js-utf8') {\n                script_dom.charset = 'UTF-8';\n            }\n            script_dom.src = srcUrl;\n            script_dom.addEventListener(\"load\", function() {\n              callback && callback();\n            }, false);\n            script_dom.addEventListener('error', function () {\n              callback && callback();\n            }, false);\n            head.appendChild(script_dom);\n        }\n        if (type === 'css') {\n            var link = document.createElement('link');\n            link.type = 'text/css';\n            link.rel = 'stylesheet';\n            link.href = srcUrl;\n            head.appendChild(link);\n        }\n    };\n    // 引入js\n    insertStaticFile('js', '//www.500cache.com/versionnumber/staticversion.js', function() {\n      insertStaticFile('js-utf8', '//www.500cache.com/public/js/download500app.js')\n    });\n})();\n\n\n //弹窗样式，使用vh单位\n var styleStr = `.pop-gotouch, .pop-gotouch .layer {position: fixed; z-index:10000;left: 0; top: 0;right: 0;bottom: 0;}\n .pop-gotouch {display:none;}\n .pop-gotouch .layer {background:rgba(0,0,0,.8); z-index: 5;}\n .pop-gotouch .pop-box {-webkit-transform: translate(-50%,-50%);transform: translate(-50%,-50%);background:#fff;color:#333; border-radius: 2vw;font-size: 4vw; line-height:1.8;position: fixed;z-index: 10;top:50%;left:50%;text-align: center; width: 80%;}\n .pop-gotouch .pop-cont {padding: 5vw 4vh; text-align: left;}\n .pop-gotouch .pop-cont .cont-txt {padding: 5vw 0;}\n .pop-gotouch .pop-cont .noshow {text-align: center; color: #666; display: none;}\n .pop-gotouch .pop-cont .noshow i {display: inline-block; width: 4vw; height: 4vw; border: 1px solid #d9d9d9; border-radius: .8vw; vertical-align: middle; position: relative; top: -2px; margin-right: 1.5vw;}\n .pop-gotouch .pop-cont .slt {color: #3F65CB;}\n .pop-gotouch .pop-cont .slt i {background: url(data:image/svg+xml;base64,) no-repeat center center; background-size: 3vw 3vw; border: 1px solid #3F65CB;}\n .pop-gotouch .btn-wrap {height: 13vw; display: flex; overflow: hidden; border-radius: 0 0 2vw 2vw; border-top: 1px solid #d9d9d9;}\n .pop-gotouch .btn-wrap a {display: block; width: 100%; height: 100%; line-height: 13vw; flex: 1; text-decoration: none; color: #3F65CB;}\n .pop-gotouch .btn-wrap a:last-child {color: #fff; background: #EB1815;}\n .pop-gotouch .close {position: absolute; display: block; width: 9vw; height: 9vw; background:#fff; border-radius: 100%; opacity: .5; left: 50%; transform: translateX(-50%); bottom:-13vw;}\n .pop-gotouch .close::before, .pop-gotouch .close::after {content: '';display: block; border-radius: .3vw; position: absolute; width: .6vw; height: 5vw; background: #000; left: 50%; top: 50%;}\n .pop-gotouch .close::before {transform: translate(-50%,-50%) rotate(45deg);}\n .pop-gotouch .close::after {transform: translate(-50%,-50%) rotate(-45deg);}\n `\t\n function addCSS(cssText){\n    var style = document.createElement('style'),  //创建一个style元素\n        head = document.head || document.getElementsByTagName('head')[0]; //获取head元素\n    style.type = 'text/css'; //这里必须显示设置style元素的type属性为text/css，否则在ie中不起作用\n    if(style.styleSheet){ //IE\n        var func = function(){\n            try{ //防止IE中stylesheet数量超过限制而发生错误\n                style.styleSheet.cssText = cssText;\n            }catch(e){\n            }\n        }\n        //如果当前styleSheet还不能用，则放到异步中执行\n        if(style.styleSheet.disabled){\n            setTimeout(func,10);\n        }else{\n            func();\n        }\n    }else{ //w3c\n        //w3c浏览器中只要创建文本节点插入到style元素中就行了\n        var textNode = document.createTextNode(cssText);\n        style.appendChild(textNode);\n    }\n    head.appendChild(style); //把创建的style元素插入到head中    \n}\n\n//使用\naddCSS(styleStr);\n \n\n //弹窗HTML代码\nvar gotouchHTML = `<div class=\"layer\"></div>\n        <div class=\"pop-box\">\n            <div class=\"pop-cont\">\n                <div class=\"cont-txt\">Hi~ 小伍，看到您访问了我们的电脑端页面，为更好的使用体验，建议您前往手机页面或下载App访问</div>\n                <div class=\"noshow\" id=\"noshow\" onclick=\"noShowClick()\"><i></i>不再提示</div>\n            </div>\n            <div class=\"btn-wrap\">\n                <a href=\"https://m.500.com\">前往手机页面</a>\n                <a onClick=\"DownLoad500App()\" href=\"javascript:void(0)\">下载App</a>\n            </div>\n            <span class=\"close\" onclick=\"closePop()\"></span>\n        </div>`\n    \nvar gotouch = document.createElement('div')\n    gotouch.setAttribute('id','pop-gotouch')\n    gotouch.setAttribute('class','pop-gotouch')\n    gotouch.innerHTML = gotouchHTML\n    document.body.appendChild(gotouch);\n\n// 当前设备是否移动设备\nvar flag = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobi/i.test(navigator.userAgent)\nif(flag && !window.EsApp){ layerShow(); }\n\n//设置cookie\nfunction setCookie(arr){\n\tdocument.cookie = \"pcTouchDownload500App =\" + arr + \";path=/;domain=.500.com\"\n}\n\n//读取cookie\nfunction getCookie(cname)\n{\n  var name = cname + \"=\";\n  var ca = document.cookie.split(';');\n  for(var i=0; i<ca.length; i++) \n  {\n    var c = ca[i].trim();\n    if (c.indexOf(name)==0) return c.substring(name.length,c.length);\n  }\n  return \"\";\n}\n\n//弹窗显示 or 隐藏逻辑\nfunction layerShow(){\n\tvar appCookie = getCookie('pcTouchDownload500App').split(',')\n\tvar nowDate = new Date()\n\tvar pop = document.querySelector('#pop-gotouch')\n    var btn = document.querySelector('#noshow')\n\tif (appCookie=='') {\n\t\tsetCookie([0,nowDate.getTime()])\n\t\tpop.style.display = 'block'\n\t} else {\n        pop.style.display = 'none'\n        if (appCookie[0] == 0) {  \n            var nowTime = new Date(new Date().toLocaleDateString()).getTime()   // 当前日 0 点时间戳\n            // var nowTime = new Date(new Date(2022,12,20).toLocaleDateString()).getTime() //测试用，修改时间戳\n\t\t\tvar flag = nowTime - parseInt(appCookie[1])          \n\t\t\tif( flag > 0) {\n\t\t\t\tpop.style.display = 'block'\n\t\t\t\tbtn.style.display = 'block'\t\n                setCookie([0,new Date().getTime()])\n\t\t\t} \n\t\t}\n\t}\n}\n\n//\"不再显示\"按钮交互逻辑\nfunction noShowClick(){\n\tvar arr = getCookie('pcTouchDownload500App').split(',')\n\tvar btn = document.querySelector('#noshow')\n\tvar cls = btn.className\n\tif(cls.indexOf('slt') == -1) {\n\t\tbtn.classList.add('slt')\n\t\tarr.splice(0,1,1)\n\t\tsetCookie(arr)\n\t} else {\n\t\tbtn.classList.remove('slt')\n\t\tarr.splice(0,1,0)\n\t\tsetCookie(arr)\n\t}\n}\n\n//下载APP\nfunction download500app() {\n    if (window && window.DownLoad500App && typeof window.DownLoad500App === 'function') {\n        var errorMes = window.DownLoad500App()\n    }\n}\n\n//关闭弹窗\nfunction closePop() {\n    var obj = document.querySelector('#pop-gotouch')\n    obj.style.display = 'none'\n}\n"
          },
