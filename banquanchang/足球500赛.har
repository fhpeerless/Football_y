n\t\t\t}\n\t\t\tvar basketcode_len = this.get('codes').length;\n\t\t\tif(this.get('modifyData') === false){\n\t\t\t\t//if(basketcode_len > this.get().maxLine){\n\t\t\t\t//\treturn __sys.alert('很抱歉，最多可选'+this.get().maxLine+'组号码');\n\t\t\t\t//}\n\t\t\t\tthis.get('codes').push(_code);\n\t\t\t}\n\t\t\tvar basketcode = [];\n\t\t\tthis.get('codes').forEach(function(c, i){\n\t\t\t\tif(_T.get('modifyData') !== false && _T.get('modifyData').index == c.index){\n\t\t\t\t\t_code.index = i;\n\t\t\t\t\tbasketcode.push(_code);\n\t\t\t\t}else{\n\t\t\t\t\tc.index = i;\n\t\t\t\t\tbasketcode.push(c);\n\t\t\t\t}\n\t\t\t});\n\t\t\tthis.set('codes', basketcode);\n\t\t\tthis.set('modifyData', false);\n\t\t\t$('body,html').animate({\n\t\t\t\tscrollTop: $('div.main').offset().top\n\t\t\t});\n\t\t\tthis.update();\n\t\t\tthis.options.choose.clearchoose();\n\t\t\tthis.options.choose.updateTzbl();\n\t\t\tthis.options.choose.updateshebtn();\n\t\t},\n\t\t//清空列表\n\t\tclearCode: function(el){\n\t\t\tvar _T = this;\n\t\t\tif(this.get('codes').length > 0){\n\t\t\t\tif(el == 'success'){\n                    _T.set('codes', []);\n                    _T.set('modifyData', false);\n                    _T.update();\n                }else{\n                    __sys.confirm({html: '确定清空投注列表吗？'}, this.bind(function (ok){\n                        if (ok) {\n                            _T.set('codes', []);\n                            _T.set('modifyData', false);\n                            _T.update();\n                        }\n                    }));\n                    \n                }\t\t    \n\t\t\t}\n\t\t},\n\t\t//显示号码蓝投注号码\n\t\tshowBasket: function(codetable){\n\t\t\tthis.set('codetable', codetable, true);\n\t\t},\n\t\t//显示总金额和注数\n\t\tshowSum: function(){\n\t\t\tvar allmoney = this.get('allmoney')*this.get('multiple');\n\t\t\tthis.set('summoney', __sys.format(sumTmpl, {allmoney: __sys.getRmb(allmoney, false, 2), allzs: this.get('allzs')}));\n\t\t},\n\t\t//更新投注内容\n\t\tupdate: function(){\n\t\t\tvar codetable = '';\n\t\t\tvar allmoney = 0, allzs = 0;\n\t\t\tif(this.get('codes').length > 0){\n\t\t\t\tcodetable = this.get('codes').map(function(data, i){\n\t\t\t\t\tallmoney += parseInt(data.money, 10);\n\t\t\t\t\tallzs += parseInt(data.zs, 10);\n\t\t\t\t\treturn __sys.format(lineTmpl,{\n\t\t\t\t\t\tindex: data.index,\n\t\t\t\t\t\tcode: (function(code){\n\t\t\t\t\t\t\tvar codestr = '';\n\t\t\t\t\t\t\tcode.split(',').forEach(function(el,i){\n\t\t\t\t\t\t\t\tif(i%2){\n\t\t\t\t\t\t\t\t\tif(i == code.split(',').length-1){\n\t\t\t\t\t\t\t\t\t\tcodestr += el;\n\t\t\t\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\t\t\t\tcodestr += el + ' | ';\n\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\t\t\tcodestr += el + ',';\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t});\n\t\t\t\t\t\t\treturn codestr;\n\t\t\t\t\t\t})(data.code),\n\t\t\t\t\t\tdftype: data.dftype,\n\t\t\t\t\t\tzs: data.zs,\n\t\t\t\t\t\tmoney: data.money\n\t\t\t\t\t});\n\t\t\t\t}).join('');\n\t\t\t}\n\t\t\tthis.set('allzs', allzs);\n\t\t\tthis.set('allmoney', allmoney);\n\t\t\tthis.showBasket(codetable);\n\t\t\tthis.showSum();\n\t\t}\n\t};\n});\n\n/* \n * 提交购买\n */\n__defineClass('DoBuy', function() {\n\treturn {\n\t\tui: {\n\t\t\t'div.bet-ok': {\n\t\t\t\tbind: 'data-click',\n\t\t\t\t'a#buy_ok': {\n\t\t\t\t\twatch: {\n\t\t\t\t\t\t'sys.isOpenBuy': 'setIsOpen($e, $el)',\n\t\t\t\t\t\t'sys.isBuyStop': 'setIsOpen($e, $el)',\n\t\t\t\t\t\t'sys.isbai': 'setIsOpen($e, $el)'\n\t\t\t\t\t}\n\t\t\t\t},\n\t\t\t\t'input:checkbox': {\n\t\t\t\t\tname: 'chkbtn',\n\t\t\t\t\tinit: 'set(readed, $checked)'\n\t\t\t\t}\n\t\t\t},\n\t\t\t'#expect': {\n\t\t\t\tinit: function(el) {\n\t\t\t\t\tthis.set('expect', el.val());\n\t\t\t\t}\n\t\t\t},\n\t\t\t'#vsTable': {\n\t\t\t\tname: 'vstable'\n\t\t\t}\n\t\t},\n\t\tevents: {\n\t\t\t//显示停售样式\n\t\t\t'sys.stopBuy.change noCode.change': function() {\n\t\t\t\tthis.set({\n\t\t\t\t\tstop: __sys.get().stopBuy || this.get().noCode\n\t\t\t\t});\n\t\t\t},\n\t\t\t'sys.greementOk.change': function(v) {\n\t\t\t\tthis.ui_chkbtn.prop('checked', v);\n\t\t\t\tthis.get().readed = v;\n\t\t\t}\n\t\t},\n\t\t//set btn-ok监听是否开售和截止\n\t\tsetIsOpen: function(v, el){\n\t\t\tvar d = 'btn-red-off';\n\t\t\tif(__sys.get().isBuyStop){\n\t\t\t\tel.html('已截止').addClass(d);\n\t\t\t\t$('.zcfilter-endtime').html('投注已截止').css({\n\t\t\t\t\t'color':'red',\n\t\t\t\t\t'fontWeight' : 'bold'\n\t\t\t\t});\n\t\t\t}else{\n\t\t\t\tel.html('保存方案').removeClass(d);\n\t\t\t}\n\t\t},\n\t\tgetData: function(){\n\t\t\tvar data = {}, beishu = 1, money = 0, allmoney = 0, zhushu = 0, allzs = 0, codes = '', playArr = [];\n\t\t\tzhushu = this.options.codebasket.get('allzs');\n\t\t\tbeishu = this.options.codebasket.get('multiple');\n\t\t\tmoney = this.options.codebasket.get('allmoney');\n\t\t\tcodes = this.options.codebasket.get('codes');\n\t\t\tcodes.forEach(function(code, i){\n\t\t\t\tallzs += code.zs;\n\t\t\t\tallmoney += code.money;\n\t\t\t\tif(playArr.indexOf(code.playid) == -1){\n\t\t\t\t\tplayArr.push(code.playid);\n\t\t\t\t}\n\t\t\t});\n\t\t\tif(allmoney != money || allzs != zhushu){\n\t\t\t\treturn __sys.alert('金额注数错误，请重新投注');\n\t\t\t}\n\t\t\t//返回数据\n\t\t\tdata.lotid = parseInt($.trim($('#lotid').val()), 10);\n\t\t\tdata.expect = parseInt($.trim($('#expect').val()), 10);\n\t\t\tdata.beishu = beishu;\n\t\t\tdata.zhushu = zhushu;\n\t\t\tdata.allmoney = parseInt(money*beishu, 10);\n\t\t\tdata.playid = playArr.length>1?408:playArr[0];\n\t\t\tdata.codes = this.getFormatCode(codes, data.playid);\n\t\t\tdata.vs = this.getVsList();\n\t\t\tdata.line = codes.length;\n\t\t\tdata.isusehb = parseInt($.trim($('#isusehb').val()), 10);\n\t\t\tif(data.codes){\n\t\t\t\tthis.set('noCode', false); \n\t\t\t}else{\n\t\t\t\tthis.set('noCode', true); \n\t\t\t}\n\t\t\treturn data;\n\t\t},\n\t\t//获取对阵列表\n\t\tgetVsList: function(){\n\t\t\tvar vslist = [];\n\t\t\tthis.ui_vstable.find('tr.bet-tb-tr').each(function(i, el){\n\t\t\t\tvslist.push($.trim($(el).attr('data-vs')));\n\t\t\t});\n\t\t\treturn vslist.join('$');\n\t\t},\n\t\t//生成投注号码\n\t\tgetFormatCode: function(codes, playid){\n\t\t\tif(!codes || codes.length === 0){ return '';}\n\t\t\treturn codes.map(function(el, i){\n\t\t\t\tif(playid == 408){\n\t\t\t\t\treturn el.code+'#'+el.playid;\n\t\t\t\t}else{\n\t\t\t\t\treturn el.code;\n\t\t\t\t}\n\t\t\t}).join('$');\n\t\t},\n\t\t//点击提交\n\t\ttobuy: function(el) {\n\t\t\t//判断是否可点击\n\t\t\tif($(el).hasClass('btn-red-off')){\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\t//预售期          \n\t\t\tif(__sys.get('zc.issave')!=1){\n\t\t\t\treturn __sys.alert('本期尚未开售，暂不支持保存方案');\n\t\t\t}\n\t\t\t//获取投注内容\n\t\t\tvar data = this.getData();\n\t\t\t//判断是否有注数\n\t\t\tif (this.get().noCode) {\n\t\t\t\treturn __sys.alert('您好，请至少选择1注号码再进行购买');\n\t\t\t}\n\t\t\t//购买确认层\n\t\t\tvar _T = this;\n\t\t\t__sys.checkLogin(function() {\n\t\t\t\tvar userData = __sys.get().userInfoData;\n\t\t\t\tif(userData){\n\t\t\t\t\t_T.loginChk(data);\n\t\t\t\t}else{\n\t\t\t\t\t__sys.on('userInfoData.change?', function(){\n\t\t\t\t\t\t_T.loginChk(data);\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t});\n\t\t},\n\t\tsend: function(param) {\n\t\t\t__require('HttpQuery').buy(param, this.bind(function(data) {\n\t\t\t\tthis.buyCallback(data, param);\n\t\t\t}), function() {\n\t\t\t\t__sys.alert(\"网络异常，请稍后重试！\");\n\t\t\t});\n\t\t},\t\t\n\t\trequire: ['SucessDialog'],  \n\t\t//成功\n\t\tsuccess: function(data) {\n\t\t\tvar success = __libs.SucessDialog();\n            var _T = this;\n            success.open(function(){\n                _T.options.codebasket.clearCode(\"success\");\n                \n            });\n            $(\".numsel-inp\").find('input').val(1)\n\t\t},\n        \n\t\texpectOver: function(data, param) {\n\t\t\tvar _T = this;\n\t\t\tvar expect = data.msgmode;\n\t\t\t__sys.confirm('第' + param.expect + '期认购已经截止，将从' + expect + '期开始追号',\n\t\t\t\tfunction() {\n\t\t\t\t\tparam.expect = expect;\n\t\t\t\t\tparam.expect_list = expect;\n\t\t\t\t\t_T.send(param);\n\t\t\t\t});\n\t\t},\n\t\tbuyCallback: function(data, param) {\n\t\t\tvar code = data.code;\n\t\t\tvar info = data.info || '';\n\t\t\t//判断是否正确\n\t\t\tswitch (code) {\n\t\t\t\tcase '100':\n\t\t\t\t\tthis.success(data);\n\t\t\t\t\tbreak;\t\t\t\t\n\t\t\t\tcase '-1001':\n\t\t\t\t\tthis.expectOver(info, param);\n\t\t\t\t\tbreak;\n\t\t\t\tdefault:\n\t\t\t\t\t//收银台\n\t\t\t\t\t__sys.alert(\"网络异常，请稍后重试!!\");\n\t\t\t}\n\t\t},\n\t\tinit: function() {\n\t\t\tthis.set('noCode', true);\n\t\t},\n\t\tloginChk: function(data){\n\t\t\tvar _T = this;\t\t\t\n\t\t\tthis.startSend(data);\t\t\n\t\t},\n\t\tstartSend: function (data){\n\t\t\t__require('buyLay');\n\t\t\tdata = $.extend({}, data);\n\t\t\tvar lay = __sys.libs.buyLay();\n\t\t\tvar headerTmpl = __sys.libs.tmpl.create($('#tmpl_buy_header').html());\n\t\t\tvar me = this;\n\t\t\tvar cfg = {\n\t\t\t\t401 : '单式',\n\t\t\t\t402 : '复式',\n\t\t\t\t408 : '混合'\n\t\t\t};\n\t\t\tif (data.allmoney) {\n\t\t\t\tdata.totalmoney = data.allmoney;\n\t\t\t}\t\t\n\t\t\tdata._beishu = '倍数：' + data.beishu + '倍';\n\t\t\tdata._zhushu = '注数：' + data.zhushu + '注';\n\t\t\tdata.endtime = $('#buyendtime').val();\n\t\t\tdata.title2 = '半全场 第'+data.expect+'期（' + cfg[data.playid] + '购买）';\n\t\t\tdata.totalmoney2 = __sys.getRmb(data.totalmoney, false, 2);\n\t\t\tvar vsList = data.vs.split('$').map(function (vs){\n\t\t\t\treturn vs.split('vs');\n\t\t\t});\n\t\t\tdata.codes2 = data.codes.split('$').map(function (v){\n\t\t\t\tv = v.split('#')[0];\n\t\t\t\treturn v.split(',');\n\t\t\t});\n\t\t\tdata.header = headerTmpl({\n\t\t\t\tvsList: vsList\n\t\t\t});\n            \n             //保存方案\n            if(data.totalmoney>20000){\n                __sys.alert('方案金额不能超过20000元，请调整后重试');\n                return false;\n            }            \n            //保存方案\n            if(data.line>100){\n                __sys.alert('最多选择100组号码');\n                return false;\n            } \n\t\t\t__sys.checkLogin(function() {\t\t\t\t\n\t\t\t\tme.send(data);\n\t\t\t});\n\t\t}\n\t};\n});\n\n/*\n其它层\n*/\n__define('ToAddMoney', function() {\n\tvar Dialog = __require('Dialog');\n\tvar addMoneyDlg = Dialog({\n\t\troot: $('#dialog_tmpl_addmoney').html(),\n\t\tdrag: '.tips_title',\n\t\tcontent: '.tips_content'\n\t});\n\treturn {\n\t\t//充值层\n\t\topenAddMoney: function(fn) {\n\t\t\taddMoneyDlg.open(this.noop, function(yes) {\n\t\t\t\tif (yes) {\n\t\t\t\t\t__sys.result(fn);\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t};\n});\n\n/*\n * Ajax进行Http请求查询\n * @author  yangxd  \n */\n__define('HttpQuery', function(){\n\t//请求的url\n\tvar urls = {\n\t\tbuy: '/interface/request.php?q=trade.createorder',\n\t\ttmpbuy: '/interface/request.php?q=trade.createtmporder',\n\t\tiscanbuy: '/static/public/config/trade/xml/sysexp/1251.xml',\n\t\ttzbl_lzc: '/static/public/jczq/json/popularity/lzc/'+__sys.get('expect')+'.json',\n\t\ttzbl_szc: '/static/public/jczq/json/popularity/szc/'+__sys.get('expect')+'.json'\n\t};\n\tvar pause = {};\n\t/*\n\t * 封装了$.ajax方法\n\t */\n\tfunction send(key, param, fn, cfg) {\n\t\tif (pause[key]) {\n\t\t\treturn ;\n\t\t}\n\t\tpause[key] = true;\n\t\treturn $.ajax($.extend({}, {\n\t\t\turl: urls[key],\n\t\t\ttype: 'POST', //默认方法\n\t\t\tdataType: 'json', //默认类型\n\t\t\tdata: param,\n\t\t\tsuccess: fn,\n\t\t\tcomplete: function() {\n\t\t\t\tsetTimeout(function() {\n\t\t\t\t\tpause[key] = null;\n\t\t\t\t}, 1000);\n\t\t\t}\n\t\t}, cfg));\n\t}\n\treturn {\n\t\t//投注彩票\n\t\tbuy: function(param, fn, error) {\n\t\t\treturn send('buy', param, fn, {\n\t\t\t\terror: error\n\t\t\t});\n\t\t},\n\t\t//投注彩票\n\t\ttmpbuy: function(param, fn, error) {\n\t\t\treturn send('tmpbuy', param, fn, {\n\t\t\t\terror: error\n\t\t\t});\n\t\t},\n\t\t//是否开售查询\n\t\tiscanbuy:function(fn){\n\t\t\treturn send('iscanbuy', {_: +new Date()},\n\t\t\t\tfunction(xml) {\n\t\t\t\t\tvar flag=$(xml).find('row')[0].getAttribute('Value')==='1'?true:false;\n\t\t\t\t\tfn(flag);\n\t\t\t\t}, {\n\t\t\t\t\ttype: 'GET',\n\t\t\t\t\tdataType: 'xml'\n\t\t\t\t});\n\t\t},\n\t\t//用户投注比例\n\t\ttzbl: function(lotid, fn, error){\n\t\t\tvar key;\n\t\t\tif(lotid == 15){\n\t\t\t\tkey = 'tzbl_lzc';\n\t\t\t}else if(lotid == 17){\n\t\t\t\tkey = 'tzbl_szc';\n\t\t\t}else{\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\treturn $.ajax({\n\t\t\t\ttype: \"get\",\n\t\t\t\turl : urls[key],\n\t\t\t\tdata: {_: +new Date()},\n\t\t\t\tdataType: 'text',\n\t\t\t\tcontentType: \"application/x-www-form-urlencoded;charset=utf-8;\",\n\t\t\t\tsuccess: function(content, result){\n\t\t\t\t\tif(result == 'success' && content){\n\t\t\t\t\t\tfn(content.replace(/[\\r\\n\\s]/g,''));\n\t\t\t\t\t}\n\t\t\t\t},\n\t\t\t\terror: error || __sys.noop\n\t\t\t});\n\t\t}\n\t};\n});\n\n/*\n * 数字输入\n */\n__defineClass('Number',function() {\n\treturn {\n\t\toptions: {\n\t\t\tadd: 'span.numsel-jia',\n\t\t\tminus: 'span.numsel-jian',\n\t\t\tmin: 1,\n\t\t\tmax: 9e9,\n\t\t\tmod: 1,\n\t\t\tstep: 1,\n\t\t\ttmpl: '{%0}注'\n\t\t},\n\t\tui: {\n\t\t\t'{root}': {\n\t\t\t\tinput: {\n\t\t\t\t\tname: 'input',\n\t\t\t\t\tvalue: 'valueUpdate, value',\n\t\t\t\t\tonkeyup: 'setValue($value)',\n\t\t\t\t\tonblur: 'setValue($value, blur)',\n\t\t\t\t\tonfocus: 'focus($el)'\n\t\t\t\t},\n\t\t\t\t'{add}': {\n\t\t\t\t\tonclick: 'add'\n\t\t\t\t},\n\t\t\t\t'{minus}': {\n\t\t\t\t\tonclick: 'minus'\n\t\t\t\t}\n\t\t\t}\n\t\t},\n\t\tminus: function() {\n\t\t\tvar val = parseFloat(this.get().value);\n\t\t\tthis.setValue(Math.max(this.options.min, val - this.options.step), true);\n\t\t},\n\t\tadd: function() {\n\t\t\tvar val = parseFloat(this.get().value);\n\t\t\tthis.setValue(Math.min(this.options.max, val + this.options.step), true);\n\t\t},\n\t\tsetValue: function(v, isBlur) {\n\t\t\tvar ini = this.options;\n\t\t\tif ($.isString(v)) {\n\t\t\t\tv = v.replace(/\\D/g, '');\n\t\t\t}\n\t\t\tif (v === '') {\n\t\t\t\tif (isBlur) {\n\t\t\t\t\tv = ini.min;\n\t\t\t\t} else {\n\t\t\t\t\tthis.set('valueUpdate', '', true);\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t}\n\t\t\tv = Math.min(ini.max, parseFloat(v));\n\t\t\tif (isBlur) {\n\t\t\t\tv = Math.max(ini.min, v);\n\t\t\t}\n\t\t\tif (this.trigger('beforeChange', v) === false) {\n\t\t\t\tthis.set('value', this.get().value, true);\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tthis.set('value', v);\n\t\t\tif (isBlur && ini.templ) {\n\t\t\t\tv = __sys.format(ini.templ, v);\n\t\t\t}\n\t\t\tthis.set('valueUpdate', v, true); //刷新输入框\n\t\t},\n\t\tfocus: function(el) {\n\t\t\tif (this.options.autoSelect) {\n\t\t\t\tsetTimeout(function() {\n\t\t\t\t\tel.select();\n\t\t\t\t},10);\n\t\t\t}\n\t\t},\n\t\tinit: function() {\n\t\t\t//this.ui_input.attr('maxlength', this.options.length || (this.options.max + '').length);\n\t\t\tvar value=this.options.defaultValue? this.options.defaultValue:this.options.min;\n\t\t\tthis.set('value', value);\n\t\t}\n\t};\n});\n/*\n * 页面初始化统一入口\n * @author  yangxd\n * @date    2015-10-28               \n */\n__object(function(){\n\tthis.ready = $;\n\t$(\"html,body\").animate({scrollTop:$(\"#nav-lott\").offset().top});\n\tif(!('indexOf' in [])){\n\t\tArray.prototype.indexOf = function(v){\n\t\t\tvar I = -1, A = this;\n\t\t\tfor(var i=0; i<A.length; i++){\n\t\t\t\tif(A[i] == v){\n\t\t\t\t\tI = i;\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn I;\n\t\t};\n\t}\n\tthis.ui = {\n\t\t'.popbox-bqc' : {\n\t\t\tinit : function(el){\n\t\t\t\tel.css('display', 'none');\n\t\t\t}\n\t\t},\n\t\t'#lotid': { init: function(el) { __sys.set('lotid', el.val()); } },\n        '#issave': { init: function(el) { __sys.set('zc.issave', el.val()); } },\n\t\t'#expect': { init: function(el) { __sys.set('expect', el.val()); } },\n\t\t'#curexp': { init: function(el) { __sys.set('curexp', el.val()); } }\n\t};\n\tthis.init = function(){\n\t\t//引入选号类\n\t\tvar choose = __require('Choose')({root: '.bet-main'});\n\t\tvar codebasket = __require('CodeBasket')({ root: '#cResult', choose: choose });\n\t\t__require('DoBuy')({ root: '#cResult', codebasket: codebasket });\n\t};\n});"
