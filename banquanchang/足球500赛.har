          "cookies": [],
          "content": {
            "size": 2905,
            "mimeType": "application/x-javascript",
            "text": "/**\n * @returns\n * 成功返回值为空字符串\n * 失败返回具体失败字符串\n */\nfunction DownLoad500App() {\n  try {\n    var navigatorUserAgent = navigator.userAgent;\n    var ua = navigatorUserAgent.toLowerCase() || '';\n    var isAndroid = /android/.test(ua);\n    var isWeixin = /micromessenger/.test(ua);\n    var isIos = /iphone|ipad/.test(ua);\n    var isSwan = /swan/.test(ua)\n    // 百度小程序\n    var isBaiduSwan = ua.indexOf('baiduboxapp') > -1 && isSwan\n    var isEsApp = Boolean(\n      window.EsApp && typeof window.EsApp.init === \"function\"\n    );\n    var evsDomain = \"//ets.500.com\";\n    var DOWN_PC = window.location.protocol + \"//www.500.com/wap/index.php\";\n    var IOS_DOWN_URL =\n      window.location.protocol +\n      \"//itunes.apple.com/cn/app/ -cai-piao/id432486451\";\n    // 是否是移动端\n    function isMobile() {\n      var flag =\n        /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(\n          navigatorUserAgent\n        );\n      return flag;\n    }\n    // 获取安卓下载链接\n    function getAndroidDownUrl(versionString) {\n      return (\n        window.location.protocol +\n        \"//soft.500.com/updatefiles/v\" +\n        versionString +\n        \"/500_lottery_client_for_Android_\" +\n        versionString +\n        \".80002.apk\"\n      );\n    }\n    var DEFAULT_APPVERSION = getAndroidDownUrl(\"4.7.7\");\n    // PC端处理\n    if (!isMobile()) {\n      window.location.replace(DOWN_PC);\n      return \"isPc\";\n    }\n    // 安卓微信处理\n    if (isWeixin && isAndroid) {\n      return \"isAndroidWeixin\";\n    }\n    // app 处理\n    if (isEsApp) {\n      return \"isEsApp\";\n    }\n    // 百度小程序处理\n    if(isBaiduSwan) {\n      return \"isBaiduSwan\";\n    }\n    // 成功处理\n    if (isAndroid) {\n      // 安卓\n      var xhr = new XMLHttpRequest();\n      xhr.onreadystatechange = function () {\n        if (xhr.readyState == 4) {\n          var resp = JSON.parse(xhr.responseText);\n          if (resp.status == \"100\") {\n            var version =\n              resp.data && resp.data.android && resp.data.android.version_num;\n            window.location.href = !version\n              ? DEFAULT_APPVERSION\n              : getAndroidDownUrl(version);\n          } else {\n            console.log(resp.message);\n          }\n        }\n      };\n      xhr.open(\n        \"post\",\n        evsDomain +\n          \"/thinfo/banner/latest_app_version?_t=\" +\n          new Date().getTime(),\n        true\n      ); // 打开链接\n      xhr.setRequestHeader(\"Content-Type\", \"application/json; charset=utf-8\"); // 设置请求头\n      xhr.send(\"p=android\"); // 设置需要携带到后端的字段，字符串形式\n      return \"\";\n    } else if (isIos) {\n      //ios\n      window.location.href = IOS_DOWN_URL;\n      return \"\";\n    }\n    // 未知原因\n    return \"unknownError\";\n  } catch (error) {\n    console.log(error);\n    return \"tryError\";\n  }\n}\n"
          },
          "redirectURL": "",
          "headersSize": -1,
