            "text": " <style>\nbody{\n    margin:0;\n    padding: 0;\n}\n.gongju{\t\n    font-family:Arial,'Microsoft Yahei','\\5FAE\\8F6F\\96C5\\9ED1','Hiragino Sans GB','\\5B8B\\4F53';\n\tmargin: 0 auto;\t\t\n    padding: 24px 0 ;  \n    position: relative;    \n}\n.gongju.border-top{\n    border-top: 1px solid #eee;    \n    margin-bottom: 15px;\n}\n.gongju.bggray::after{\n    content: '';\n    height:15px;\n    left: 0;\n    width: 100%;\n    position: absolute;\n    bottom: -15px;\n    background: #f1f1f1;    \n}\n.gongju2.bggray2::after{\n    content: '';\n    height:10px;\n    left: 0;\n    width: 100%;\n    position: absolute;\n    bottom: 0px;\n    background: #E5E5E5;    \n}\n.gongju.bg{\n    padding: 24px 0  26px;  \n    background: #fff url(data:image/jpeg;base64,) repeat-x 0 100%;    \n}\n.gongju-list{\n \tclear: both; \t\n \twidth: 1180px;\n \tmargin: 0 auto 0;\n    background: #fff\n}\n.gongju-list .gongju-item{\t\n\tfloat: left;\n\tposition: relative;\n\toverflow: hidden;\t\n\tmargin-right: 60px;\n}\n.gongju-list .gongju-item:last-child::after,\n.gongju-list .gongju-item.last::after{\n\tcontent: '';\n\tposition: absolute;\n\tleft: 0;\n\ttop: 0;\n\tbottom: 0;\n\twidth: 1px;\n\tbackground-color: #e7e7e7;\n}\n.gongju-list .gongju-item.last,\n.gongju-list .gongju-item:last-child{\n\tpadding-left: 60px;\n\tmargin-right: 0;\n}\n.gongju-list .gongju-item .fl{\n    float:left;\n}\n.gongju-list .gongju-item .gongju-logo{\n\tdisplay: inline-block;\n    width: 56px;\n    height: 56px;\n    float: left;\n    margin-right: 22px;\n}\n.gongju-list .gongju-item .gongju-name{\n\tfont-size: 18px;        \n    font-weight: 700;    \n    margin:0;\n    margin-bottom: 6px;\n}\n.gongju-list .gongju-item .gongju-performance{\n\tdisplay: inline-block;\n    font-size: 12px;\n    color: #f63f3f;\n    border: 1px solid #f5bbb0;\n    border-radius: 2px;\n    padding: 2px 4px;\n    margin-left: 10px;\n    font-weight: 400;\n}\n.gongju-list .gongju-item .gongju-desc{\n\tfont-size: 16px;\n    color: #999;     \n}\n.gongju-list .gongju-item .btn-buy{\n\ttext-align: center;\n    color: #ffffff;\n    font-size: 12px;\n    display: inline-block;\n    width: 80px;\n    height: 32px;\n    line-height: 32px;\n    border-radius: 4px;\n    box-shadow: 0 4px 8px rgba(193, 148, 80, 0.4);\n    background: rgb(245, 203, 146);    \n    float: left;\n    margin-left: 30px;\n    margin-top: 12px;\n    /* Old browsers */\n    background: -moz-linear-gradient(left, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* FF3.6-15 */\n    background: -webkit-linear-gradient(left, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* Chrome10-25,Safari5.1-6 */\n    background: linear-gradient(to right, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* W3C, IE10+, FF16+, Chrome26+, Opera12+, Safari7+ */\n    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#f5cb92', endColorstr='#ce9134', GradientType=1);\n    /* IE6-9 */\n}\n.gongju2{\n    border-top: 1px solid #eee;\n    padding: 20px 0 30px;\n    background: none;\n    position: relative;\n}\n.gongju2::after{\n    content:'';\n    position: absolute;\n    bottom: 0;\n    height: 10px;\n    left: 0;\n    width: 100%;\n}\n.gongju2 .gongju-list{\n    margin-bottom: 0;    \n}\n.gongju2 .gongju-title{\n    width: 142px;\n    height: 52px;\n    float: left;    \n    margin-right: 20px;\n    overflow: hidden;\n    text-indent: -9999em;\n    /*background: url('data:image/png;base64,');*/\n    background: url('data:image/png;base64,')\n}\n.gongju2 .gongju-list .gongju-item{\n    /*border-right:1px solid #f00;*/\n    margin-right: 15px;   \n    padding-right: 15px;\n}\n.gongju2 .gongju-list .gongju-item .gongju-name{\n    font-size: 16px;\n    color: #333;\n    font-weight: 400;\n}\n.gongju2 .gongju-list .gongju-item .gongju-performance{\n    margin-left: 0;\n    margin-right: 5px;\n    padding: 0 2px;\n}\n.gongju2 .gongju-list .gongju-item .gongju-performance:last-child{\n    margin-right: 0;\n}\n\n.gongju2 .gongju-list .gongju-item .gongju-logo{\n    width: 52px;\n    height: 52px;\n    margin-right: 10px;\n}\n.gongju2 .gongju-list .gongju-item:last-child{\n    padding-left: 0;\n    border-right: 0;\n    margin-right: 0;\n}\n.gongju2 .gongju-list .gongju-item:last-child::after,.gongju2 .gongju-list .gongju-item.last::after{\n    display: none\n}\n.gongju2 .btn-more{\n    text-align: center;\n    color: #ffffff;\n    font-size: 14px;\n    display: inline-block;\n    width: 70px;\n    height: 32px;\n    line-height: 32px;\n    border-radius: 4px;\n    box-shadow: 0 4px 8px rgba(193, 148, 80, 0.4);\n    background: rgb(245, 203, 146);    \n    float: left;\n    margin-top: 10px;\n    position: relative;    \n    /* Old browsers */\n    background: -moz-linear-gradient(left, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* FF3.6-15 */\n    background: -webkit-linear-gradient(left, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* Chrome10-25,Safari5.1-6 */\n    background: linear-gradient(to right, rgba(245, 203, 146, 1) 0%, rgba(206, 145, 52, 1) 100%);\n    /* W3C, IE10+, FF16+, Chrome26+, Opera12+, Safari7+ */\n    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#f5cb92', endColorstr='#ce9134', GradientType=1);\n}\n</style>\n                    <div class=\"gongju gongju2 bggray2\">\n                        <div class=\"gongju-list clearfix\">\n                            <div class=\"gongju-title\">智能大数据</div>\n                            <div class=\"gongju-item\">   \n\t<a href=\"https://zx.500.com/gongju/detail.shtml#/privilege/compensate\" target=\"_blank\">\n\t<img src=\"https://www.500cache.com/news/images/service/tools/icon-tp-square.png\" alt=\"\" class=\"gongju-logo\">\n\t<div class=\"fl\">\n\t\t<h3 class=\"gongju-name\">历史同赔</h3>\n\t\t<div><span class=\"gongju-performance\">热门推荐</span></div>\n\t</div>      \n\t</a>      \n</div> \n\n\n\n\n\n<div class=\"gongju-item\">   \n\t<a href=\"https://zx.500.com/gongju/detail.shtml#/privilege/jczq2x1\" target=\"_blank\">\n\t<img src=\"https://www.500cache.com/news/images/service/tools/icon-jczq2x1-square.png\" alt=\"\" class=\"gongju-logo\">\n\t<div class=\"fl\">\n\t\t<h3 class=\"gongju-name\">精选2串1</h3>\n\t\t<div><span class=\"gongju-performance\">人气TOP1</span><span class=\"gongju-performance\">最高+1208%</span></div>\n\t</div>      \n\t</a>      \n</div> \n\n\n\n\n\n<div class=\"gongju-item\">   \n\t<a href=\"https://zx.500.com/gongju/detail.shtml#/privilege/poisson\" target=\"_blank\">\n\t<img src=\"https://www.500cache.com/news/images/service/tools/icon-yp-square.png\" alt=\"\" class=\"gongju-logo\">\n\t<div class=\"fl\">\n\t\t<h3 class=\"gongju-name\">泊松亚指</h3>\n\t\t<div><span class=\"gongju-performance\">命中上升期</span><span class=\"gongju-performance\">最高15连中</span></div>\n\t</div>      \n\t</a>      \n</div> \n\n\n\n\n\n<div class=\"gongju-item\">   \n\t<a href=\"https://zx.500.com/gongju/detail.shtml#/privilege/bigdata\" target=\"_blank\">\n\t<img src=\"https://www.500cache.com/news/images/service/tools/icon-ai-square.png\" alt=\"\" class=\"gongju-logo\">\n\t<div class=\"fl\">\n\t\t<h3 class=\"gongju-name\">胜平负锦囊</h3>\n\t\t<div><span class=\"gongju-performance\">8连中</span><span class=\"gongju-performance\">近7日79%命中</span><span class=\"gongju-performance\">最高21连中</span></div>\n\t</div>      \n\t</a>      \n</div> \n\n\n\n\n\n\n                            <a href=\"//zx.500.com/gongju/\" target=\"_blank\" class=\"btn-more\">更多&gt;</a>\n                        </div>\n                    </div>\n                "
