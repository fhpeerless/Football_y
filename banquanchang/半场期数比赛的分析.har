          "content": {
            "size": 3894,
            "mimeType": "application/javascript",
            "text": "var jcwCtzcBetsNums = {\n    //直选玩法，例：bnContent=\"3,2,1,2,3,1,2,3,1,2,3,1,2,3\"\n    czCalculator: function (bnContent) {\n        var bnCount = 1;\n        for (var i = 0; i < bnContent.length; i++) {\n            bnCount = bnCount * bnContent[i];\n        }\n        return bnCount;\n    },\n    czCalCost: function (count, times) {\n        return parseInt(count) * parseInt(times) * 2;\n    },\n    setBetsCost: function () {\n        var betsTimes = vm.$children[0].betTimesNum;\n        var betsNumber = $(\".m-czBox em.red:first\").html();\n        var betsCosts = jcwCtzcBetsNums.czCalCost(betsNumber, betsTimes);\n        $(\".m-czBox em.red:last\").html(betsCosts);\n    },\n    setBetsCount: function () {\n        var selectedBets = Array();\n        var isCal = 0;\n        var czGameType = $(\"#ctzc_jsq .m-czTitle .m-czTitle-l li\").index($(\"#ctzc_jsq .m-czTitle .m-czTitle-l .on\"));\n        $(\".m-czTab tr .tdOption .tdDiv\").each(function () {\n            isCal++;\n            var sltdBetNums = $(this).find(\".on\").length;\n            if (sltdBetNums > 0) {\n                selectedBets.push(sltdBetNums);\n            }\n        });\n        if (selectedBets.length > 0) {\n            $(\".m-czBox span.u-icon\").addClass(\"blue\");\n        } else {\n            $(\".m-czBox span.u-icon\").removeClass(\"blue\");\n        }\n        if (czGameType === 1) {\n            if (selectedBets.length > 8) {\n                var betsCount = jcwCtzcBetsNums.calcuterRxj(selectedBets);\n                $(\".m-czBox em.red:first\").html(betsCount);\n            } else {\n                $(\".m-czBox em.red:first\").html(0);\n            }\n        } else {\n            if (selectedBets.length == isCal) {\n                var betsCount = jcwCtzcBetsNums.czCalculator(selectedBets);\n                $(\".m-czBox em.red:first\").html(betsCount);\n            } else {\n                $(\".m-czBox em.red:first\").html(0);\n            }\n        }\n    },\n    clearAllBets: function (e) {\n        if ($(e).hasClass(\"blue\")) {\n            $(\".tdOption .tdDiv span\").removeClass(\"on\");\n            $(\".m-czBox em.red:first\").html(0);\n            $(\".m-czBox em.red:last\").html(0);\n            vm.$children[0].betTimesNum = 1\n            $(e).removeClass(\"blue\");\n        }\n    },\n    clearJsqPfl: function () {\n        $(\".tdOption .tdDiv span\").removeClass(\"on\");\n        $(\".m-czBox em.red:first\").html(0);\n        $(\".m-czBox em.red:last\").html(0);\n        vm.$children[0].betTimesNum = 1\n        $(\".m-czBox .u-icon\").removeClass(\"blue\");\n    },\n    selectBets: function (e) {\n        if ($(e).hasClass(\"on\")) {\n            $(e).removeClass(\"on\");\n        } else {\n            $(e).addClass(\"on\");\n        }\n        jcwCtzcBetsNums.setBetsCount();\n        jcwCtzcBetsNums.setBetsCost();\n    },\n    calcuterRxj: function (calData) {\n        var result = this.getNumbers(calData, 9);\n        var sum = 0;\n        for (var i = 0; i < result.length; i++) {\n            sum += jcwCtzcBetsNums.czCalculator(result[i]);\n        }\n        return sum;\n    },\n    getNumbers: function (arr, size) {\n        var allResult = [];\n\n        (function (arr, size, result) {\n            var arrLen = arr.length;\n            if (size > arrLen) {\n                return;\n            }\n            if (size == arrLen) {\n                allResult.push([].concat(result, arr))\n            } else {\n                for (var i = 0; i < arrLen; i++) {\n                    var newResult = [].concat(result);\n                    newResult.push(arr[i]);\n\n                    if (size == 1) {\n                        allResult.push(newResult);\n                    } else {\n                        var newArr = [].concat(arr);\n                        newArr.splice(0, i + 1);\n                        arguments.callee(newArr, size - 1, newResult);\n                    }\n                }\n            }\n        })(arr, size, []);\n\n        return allResult;\n    }\n}"
