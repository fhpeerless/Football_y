          "cookies": [],
          "content": {
            "size": 15597,
            "mimeType": "text/css",
            "text": "@charset \"UTF-8\";\n/*重置*/\nbody, div, p, ul, li, dl, dt, dd, h1, h2, h3, h4, h5, h6, table, tr, th, td, strong, span, em, i, form, input, select, textarea, button, img, a {\n    padding: 0;\n    margin: 0;\n    -moz-box-sizing: border-box;\n    -webkit-box-sizing: border-box;\n    box-sizing: border-box;\n}\nbody{font-family:PingFangSC-Regular,\"Microsoft YaHei\", Arial;color:#181818;}\n.clear:after {\n    content: '';\n    clear: both;\n    display: block;\n    height: 0;\n    visibility: hidden;\n}\na{color:#666;text-decoration:none;cursor:pointer;}\na:hover{color:#e01212;}\na.a-arrow, a.a-arrow:hover,a.a-arrow:active{cursor:default;}\ni,em{font-style:normal;}\nimg{display:inline-block;vertical-align:middle;border:none;}\nli{list-style:none;}\n.f-fl{float:left !important;}\n.f-fr{float:right !important;}\n/* 按钮 */\n.btnWhite, .btnRed{border:1px solid #e01212; border-radius:4px; background:#e01212; text-align:center; cursor:pointer; color:#fff;}\n.btnWhite{border:1px solid #d8d8d8; background:#fff; color:#181818;}\n.btnS{width:240px; height:32px; line-height:30px; font-size:14px;}\n.btnxS{width:100px; height:32px; line-height:30px; font-size:14px;}\n.btnN{width:200px; height:50px; line-height:48px;}\n.btnRed:hover{border:1px solid #ce2a33; background:#ce2a33; color:#fff;}\n.btnWhite:hover{background:#f2f2f2; color:#181818;}\n.btnLoad, .btnLoad:hover{border:1px solid #ce2a33; background:url(\"../images/btnloag.gif\") #ce2a33 no-repeat center; background-size:16px;}\n/********** 传足投注-左侧 **********/\n#ctzc_jsq{\n\twidth: 1180px;\n\tmargin: 0 auto;\n\tposition: relative;\n\tborder-bottom: 1px solid #D7D7D7;\n}\n.m-czL{\n\tposition:relative;\n\twidth:100%;\n\tbackground:#fff;\n\tborder-radius:4px;\n}\n/*****传足投注-标题*****/\n.m-czTitle{\n\tposition:relative;\n\theight:60px;\n\tline-height:60px;\n\tbackground-color: #404650;\n\tborder-top-left-radius: 5px;\n\tborder-top-right-radius: 5px;\n\tbackground-size:1180px 60px;\n\tfont-size:14px;\n\tcolor:#d8d8d8;\n}\n/*传足投注-标题-左*/\n.m-czTitle-l li{\n\tposition:relative;\n\tfloat:left;\n\ttext-align:center;\n\twidth:150px;\n\tfont-size:20px;\n\tcursor:pointer;\n}\n.m-czTitle-l li:after{\n    position:absolute;\n\ttop:6px;\n\tright:0;\n\tcontent:'';\n\twidth:3px;\n\theight:50px;\n\tbackground:url(../jcw/images/cz/lotto_title_line.png) no-repeat;\n\tbackground-size:3px;\n}\n.m-czTitle-l li.on{ \n\theight: 60px; \n\tbackground-color: #27292E; \n\tcolor:#fff;\n\tborder-top-left-radius: 5px;\n\tborder-top-right-radius: 5px;\n}\n.m-czTitle-l li.on:before,\n.m-czTitle-l li:hover:before{\n\tcontent:\"\";\n\tposition:absolute;\n\tbottom:10px;\n\tleft:50%;\n\tdisplay:block;\n\tmargin-left:-12px;\n\ttext-align:center;\n\twidth:28px;\n\theight:2px;\n\tbackground:#fff;\n}\n.m-czTitle-l li.on:after{background:none}\n.m-czTitle-l li:hover{color:#fff}\n/*传足投注-标题-右.单注最高奖金*/\n.m-czTitle-r{\n\tfont-size:16px;\n}\n.m-czTitle-r span{\n\tdisplay:inline-block;\n\tmargin:0 30px 0 15px;\n\tpadding:0 9px;\n\ttext-align:left;\n\twidth:93px;\n\theight:29px;\n\tline-height:29px;\n\tbackground-color: #27292E;\n\tborder-radius: 5px;\n\tfont-size:16px;\n}\n.m-czTitle-r span em{\n\tpadding-right:5px;\n\tfont-size:14px;\n\tcolor:#fff44d;\n}\n/*传足投注-标题-右.玩法规则*/\n.m-czRule{position:relative; padding:0 32px}\n.m-czRule:after{\n\tposition: absolute;\n    top: 6px;\n    left: 0;\n    content: '';\n    width: 3px;\n    height: 50px;\n    background: url(../jcw/images/cz/lotto_title_line.png) no-repeat;\n    background-size: 3px;\n}\n.m-czRule .ico-12:before{background: url(../jcw/images/cz/icon_txt.svg) no-repeat}\n/*****乐透投注-玩法提示*****/\n.m-sfcL,.m-r9L,.m-bqcL,.m-zjqL{\n\tborder-left: 1px solid #D7D7D7;\n\tborder-right: 1px solid #D7D7D7;\n}\n.m-czNotice{\n\tposition:relative;\n\tpadding:18px 0 0 30px;\n\theight:66px;\n\tbackground:#fff url(../jcw/images/cz/lotto_intro_bg.png) no-repeat left bottom;\n\tbackground-size:1180px;\n\tcolor:#666;\n}\n/*****在售奖期和即将开售tab*****/\n.m-zstab{\n\theight: 42px;\n\tline-height: 42px;\n\twidth: 506px;\n\tborder-bottom: 1px solid #E4E4E4;\n\toverflow: hidden;\n\tmargin-left: 40px;\n\tmargin-top: 10px;\n}\n.m-zstab li{\n\twidth: 96px;\n\ttext-align: center;\n\tcolor: #666666;\n\tfont-size: 18px;\n\tborder-bottom: 1px solid #ffffff;\n\tfloat: left;\n\theight: 41px;\n\tmargin-right: 30px;\n\tcursor: pointer;\n}\n.m-zstab li.on{\n\twidth: 96px;\n\ttext-align: center;\n\tcolor: #E34E46;\n\tfont-size: 18px;\n\tborder-bottom: 1px solid #E34E46;\n}\n/*****乐透投注-期次&截止时间*****/\n.m-czTime{\n\twidth:100%;\n\tpadding:27px 40px 26px 40px;\n\tfont-size:14px;\n    color:#666;\n}\n.m-czTime-l{position:relative;}\n/*箭头*/\n.m-czTime-l .u-arrowL,\n.m-czTime-l .u-arrowR{\n    position:absolute;\n\ttop:0;\n\tdisplay:block;\n\tbackground:url(../jcw/images/cz/ico_arrow_right.png) no-repeat center center;\n\tpadding:8px 10px 9px;\n\twidth:30px;\n\theight:34px;\n}\n.m-czTime-l .u-arrowL{\n\tleft:-30px;\n\t-moz-transform:scaleX(-1);\n    -webkit-transform:scaleX(-1);\n    -o-transform:scaleX(-1);\n    transform:scaleX(-1);\n    filter:FlipH;\n}\n.m-czTime-l .u-arrowR{right:-30px;}\n/*期次*/\n.m-czNums{\n\tborder:1px solid #d8d8d8;\n\tborder-radius:4px;\n\ttext-align:left;\n\tmax-width:506px;\n\theight:40px;\n\toverflow:hidden;\n}\n.m-czNums ul{white-space:nowrap;}\n.m-czNums li{\n\tfloat:left;\n\ttext-align:center;\n\tborder-right:1px solid #d8d8d8;\n\tbackground:url(../jcw/images/cz/cz_time.png) repeat-x;\n\tbackground-size: contain;\n\twidth:126px;\n\theight:40px;\n\tline-height:40px;\n\tcursor:pointer;\n\tfont-size: 16px;\n}\n.m-czNums li:last-child{border:none}\n.m-czNums li.on{background:url(../jcw/images/cz/cz_time_on.png) repeat-x;background-size: contain;}\n.m-czNums li.on,\n.m-czNums li:hover{color:#181818}\n.m-czNums li span{margin-right:5px}\n/*投注截止时间*/\n.m-czTime-r{height:34px; line-height:34px; font-size: 16px}\n/*****传足投注-区域*****/\n.m-czBet{position:relative;margin:0 auto;width:1100px;}\n.m-czTab{\n\tmargin:0 auto;\n\tborder:1px solid #d8d8d8;\n\tborder-radius:4px;\n\tborder-collapse:separate;\n\ttable-layout:fixed;\n\twidth:1100px;\n\tfont-size:14px;\n\tcolor:#666;\n\toverflow:hidden;\n}\n.m-czTab th{\n\ttext-align:center;\n\tborder-right:1px solid #d8d8d8;\n\tborder-bottom:1px solid #d8d8d8;\n\tbackground:#f5f5f5;\n\theight:58px;\n\tfont-weight:normal;\n}\n.m-czTab th strong{\n\tfloat:left;\n\tdisplay:block;\n\tborder-bottom:1px solid #d8d8d8;\n\twidth:100%;\n\theight:29px;\n\tline-height:29px;\n\tfont-weight:normal;\n}\n.m-czTab td{\n\ttext-align:center;\n\tborder-right:1px solid #ececec;\n\tborder-bottom:1px solid #ececec;\n\theight:40px;\n}\n.m-czTab .tdTeam, .m-czTab .tdOption{border-right:1px solid #d8d8d8}\n.m-czTab .tdOption{border-bottom:1px solid #d8d8d8}\n.m-czTab tr th:last-child, .m-czTab tr td:last-child{border-right:none}\n.m-czTab tr:last-child td{border-bottom:0;height:34px}\n/*联赛*/\n.tdLs{font-size: 16px}\n.tdLs a, .tdLs a:hover{color:#666;}\n.tdLs a:hover{text-decoration:underline; color: #e01212}\n/*主/客队*/\n.team{position:relative; font-size: 16px}\n.teamL, .teamVs, .teamR{display:inline-block}\n.teamL, .teamR{position:absolute; width:46%; color:#999}\n.teamL{top:0; left:0; text-align:right;padding-right:5px}\n.teamR{top:0; right:0; text-align:left;padding-left:5px}\n.team .gray{font-size: 16px;}\n.teamVs{text-align:center;color:#999}\n.teamL a,.teamR a{color:#181818;font-size: 16px;}\n.teamL a:hover,.teamR a:hover{color:#e01212;}\n.teamL a{padding-left:5px}\n.teamR a{padding-right:5px}\n.team a{color: #999}\n.team a .teamL,.team a .teamR {color:#181818}\n.team a:hover .teamL,.team a:hover .teamR {color:#e01212}\n.m-czTab th .teamL,\n.m-czTab th .teamR,\n.m-czTab th .teamVs{color:#666}\n/*thDiv & tdDiv*/\n.thDiv, .tdDiv{width:100.5%; overflow:hidden}\n.thDiv span,.tdDiv span{\n    float:left;\n\tdisplay:block;\n\tborder-right:1px solid #d8d8d8;\n\twidth:33.3%;\n}\n.thDiv span{height:29px; line-height:29px}\n.tdDiv span{border-right:1px solid #ececec; height:40px; line-height:40px}\n.tdOption .tdDiv span{border-right:1px solid #d8d8d8}\n.tdOption .thDiv span:last-child,.tdOption .tdDiv span:last-child{border-right:none; width:calc(33.3% - 0.5px);width:-webkit-calc(33.3% - 0.5px);width:-moz-calc(33.3% - 0.5px);}\n/*选项*/\n.tdOption .tdDiv span{cursor:pointer; color:#181818;width: 33.3%}\n.tdOption .tdDiv span em{\n\tdisplay:block;\n\tborder:1px solid #fff;\n\tbackground:url(../jcw/images/cz/cz_td_bg.png) repeat-x;\n\tbackground-size: contain;\n\theight:40px;\n\tline-height:40px;\n\tfont-size:16px;\n}\n.tdOption .tdDiv span.on em{background:#df3d3d;color:#fff}\n/*竞彩*/\n.tdJc .tdDiv span{position:relative}\n.u-arrow{\n\tposition:absolute;\n\tright:1px;\n\tdisplay:inline-block;\n\twidth:8px;\n\theight:8px;\n}\n.u-arrowUp{background:url(../jcw/images/cz/icon_up.svg) no-repeat; top:13px}\n.u-arrowDown{background:url(../jcw/images/cz/icon_down.svg) no-repeat; top:14px}\n/*资讯*/\n.tdInfo a.blue:hover,.m-czTab td:last-child a.blue:hover{text-decoration:underline}\n/*数据*/\n.tdData{color:#999}\n.tdData em{\n\tdisplay:inline-block;\n\tmargin-left:3px;\n\twidth:9px;\n\theight:6px;\n\tbackground:url(../jcw/images/cz/lc_arrow_u.png) no-repeat;\n\tbackground-size:9px;\n\tcolor:#999;\n\ttransform:rotate(-180deg);\n}\n.tdData.on em{transform:rotate(0deg)}\n.m-czTab tr .tdDataCon{background:#fffcf5; border-bottom:1px solid #d8d8d8;}\n.m-czTab tr .tdDataCon,\n.m-czTab tr:last-child td.tdDataCon{height:107px}\n.tdDataTab{margin:0 auto; width:820px;}\n.tdDataTab tr th,\n.tdDataTab tr td{\n\ttext-align:left;\n\theight:36px;\n\tline-height:35px;\n\tborder-right:none;\n\tborder-bottom:1px dashed #ececec;\n}\n.tdDataTab tr th{background:none; padding-left:20px}\n.tdDataTab tr:last-child th{border-bottom:none}\n.u-block{\n\tfloat:left;\n\tdisplay:inline-block;\n\tmargin-right:5px;\n\ttext-align:center;\n\tborder-radius:4px;\n\twidth:16px;\n\theight:16px;\n\tline-height:16px;\n\tcolor:#fff;\n}\n.bg-red{background:#f83d3d !important;}\n.bg-green{background:#22b573 !important;}\n.bg-blue{background:#499bf4 !important;}\n.green{color:#22b573 !important;}\n.u-more:hover{text-decoration:underline}\n/*6场半全场 & 4场进球*/\n.m-czBqcTab .thDiv span,.m-czBqcTab .tdDiv span{width:33.3%;}\n.m-czBqcTab .thDiv span:last-child,.m-czBqcTab .tdDiv span:last-child{width:calc(33.3% - 0.5px);width:-webkit-calc(33.3% - 0.5px);width:-moz-calc(33.3% - 0.5px);}\n.m-czBqcTab .tdTime,.m-czTab .tdTime{text-align:center; padding:0 10px}\n.m-czBqcTab .tdTeam{border-right:1px solid #ececec}\n.m-czBqcTab .tdBqc{border-right:1px solid #d8d8d8}\n.m-czBqcTab .tdBqc span{display:inline-block; width:100%; height:40px; line-height:40px}\n.m-czBqcTab .tdBqc span:first-child{border-bottom:1px solid #ececec; height:40px}\n.m-czBqcTab .tdOption .tdDiv:first-child{border-bottom:1px solid #d8d8d8; height:40px}\n.m-czBqcTab .tdJc .tdDiv span{height:80px; line-height:80px}\n.m-czBqcTab .tdJc .u-arrowUp{background:url(../jcw/images/cz/icon_up.svg) no-repeat; top:30px; right:2px;}\n.m-czBqcTab .tdJc .u-arrowDown{background:url(../jcw/images/cz/icon_down.svg) no-repeat; top:31px; right:2px;}\n.m-czZjqTab .thDiv span,.m-czZjqTab .tdDiv span{width:45px;}\n.m-czZjqTab .thDiv span:last-child,.m-czZjqTab .tdDiv span:last-child{width:calc(25% - 0.5px);width:-webkit-calc(25% - 0.5px);width:-moz-calc(25% - 0.5px);}\n.m-czZjqTab .tdJc span{display:block;width:100%;height:40px;line-height:40px;}\n.m-czZjqTab .tdJc span:first-child{border-bottom:1px solid #ececec;}\n/*弹窗*/\n.m-czWin{\n\tz-index:9;\n\tposition:absolute;\n\ttop:75px;\n\tleft:525px;\n\tbox-shadow:0 0 8px #d8d8d8; \n\tborder-radius:4px;\n\tbackground:#fff;\n\tpadding-bottom:5px;\n\twidth:280px;\n\tmax-height:151px;\n\tfont-size:12px;\n}\n.m-czWin:before{\n\tdisplay:block;\n\tmargin:-6px auto 5px;\n\ttext-align:center;\n\tcontent:\"\";\n\twidth:0;\n    height:0;\n    border-left:3px solid transparent;\n    border-right:3px solid transparent;\n    border-bottom:6px solid #fff;\n}\n.m-czWin .title{\n\tmargin:0 auto;\n\twidth:266px;\n\theight:20px;\n\tline-height:20px;\n\ttext-align:center;\n\tborder-radius:4px 4px 0 0;\n\tbackground:#666;\n\tcolor:#fff;\n}\n.m-tabTitle{margin:0 auto;width:266px;height:25px;line-height:25px;}\n.m-tabTitle th{font-weight:normal; color:#666;}\n.m-czWin-con{width:100%; max-height:100px; overflow-y:auto;overflow-x:hidden;}\n.m-czWin-con::-webkit-scrollbar{width:4px; height:4px;}\n.m-czWin-con::-webkit-scrollbar-thumb{border-radius:5px; background:#d8d8d8;}\n.m-czWin-con::-webkit-scrollbar-track{border-radius:0; background:#fff;}\n.m-czWin-con table{margin:0 auto;width:266px;}\n.m-czWin-con table td{position:relative;text-align:center;height:25px;}\n.m-czWin-con table td .u-arrow{top:8.5px;}\n.m-czWin-con table tr:nth-child(odd) td{background:#ececec}\n/*传足无赛事*/\n.m-czNo{text-align:center; padding:249px 0}\n.m-czNo img{width:196px; height:196px;}\n/*****传足投注-漂浮栏*****/\n.m-czBox{\n\tposition: relative;\n\tbox-shadow:0px -5px 8px #ececec;\n\tbackground:#fff;\n\tpadding:28px 30px;\n\twidth:100%;\n\theight:88px;\n\tfont-size: 16px;\n\tborder: 1px solid #D7D7D7;\n\tborder-top: none;\n\tborder-bottom: none;\n}\n/*清空选项*/\n.u-icon{float:left; position:relative; margin-top:6px; height:20px; line-height:20px; color:#999;}\n.u-icon .ico-12{cursor:default;padding-left: 20px;font-size: 14px}\n.u-icon .ico-12:before{position:absolute; left:0; top:2px; background:url(../jcw/images/cz/icon_delete_gray.svg) no-repeat;content:\"\";width: 16px; height: 16px;background-size: 16px 16px;}\n.u-icon.blue .ico-12{cursor:pointer}\n.u-icon.blue .ico-12:before{background:url(../jcw/images/cz/icon_delete.svg) no-repeat;width: 16px; height: 16px;background-size: 16px 16px;padding-left: 15px; content:\"\";}\n/*投注倍数*/\n.u-multiple{float:left; margin:4px 50px 0 70px; color:#666;font-size: 16px}\n.u-multiple span{display:inline-block; float:left; height:28px; line-height:28px; color:#666;}\n.m-inpt{margin:0 10px; border:1px solid #d8d8d8; border-radius:4px;}\n.u-sub, .u-add{float:left; text-align:center; width:28px; height:26px; line-height:25px; cursor:pointer; overflow:hidden;}\n.u-sub{border-right:1px solid #d8d8d8;line-height: 27px}\n.u-add{border-left:1px solid #d8d8d8;}\n.m-inpt input{float:left; border:none; text-align:center; width:48px; height:26px; padding-top:1px; font-size:16px; color:#181818;}\n.m-inpt:hover{border:1px solid #499bf4;}\n.m-inpt .u-sub:hover,\n.m-inpt .u-add:hover{color:#499bf4;}\n.m-inpt .u-sub.gray:hover,\n.m-inpt .u-add.gray:hover{cursor:default;}\n/*注数&金额*/\n.m-czBox em.red{padding:0 5px}\n.m-czBox p{display:inline-block; padding-top:7px; line-height:18px; font-size:16px; color:#666}\n.m-czBox p span.gray{font-size:14px}\n/*按钮*/\n.m-czBox .bigBtn{float:right; display:inline-block; margin-left:15px;}\n.m-czComment{font-size: 14px;color: #666666; width: 1180px;\tmargin: 0 auto; padding: 16px 0}\n\n.m-bonus { color: #181818; margin: 30px 0;}\n.m-bonus-title { text-align: center; font-size: 14px; margin-bottom: 16px; display: flex; align-items: center;\n\tjustify-content: space-between;}\n.m-bonus-content { display: flex; font-size: 12px; align-items: center;\tjustify-content: center;}\n.m-bonus-sales { display: flex; }\n.m-bonus-first { display: flex;  align-items: center;}\n.m-bonus-second { display: flex; align-items: center;}\n.m-bonus-next {display: flex; align-items: center;}\n.m-bonus-first span.m-bonus-red, .m-bonus-second span.m-bonus-red, .m-bonus-next span.m-bonus-red, .m-bonus-sales span.m-bonus-red{ color: #FA5B57; padding: 0 2px; font-size: 12px;}\n.m-bonus-line {\tborder-left: 1px solid #b2b2b2;\theight: 16px; display: inline-block; margin: 0 10px;}\n.m-bonus-first div, .m-bonus-second div, .m-bonus-next div {\tmargin-right: 6px;}\n.m-bonus-first div:last-child, .m-bonus-second div:last-child, .m-bonus-next div:last-child {\tmargin-right: 0px;}\n.m-bonus-title-left { margin-left: 40px; width: 466px; height: 0; border-top: 1px solid #d8d8d8; }\n.m-bonus-title-right { margin-right: 40px; width: 466px; height: 0; border-top: 1px solid #d8d8d8; }\n.m-bonus-pad6 {\tpadding-right: 0; display: inline-block}\n"
