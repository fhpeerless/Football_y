            "text": "@charset \"UTF-8\";\n/* 小幻灯片 */\n.g-banner1 .swiper-container {width: 100%;height: 212px;}\n.g-banner1 img {width: 100%;height: 210px;}\n.g-banner1 .swiper-pagination {width: auto !important;left: auto !important;right: 8px;bottom: 8px;}\n.g-banner1 .swiper-pagination-bullet {\n    float: left;\n    margin: 0 3px !important;\n    width: 10px;\n    height: 10px;\n    font-size: 0;\n    opacity: 1;\n    border: 2px solid #fff;\n    border-radius: 50%;\n    background-color: rgba(255, 255, 255, 0);\n}\n.g-banner1 .swiper-pagination-bullet-active {border: none !important;background-color: #fd5f20;}\n.g-banner1 .u-banner1-tit  {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    padding-right: 100px;\n    padding-left: 16px;\n    width: 100%;\n    height: 32px;\n    line-height: 32px;\n    color: #fff;\n    background: rgba(0, 0, 0, .6);\n}\n/* 通栏幻灯片 */\n.g-banner2 .swiper-container{width: 100%;height: 70px;}\n.g-banner2 img {width: 100%;height: 70px;}\n/* 灰阶错位问题修复 */\n.u-graySwiper{\n    display: block;\n    position: relative;\n}"
