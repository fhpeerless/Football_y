          ],
          "cookies": [],
          "content": {
            "size": 3417,
            "mimeType": "application/javascript",
            "text": "\nvar loginTipsHtml = `\n<style>\n/**\n * 弹窗遮罩层样式\n * 全屏覆盖，居中显示弹窗内容\n */\n.login-tips-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(0, 0, 0, 0.5);  /* 半透明黑色背景 */\n    z-index: 10000;                     /* 确保在最顶层 */\n    display: flex;\n    justify-content: center;            /* 水平居中 */\n    align-items: center;                /* 垂直居中 */\n}\n\n/**\n * 弹窗主体样式\n * 固定宽高，使用背景图，圆角带阴影\n */\n.login-tips {\n    width: 720px;\n    height: 497px;         /* 背景图自适应 */\n    position: relative;                 /* 相对定位，内部元素绝对定位 */\n}\n\n/**\n * 关闭按钮样式（右上角X）\n * 使用伪元素绘制X图标 */\n.login-tips-close {\n    position: absolute;\n    top: 16px;\n    right: 16px;\n    width: 16px;\n    height: 16px;\n    cursor: pointer;                   /* 鼠标变为手型 */\n    z-index: 15;\n}\n\n.login-tips-close::before,\n.login-tips-close::after {\n    content: '';\n    position: absolute;\n    width: 16px;\n    height: 2px;\n    background: #666;                  /* 灰色X线 */\n    top: 7px;\n    left: 0;\n}\n\n.login-tips-close::before {\n    transform: rotate(45deg);          /* 顺时针45度 */\n}\n\n.login-tips-close::after {\n    transform: rotate(-45deg);         /* 逆时针45度 */\n}\n</style>\n\n<!-- 弹窗DOM结构 -->\n<div class=\"login-tips-overlay\" id=\"loginTipsOverlay\">\n    <div class=\"login-tips\" id=\"loginTips\">\n        <!-- 关闭按钮 -->\n        <div class=\"login-tips-close\" id=\"loginTipsClose\"></div>\n        <img src=\"https://static.sporttery.cn/res_1_0/jcw/images/login/xxfc.png\" alt=\"\" class=\"login-tips-arrow\">\n<!--<img src=\"//static.sporttery.cn/res_1_0/jcw/upload/teamlogo/xxfc.png\" alt=\"\" class=\"login-tips-arrow\">-->\n    </div>\n</div>\n`;\nloginTips = {\n    show: function() {\n        var overlay = document.getElementById('loginTipsOverlay');\n        if (overlay) {\n            // 弹窗已存在，直接显示\n            overlay.style.display = 'flex';\n        } else {\n            // 弹窗不存在，插入HTML并绑定事件\n            document.body.insertAdjacentHTML('beforeend', loginTipsHtml);\n            this.bindEvents();\n        }\n        // 显示弹窗时不调用接口，协议勾选后才生成二维码\n    },\n    bindEvents: function() {\n\n        // 绑定关闭按钮点击事件\n        var closeBtn = document.getElementById('loginTipsClose');\n        if (closeBtn) {\n            closeBtn.onclick = function() {\n                loginTips.hide();\n            };\n        }\n\n        // 绑定遮罩层点击事件（点击遮罩关闭弹窗）\n        var overlay = document.getElementById('loginTipsOverlay');\n        if (overlay) {\n            overlay.onclick = function(e) {\n                // 只有点击遮罩层本身（不是弹窗内容）才关闭\n                if (e.target === overlay) {\n                    loginTips.hide();\n                }\n            };\n        }\n    },\n    hide: function() {\n        var overlay = document.getElementById('loginTipsOverlay');\n        if (overlay) {\n            overlay.style.display = 'none';\n        }\n    }\n}\n\nfunction showLoginTips() {\n    loginTips.show();\n}\n\nfunction getSubscribeStatus(data) {\n    if(Object.keys(data).length>0 && data.subscribeConfig == 0){\n        window.showLoginTips()\n    }\n}"
          },
