            "mimeType": "text/css",
            "text": "@charset \"UTF-8\";\n/* tab切换 */\n.m-list .nav{height: 48px;line-height: 42px;padding-top: 4px;}\n.m-list .nav li{position: relative;margin-right: 32px;}\n.m-list .nav li:last-child{margin-right: 0;}\n.m-list .nav li:after{position: absolute;top:50%;right: -16px;margin-top: -8px;display: block;content: \"\";width: 1px;height: 16px;background-color: #d8d8d8;}\n.m-list .nav li:last-child:after{display: none;}\n.m-list .nav-link{padding: 0;}\n.m-list .nav .active{border-bottom:2px solid #e01212;display: block;}\n.list-cirl{width: 10px;display: inline-block;}\n/* tab1切换 */\n.m-list1 .nav{height: 50px;}\n.m-list1 .nav li{height: 50px;line-height: 47px;}\n.m-list1 .nav li span{\n    display: block;\n    cursor: pointer;\n    padding: 0 32px;\n    vertical-align: middle;\n    border-left:1px solid rgba(255,255,255,0);\n    border-right:1px solid rgba(255,255,255,0);\n    border-bottom:1px solid rgba(255,255,255,0);\n    border-top:2px solid rgba(255,255,255,0);\n}\n.m-list1 .nav li span.active{\n    color:#e01212;\n    border-left:1px solid #d8d8d8;\n    border-right:1px solid #d8d8d8;\n    border-bottom:2px solid #fff;\n    border-top:2px solid #e01212;\n    background:linear-gradient(180deg,rgba(236,236,236,1) 0%,rgba(255,255,255,1) 62%);\n}\n/* 传足页面 */\n.m-list-news{margin-top: 8px;}\n.m-list-news h3,.m-list-hot{\n    font-weight: bold;\n    font-size: 16px;\n    line-height: 28px;\n    margin-bottom: 0;\n}\n.m-list-news p{\n    margin-bottom: 0;\n    text-indent: 2em;\n    line-height: 28px;\n    color: #999999;\n}\n.u-list-hot{\n    white-space: nowrap;\n    font-size: 16px;\n}\n.m-list-hot{margin-top: 12px;line-height: 20px;}\n/* 传足页面的快捷入口 */\n.lottery-box-cz{\n    width: 100%;\n    margin-bottom: 16px;\n    /*border: 1px solid #ffe49c;\n    background-color: #fffdf4;*/\n}\n.lotto-icon-cz{\n    display: flex;\n    margin-bottom: 0;\n    text-align: center;\n    color: #ff6000;\n    font-weight: bold;\n    /*border-bottom: 1px solid #ffe49c;*/\n}\n.lotto-icon-cz li{\n    flex: 1;\n    /*padding-top: 32px;*/\n    padding-bottom: 12px;\n}\n.lotto-icon-cz li a{\n    color: #ff6000;\n    display: inline-block;\n}\n.lotto-icon-cz li a img{\n    width: 42px;\n    height: 45px;\n    margin-bottom: 8px;\n}\n.lotto-link-cz{\n    display: flex;\n    margin-bottom: 0;\n    /*padding-top: 12px;\n    padding-bottom: 12px;*/\n    text-align: center;\n}\n.lotto-link-cz li{\n    flex: 1;\n}\n.chart-table{\n\tmargin-top:5px;\n}\n.chart-table td{\n\tfont-size:14px; \n\theight:30px; \n\tline-height:30px;\n}\n/* 传足 */\n.list-unstyled li span.color-666{\n    white-space:nowrap;\n}\n.cz-nav .g-tit-list,.cz-nav .g-tit-list li { list-style: none; margin: 0}\n.cz-nav .g-tit-list { display: flex; align-items: center; justify-content: flex-end; }\n.cz-nav .g-tit-list li a{ color: #001818;}\n.cz-nav .g-tit-list li a:hover{ color: #e01212;}\n.cz-nav .g-tit-list li { padding:6px 12px 0;}\n.cz-nav .g-tit-list li img {margin-right: 8px; width: 20px; height: 20px;}\n\n/*传足新老切换*/\n.cz-new-switch ul, .cz-new-switch ul li { padding: 0; margin: 0; list-style: none}\n.cz-new-switch {position: fixed;top: 200px;left: 50%; margin-left: 609px; z-index: 998;}\n.cz-new-switch ul li img { width: 64px;}"
          },
