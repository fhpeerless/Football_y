          "content": {
            "size": 6179,
            "mimeType": "text/html",
            "text": "<!doctype html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n    <meta name=\"viewport\" content=\"width=1212, maximum-scale=1.0, user-scalable=no\" />\n    <base target=\"_blank\">\n    <meta name=\"applicable-device\" content=\"pc\">\n    <meta http-equiv=\"keywords\" content=\"\" />\n    <meta http-equiv=\"description\" content=\"\" />\n    <title>传足计算器</title>\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/css/bootstrap.min.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/swiper-5.4.1/css/swiper.min.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/reset_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/menu_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/banner_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/list_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/lotto_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/footer.css\">\n<script>\n  function domainPreV1(tid){try{var temDomain=document.domain.split(\".\");if(tid==1){if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return temDomain[0]}else{return\"www\"}}else{if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return 'mgray'}else{return\"m\"}}}catch(e){if(tid==1){return\"www\"}else{return\"m\"}}};\n   var jsCommonDataV1={\n            advUrl:\"/htmlfrag\",\n            webApi: \"//webapi.sporttery.cn\",\n            resDomain: \"//static.sporttery.cn\",\n            res: \"//static.sporttery.cn/res_1_0/jcw/default\",\n            env: \"prd\",\n            domain1:\"www.lottery.gov.cn\"\n            ,domain2:\"www.sporttery.cn\"\n            ,domain3:\"m.lottery.gov.cn\"\n            ,domain4:\"m.sporttery.cn\"\n            ,domain5:domainPreV1(1)+\".lottery.gov.cn\"\n            ,domain6:domainPreV1(1)+\".sporttery.cn\"\n            ,domain7:domainPreV1(2)+\".lottery.gov.cn\"\n            ,domain8:domainPreV1(2)+\".sporttery.cn\"\n        };\n</script>    <script src=\"//static.sporttery.cn/res_1_0/common/jquery-3.4.1.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/js/bootstrap.bundle.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/js/bootstrap.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/swiper-5.4.1/js/swiper.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/js/commonV1.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/tcw/default/jc/czCommonTip.js\"></script>\n    <style>\n        /* 更换浏览器提示 */\n        #browserTips{position: absolute;top:0;left:0;width:100%;height:0;z-index:999;}\n        .g-browserTips{position:absolute;top:-5px;left:0;width:100%;height:0;font-size:12px;color:#666;text-align:center;z-index:999;}\n        .m-browserTips{display:inline-block;padding:4px 50px 0;background:#fff;border-radius:4px;border:1px solid #d8d8d8;height:32px;line-height:26px;position:relative;}\n        .m-browserTips img{vertical-align:text-bottom;margin-right:3px;}\n        .u-quit{width:8px;height:8px;position:absolute;right:10px;top:13px;cursor:pointer;}\n    </style>\n</head>\n\n<body>\n<!--topBar-->\n<div id=\"sy_735\">\n</div>\n<!--menu-->\n<div class=\"g-menu bg-red\" id=\"sy_736\">\n</div>\n<!--内容-->\n<div class=\"container\">\n    <!-- 面包屑-->\n    <div class=\"row\">\n        <div class=\"col-4\">\n<div class=\"m-crumbs\"><a href=\"/\" title=\"竞彩网\" class=\"color-999\">竞彩网</a> &gt;<a href=\"/ctzc/index.html\" class=\"color-999\">传统足彩</a> &gt;<span class=\"color-999\">传足计算器</span> </div><script>\n    $(function () {\n        if (window.location.href.includes('/ctzc/ctzq/')) {\n            $('.m-crumbs').html('<a href=\"/\" title=\"竞彩网\" class=\"color-999\">竞彩网</a> &gt;<span class=\"color-999\">传统足彩</span>')\n        } else {\n            var specificLinks = document.querySelectorAll('.m-crumbs a');\n            specificLinks.forEach(function (link) {\n                if (link.href.includes('/ctzc/index.html')) {\n                    var newUrl = '/ctzc/ctzq/index.html';\n                    link.href = link.href.replace('/ctzc/index.html', newUrl);\n                }\n            });\n        }\n    })\n</script>        </div>\n        <div class=\"col-8 cz-nav\" id=\"sy_1251\">\n            <!--顶部导航-->\n        </div>\n    </div>\n    <div class=\"row\">\n        <div class=\"col-12\">\n            <div class=\"m-b3\">\n                <iframe style=\"display: block;\" width=\"100%\" height=\"850\" scrolling=\"no\" frameborder=\"0\"\n                        id=\"iFrame2\" name=\"iFrame2\" src=\"\">\n                </iframe>\n            </div>\n        </div>\n    </div>\n</div>\n<!--footer-->\n<div id=\"sy_608\">\n</div>\n<div id=\"browserTips\"></div>\n<script>\n    var idList = 'sy_735,sy_736,sy_1251,sy_608,sy_835,sy_836,sy_837,sy_838,sy_840,sy_845,sy_846';\n    var adList = '735,736,1251,608,835,836,837,838,840,845,846';\n    var funList = '';\n    commonV1Fun.loadHtml(idList, adList, funList);\n\n    $(function () {\n        window.addEventListener('message', function (e) {\n            if(e.type == 'message'){\n                var hh = e.data.heightNum;\n                if (typeof (hh) != \"number\") {\n                    hh = 1134;\n                }else {\n                    document.getElementById('iFrame2').height = hh + Number(60);\n                }\n            }\n\n        }, false);\n    })\n    function getDomain() {\n        return window.location.hostname;\n    }\n    function getGameStr(){\n        var czGameStr = ''\n        var czGid = commonV1Fun.getPara('gid')\n        var czPid = commonV1Fun.getPara('pid');\n        var czSid = commonV1Fun.getPara('sid');\n        if(czGid !='') czGameStr += '&gid='+czGid\n        if(czPid !='') czGameStr += '&pid='+czPid\n        if(czSid !='') czGameStr += '&sid='+czSid\n        return czGameStr\n    }\n\n    var host = getDomain();\n    var czGameStr = getGameStr()\n    document.getElementById(\"iFrame2\").src =\n        '//' + jsCommonDataV1.domain6 + '/ctzc/jsq/index.html?f=' + host+czGameStr;\n\n</script>\n\n</body>\n\n</html>"
