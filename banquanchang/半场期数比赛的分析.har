            {
              "name": "x-waf-uuid",
              "value": "77eb1202451d80346bc12f7d739553ed-dacf55692c7fcaea09acae028eeb3e63"
            }
          ],
          "cookies": [],
          "content": {
            "size": 16146,
            "mimeType": "application/javascript",
            "text": "var vm = new Vue({\n    el: '#ctzc_jsq',\n    data: {\n        activeGame: 90,\t//当前选择游戏变量\n        isNoSelling: true,\n        currentActive: [],\t//选择比赛index\n        matches: {},\t//比赛列表\n        details: [],\t//比赛详情\n        pricesVisble: false,\t//浮动奖金显示变量\n        topChange: 0,\t//浮动奖金窗口top值\n        betPriceDetails: [],\t//所有比赛浮动奖金\n        betPriceByMid: '',\t//鼠标移动到当前比赛浮动奖金\n        midList: [],\t//当前在售期的比赛id列表\n        sellingPeriods: [], \t//在售奖期列表\n        activePeriod: '',\t//当前期\n        isShowArrow: 0,\t\t//奖期两侧箭头显示，0：左右全隐藏；1：右箭头显示；2：左右全显示；3：左箭头显示；\n        firstPeriodMargin: 0,\t//奖期ul的margin-left值，点击箭头移动100\n        sellStatus: 0, //开售状态 0：在售  , 1:未来\n        recodeGame: 90, //区别14场和任九\n        issueLimits: 10, //期次数量\n        paraStrGameCode: 90, //参数带过来的游戏ID\n        gameCode :[90,91,98,94],//胜负游戏，任九，6场半全场，4场进球\n        paraActivePeriod: '', //参数带过来的期次\n        paraSellStatus: 0, //参数 0,在售奖期     1 即将开售\n        lastPoolDraw: {},\n        lastPoolDrawRj: {}\n    },\n    created: function () {\n        this.paraStrGameCode = this.getQueryKeyNew('gid')\n        this.paraActivePeriod = this.getQueryKeyNew('pid')\n        this.paraSellStatus = this.getQueryKeyNew('sid')\n        if(this.paraSellStatus != null){\n            if (Array(0,1).indexOf(parseInt(this.paraSellStatus)) > -1) {\n                this.sellStatus = parseInt(this.paraSellStatus)\n            }\n        }\n        if(this.paraStrGameCode !=null) {\n            if (this.gameCode.indexOf(parseInt(this.paraStrGameCode)) > -1) {\n                this.activeGame = parseInt(this.paraStrGameCode);\n                this.recodeGame = parseInt(this.paraStrGameCode);\n                if (this.activeGame == 91) {\n                    this.recodeGame = 90;\n                }\n            }\n        }\n        if(this.paraActivePeriod !=null){\n            this.activePeriod = this.paraActivePeriod\n        }\n        if(this.paraSellStatus !=null){\n            this.sellStatus = this.paraSellStatus\n        }\n        this.loadCtzcSellingPeriods();\n    },\n    watch: {\n        matches: {\n            handler:function(curVal, oldVal) {\n                if (JSON.stringify(curVal) != '{}') {\n                    this.$nextTick(function () {\n                        getIframeHeight($('#ctzc_jsq').height());\n                    })\n                }\n            },\n            deep: true\n        }\n    },\n    methods: {\n        //获取当前游戏在售期次，并加载\n        loadCtzcSellingPeriods: function () {\n            var gameKey = this.recodeGame;\n            //var ctzcSellingPeriodsAPIUrl = jsCommonDataV1.webApi + '/gateway/lottery/getFootBallMatchV1.qry?param=90,0&lotteryDrawNum=20019&sellStatus=1&termLimits=10';\n            var ctzcSellingPeriodsAPIUrl = jsCommonDataV1.webApi + '/gateway/lottery/getFootBallMatchV1.qry?param=' + gameKey + ',0&lotteryDrawNum='+this.activePeriod+'&sellStatus=' + this.sellStatus + '&termLimits=' + this.issueLimits;\n            //commonV1Fun.jsonpCall(ctzcSellingPeriodsAPIUrl, 'f_callback', 'importCtzcSellingPeriods');\n            commonV1Fun.ajaxFun(\n                importCtzcSellingPeriods,\n                ctzcSellingPeriodsAPIUrl,\n                undefined,\n                'get'\n            )\n        },\n        //获取当前游戏当前在售期次的比赛列表，并加载\n        loadCtzcMatches: function () {\n            var gameKey = this.recodeGame;\n            var ctzcMatchesAPIUrl = jsCommonDataV1.webApi + '/gateway/lottery/getFootBallMatchV1.qry?param=' + gameKey + ',0&lotteryDrawNum=' + this.activePeriod + '&sellStatus=' + this.sellStatus + '&termLimits=' + this.issueLimits;\n            commonV1Fun.ajaxFun(\n                importCtzcMatches,\n                ctzcMatchesAPIUrl,\n                undefined,\n                'get'\n            )\n\n        },\n        //获取当前游戏当前在售期次当前比赛的浮动奖金，并加载\n        loadCtzcBetPrices: function () {\n            /*\n            var ctzcPricesAPIUrl = 'https://i.sporttery.cn/api/fb_lottery/fb_odds_his/?mid[]=' + this.midList;\n            //commonV1Fun.jsonpCall(ctzcPricesAPIUrl, 'f_callback', 'importCtzcPrices');\n            commonV1Fun.ajaxFun(\n                importCtzcPrices,\n                ctzcPricesAPIUrl,\n                  undefined,\n                  'get'\n              )\n              */\n        },\n        //获取当前游戏当前在售期次的比赛详情列表，并加载\n        loadCtzcMatchDetails: function (mid) {\n            /*\n            var ctzcMatchDetailsAPIUrl = jsCommonDataV1.webApi+'https://i.sporttery.cn/api/fb_lottery/fb_lottery_detail/?mid=' + mid;\n            //commonV1Fun.jsonpCall(ctzcMatchDetailsAPIUrl, 'f_callback', 'importCtzcMatchDetails');\n            commonV1Fun.ajaxFun(\n                importCtzcMatchDetails,\n                ctzcMatchDetailsAPIUrl,\n                  undefined,\n                  'get'\n              )\n              */\n        },\n        upDownClass: function (i) {\n            if (i == \"up\") {\n                return \"red\";\n            } else if (i == \"down\") {\n                return \"green\";\n            }\n        },\n        upDownIconClass: function (i) {\n            if (i == \"up\") {\n                return \"u-arrowUp\";\n            } else if (i == \"down\") {\n                return \"u-arrowDown\";\n            }\n        },\n        showMatchDetails: function (index, mid) {\n            var result = this.currentActive.indexOf(index);\n            if (result == -1) {\n                this.currentActive.push(index);\n                if (mid != 0) {\n                    if (!this.details[index]) {\n                        this.loadCtzcMatchDetails(mid);\n                    }\n                } else {\n                    this.details[index] = '';\n                }\n            } else {\n                this.currentActive.splice(result, 1);\n            }\n        },\n        showPrices: function (index, mid) {\n            if (mid != 0) {\n                if (index >= 0) {\n                    var detailHeight = 0;\n                    if (this.currentActive.length > 0) {\n                        var nums = 0;\n                        for (var i = 0; i < this.currentActive.length; i++) {\n                            var element = this.currentActive[i];\n                            if (element < index) {\n                                nums++;\n                            }\n                        }\n                        detailHeight = nums * 107;\n                    }\n                    index++;\n                    if (this.activeGame === 3) {\n                        index = index * 2\n                    }\n                    if (this.betPriceDetails[mid]) {\n                        this.topChange = index * 35 + 40 + detailHeight;\n                        this.betPriceByMid = this.betPriceDetails[mid];\n                        this.pricesVisble = true;\n                    }\n                }\n            }\n        },\n        hidePrices: function () {\n            this.pricesVisble = false;\n        },\n        changeGame: function (id) {\n            if (this.activeGame != id) {\n                this.activeGame = id;\n                this.recodeGame = id;\n                if (this.activeGame == 91) {\n                    this.recodeGame = 90;\n                }\n                vm.isNoSelling = true;\n                this.sellStatus=0;\n                vm.matches = {};\n                this.activePeriod = '',\t//当前期\n                    this.isShowArrow = 0,\t\t//奖期两侧箭头显示，0：左右全隐藏；1：右箭头显示；2：左右全显示；3：左箭头显示；\n                    this.firstPeriodMargin = 0\t//奖期ul的margin-left值，点击箭头移动100\n                this.sellingPeriods = [], \t//在售奖期列表\n                    this.clearAllCzVueData();\n                this.loadCtzcSellingPeriods();\n            }\n        },\n        changeStatus: function (id) {\n            if (this.sellStatus != id) {\n                vm.isNoSelling = true;\n                this.sellStatus = id;\n                vm.matches = {};\n                this.activePeriod = '',\t//当前期\n                    this.isShowArrow = 0,\t\t//奖期两侧箭头显示，0：左右全隐藏；1：右箭头显示；2：左右全显示；3：左箭头显示；\n                    this.firstPeriodMargin = 0\t//奖期ul的margin-left值，点击箭头移动100\n                this.sellingPeriods = [], \t//在售奖期列表\n                    this.clearAllCzVueData();\n                this.loadCtzcSellingPeriods();\n            }\n        },\n        changePeriod: function (period) {\n            if (this.activePeriod != period) {\n                this.activePeriod = period;\n                vm.matches = {};\n                this.clearAllCzVueData();\n                this.loadCtzcMatches();\n            }\n        },\n        clearAllCzVueData: function () {\n            this.matches = {};\n            this.currentActive = [],\t//选择比赛index\n                //this.details = [],\t//比赛详情\n                //this.betPriceDetails = [],\t//所有比赛浮动奖金\n                //this.betPriceByMid = '',\t//鼠标移动到当前比赛浮动奖金\n                this.midList = [],\t//当前在售期的比赛id列表\n                jcwCtzcBetsNums.clearJsqPfl();\n        },\n        movePeriods: function (direction) {\n            var movedCounts = this.sellingPeriods.length + (this.firstPeriodMargin / 126) - 4;\n            if (direction == 1) {\n                //点击左箭头\n                if (this.firstPeriodMargin < 0) {\n                    this.firstPeriodMargin = this.firstPeriodMargin + 126;\n                    if (this.firstPeriodMargin === 0) {\n                        this.isShowArrow = 1;\n                    } else {\n                        this.isShowArrow = 2;\n                    }\n                }\n            } else {\n                //点击右箭头\n                if (movedCounts > 0) {\n                    this.firstPeriodMargin = this.firstPeriodMargin - 126;\n                    if (movedCounts > 1) {\n                        this.isShowArrow = 2;\n                    } else {\n                        this.isShowArrow = 3;\n                    }\n                }\n            }\n        },\n        getQueryKeyNew(kName){\n            const query = new URLSearchParams(window.location.search);\n            return query.get(kName)?decodeURIComponent(query.get(kName)):null\n        }\n    },\n    components: {\n        nosellingmatch: {\n            template: \"#jsq_wsj\"\n        },\n        czcalculator: {\n            template: \"#jsq_pfl\",\n            data: function () {\n                return {\n                    betTimesNum: 1\n                }\n            },\n            methods: {\n                changeBetTime: function (type) {\n                    if (type === 1) {\n                        if (this.betTimesNum < 99) {\n                            this.betTimesNum++;\n                        }\n                    } else {\n                        if (this.betTimesNum > 1) {\n                            this.betTimesNum--;\n                        }\n                    }\n                    jcwCtzcBetsNums.setBetsCost();\n                },\n                handleInputTime: function () {\n                    if (this.betTimesNum.length > 2) this.betTimesNum = this.betTimesNum.slice(0, 2);\n                },\n                handleInputBlur: function () {\n                    if (this.betTimesNum.length < 1) this.betTimesNum = 1;\n                    jcwCtzcBetsNums.setBetsCost();\n                }\n            }\n        }\n    }\n})\nfunction importCtzcSellingPeriods(d) {\n    if (d.errorCode == 0) {\n        if (JSON.stringify(d.value) != '{}') {\n            var info = d.value;\n            if (JSON.stringify(info.sfcMatch) != '{}') {\n                vm.matches = info.sfcMatch;\n                if(JSON.stringify(info.sfcMatch.lastPoolDraw) != '{}'){\n                    vm.lastPoolDraw = info.sfcMatch.lastPoolDraw;\n                }\n                if(JSON.stringify(info.sfcMatch.lastPoolDrawRj) != '{}'){\n                    vm.lastPoolDrawRj = info.sfcMatch.lastPoolDrawRj;\n                }\n            }\n            if (info.sfclist.length > 0) {\n                vm.sellingPeriods = info.sfclist;\n                vm.activePeriod = info.sfclist[0];\n                if (info.sfclist.length > 4) {\n                    vm.isShowArrow = 1;\n                }\n            }\n\n            if (JSON.stringify(info.jqcMatch) != '{}') {\n                vm.matches = info.jqcMatch;\n                if(JSON.stringify(info.jqcMatch.lastPoolDraw) != '{}'){\n                    vm.lastPoolDraw = info.jqcMatch.lastPoolDraw;\n                }\n            }\n            if (info.jqclist.length > 0) {\n                vm.sellingPeriods = info.jqclist;\n                vm.activePeriod = info.jqclist[0];\n                if (info.jqclist.length > 4) {\n                    vm.isShowArrow = 1;\n                }\n            }\n\n            if (JSON.stringify(info.bqcMatch) != '{}') {\n                vm.matches = info.bqcMatch;\n                if(JSON.stringify(info.bqcMatch.lastPoolDraw) != '{}'){\n                    vm.lastPoolDraw = info.bqcMatch.lastPoolDraw;\n                }\n            }\n            if (info.bqclist.length > 0) {\n                vm.sellingPeriods = info.bqclist;\n                vm.activePeriod = info.bqclist[0];\n                if (info.bqclist.length > 4) {\n                    vm.isShowArrow = 1;\n                }\n            }\n            // URL带入期数是否存在，存在则替换\n            if(vm.sellingPeriods.indexOf(vm.paraActivePeriod)>-1){\n                vm.activePeriod = vm.paraActivePeriod\n            }\n            if (vm.sellingPeriods.length > 0) {\n                vm.isNoSelling = false;\n            }else{\n                getIframeHeight(880);\n            }\n            //赛事\n            if (JSON.stringify(vm.matches) != '{}') {\n                var matchList = new Array();\n                for (var i = 0; i < vm.matches.matchList.length; i++) {\n                    if (vm.matches.matchList[i].infohubMatchId > 0) {\n                        matchList.push(vm.matches.matchList[i]);\n                    }\n                    vm.$set(vm.details, i, '');\n                }\n                //vm.midList = matchList.join(\"&mid[]=\");\n            }\n        }\n\n    } else {\n        vm.isNoSelling = true;\n        getIframeHeight(880);\n        vm.matches = {};\n        vm.lastPoolDraw = {}\n        vm.lastPoolDrawRj = {}\n        //vm.betPriceDetails = [];\n    }\n}\nfunction importCtzcMatches(d) {\n    if (d.errorCode == 0) {\n        if (JSON.stringify(d.value) != '{}') {\n            var info = d.value;\n            var matchList = new Array();\n            if (JSON.stringify(info.sfcMatch) != '{}') {\n                vm.matches = info.sfcMatch;\n            }\n            if (JSON.stringify(info.jqcMatch) != '{}') {\n                vm.matches = info.jqcMatch;\n            }\n            if (JSON.stringify(info.bqcMatch) != '{}') {\n                vm.matches = info.bqcMatch;\n            }\n            if (JSON.stringify(vm.matches) != '{}') {\n                for (var i = 0; i < vm.matches.matchList.length; i++) {\n                    if (vm.matches.matchList[i].infohubMatchId > 0) {\n                        matchList.push(vm.matches.matchList[i]);\n                    }\n                    vm.$set(vm.details, i, '');\n                }\n            }\n            //vm.midList = matchList.join(\"&mid[]=\");\n            //vm.loadCtzcBetPrices();\n        }\n    } else {\n        vm.isNoSelling = true;\n        vm.matches = {};\n        getIframeHeight(880);\n        //vm.betPriceDetails = [];\n    }\n}\nfunction getIframeHeight(num) {\n    var iframeInfo = {\n        heightNum: num\n    };\n    window.parent.postMessage(iframeInfo, '*');\n}"
          },
