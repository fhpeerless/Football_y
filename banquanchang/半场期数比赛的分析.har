          "content": {
            "size": 46928,
            "mimeType": "text/html",
            "text": "<!doctype html>\n<html>\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n    <base target=\"_blank\">\n    <title>传足计算器</title>\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/cz_tz_v2.css\">\n<script>\n  function domainPreV1(tid){try{var temDomain=document.domain.split(\".\");if(tid==1){if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return temDomain[0]}else{return\"www\"}}else{if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return 'mgray'}else{return\"m\"}}}catch(e){if(tid==1){return\"www\"}else{return\"m\"}}};\n   var jsCommonDataV1={\n            advUrl:\"/htmlfrag\",\n            webApi: \"//webapi.sporttery.cn\",\n            resDomain: \"//static.sporttery.cn\",\n            res: \"//static.sporttery.cn/res_1_0/jcw/default\",\n            env: \"prd\",\n            domain1:\"www.lottery.gov.cn\"\n            ,domain2:\"www.sporttery.cn\"\n            ,domain3:\"m.lottery.gov.cn\"\n            ,domain4:\"m.sporttery.cn\"\n            ,domain5:domainPreV1(1)+\".lottery.gov.cn\"\n            ,domain6:domainPreV1(1)+\".sporttery.cn\"\n            ,domain7:domainPreV1(2)+\".lottery.gov.cn\"\n            ,domain8:domainPreV1(2)+\".sporttery.cn\"\n        };\n</script>    <script src=\"//static.sporttery.cn/res_1_0/common/jquery-3.4.1.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/js/vue.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/js/commonV1.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/jcw/default/ctzc/betsCalculator.js\"></script>\n</head>\n\n<body>\n    <div>\n<div id=\"ctzc_jsq\" v-cloak>\n\t<!--标题-->\n\t\n\t<!--标题-->\n<div class=\"m-czTitle clear\">\n    <ul class=\"m-czTitle-l f-fl\">\n        <li :class=\"{'on': activeGame==90}\" @click=\"changeGame(90)\">胜负游戏</li>\n        <li :class=\"{'on': activeGame==91}\" @click=\"changeGame(91)\">任选9场</li>\n        <li :class=\"{'on': activeGame==98}\" @click=\"changeGame(98)\">6场半全场</li>\n        <li :class=\"{'on': activeGame==94}\" @click=\"changeGame(94)\">4场进球</li>\n    </ul>\n    <div class=\"m-czTitle-r f-fr\">单注最高奖金<span><em>500</em>万元</span></div>\n</div>\n<!--/标题结束-->\n\t<!--/标题结束-->\n\t<!--胜负彩-->\n\t<div class=\"m-sfcL\" v-if=\"activeGame==90\">\n\t\t<div class=\"m-czNotice\">玩法提示：以下14场比赛，每场比赛至少选择一个结果；比赛结果以90分钟（含伤停补时，不含加时赛）结果为准。</div>\n<div class=\"m-bonus\" v-if=\"JSON.stringify(lastPoolDraw) != '{}'\">\n    <div class=\"m-bonus-title\">\n            <div class=\"m-bonus-title-left\"></div>\n            <div class=\"m-bonus-title-center\" v-if=\"lastPoolDraw.lotteryDrawNum\"><span class=\"m-bonus-pad6\">{{lastPoolDraw.lotteryDrawNum}}期</span> 开奖信息</div>\n            <div class=\"m-bonus-title-right\"></div>\n    </div>\n    <div class=\"m-bonus-content\">\n<!--        <div class=\"m-bonus-sales\" v-if=\"lastPoolDraw.totalSaleAmount\"><span class=\"m-bonus-pad6\">销售额</span><span class=\"m-bonus-red\">{{lastPoolDraw.totalSaleAmount}}</span>元</div>-->\n<!--        <div class=\"m-bonus-line\"></div>-->\n        <template v-for=\"obj in lastPoolDraw.prizeLevelList\" v-if=\"lastPoolDraw.prizeLevelList\">\n            <div class=\"m-bonus-first\">\n                <div>{{obj.prizeLevel}} </div>\n                <div><span>中奖</span><span class=\"m-bonus-red\">{{obj.stakeCount}}</span>注 </div>\n                <div><span class=\"m-bonus-pad6\">单注奖金</span><span class=\"m-bonus-red\">{{obj.stakeAmount}}</span>元</div>\n            </div>\n            <div class=\"m-bonus-line\"></div>\n        </template>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.poolBalanceAfterDraw\">\n            <div><span class=\"m-bonus-pad6\">奖池</span><span class=\"m-bonus-red\">{{lastPoolDraw.poolBalanceAfterDraw}}</span>元</div>\n        </div>\n        <div class=\"m-bonus-line\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\"></div>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\">\n            <div><span class=\"m-bonus-pad6\">派奖奖金滚存</span><span class=\"m-bonus-red\">{{lastPoolDraw.surplusAmount}}</span>元</div>\n        </div>\n    </div>\n</div><!--标题-->\n<div class=\"m-zstab\">\n    <ul>\n        <li :class=\"{'on': sellStatus==0}\" @click=\"changeStatus(0)\">在售奖期</li>\n        <li :class=\"{'on': sellStatus==1}\" @click=\"changeStatus(1)\">即将开售</li>\n    </ul>\n</div>\n<!--/标题结束-->\t\t<!--传足无赛事-->\n\t\t<nosellingmatch v-if=\"isNoSelling\"></nosellingmatch>\n\t\t<!--传足无赛事/结束-->\n\t\t<template v-else>\n<div class=\"m-czTime clear\">\n    <div class=\"m-czTime-l f-fl\">\n        <div class=\"m-czNums\">\n            <ul :style=\"{'margin-left':firstPeriodMargin+'px'}\">\n                <template v-for=\"sm in sellingPeriods\">\n                <li :class=\"{'on': activePeriod==sm}\" @click=\"changePeriod(sm)\">\n                    <span>{{sm}}</span>期\n                </li>\n                </template>\n            </ul>\n        </div>\n        <!--期次超6个后，箭头显示-->\n        <span class=\"u-arrowL\" v-if=\"isShowArrow==2 || isShowArrow==3\" @click=\"movePeriods(1)\"></span>\n        <span class=\"u-arrowR\" v-if=\"isShowArrow==2 || isShowArrow==1\" @click=\"movePeriods(2)\"></span>\n    </div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==0\">投注截止时间：{{matches.lotterySaleEndtime}}</div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==1\">开售时间：{{matches.lotterySaleBegintime}}</div>\n</div><div class=\"m-czBet\">\n\t<table cellpadding=\"0\" cellspacing=\"0\" class=\"m-czTab\">\n\t\t<colgroup>\n\t\t\t<col width=\"45\" />\n\t\t\t<col width=\"83\"/>\n\t\t\t<col width=\"110\"/>\n\t\t\t<col/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"70\"/> \n\t\t\t<col width=\"70\"/>\n\t\t</colgroup>\n\t\t<thead>\n\t\t\t<tr>\n\t\t\t\t<th class=\"thNum\">场次</th>\n\t\t\t\t<th class=\"thLs\">联赛</th>\n\t\t\t\t<th class=\"thTime\">开赛日期</th>\n\t\t\t\t<th class=\"thTeam\">\n\t\t\t\t\t<div class=\"team\">\n\t\t\t\t\t\t<span class=\"teamL\">主队</span>\n\t\t\t\t\t\t<em class=\"teamVs\">VS</em>\n\t\t\t\t\t\t<span class=\"teamR\">客队</span>\n\t\t\t\t\t</div>\n\t\t\t\t</th>\n\t\t\t\t<th class=\"thOption\">\n\t\t\t\t\t<strong>选项</strong>\n\t\t\t\t\t<div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n\t\t\t\t</th>\n\t\t\t\t<th class=\"thJc\">\n\t\t\t\t\t<strong>竞彩</strong>\n\t\t\t\t\t<div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n\t\t\t\t</th>\n\t\t\t\t<th class=\"thInfo\">资讯</th>\n\t\t\t\t<th class=\"thData\">数据</th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody v-for=\"(m, index) in matches.matchList\" :key=\"index\">\n\t\t\t<tr>\n\t\t\t\t<td class=\"tdNum\">{{m.matchNum}}</td>\n\t\t\t\t<td class=\"tdLs\">\n\t\t\t\t\t<span v-if=\"m.matchName!=''\">{{m.matchName}}</span>\n\t\t\t\t\t<span v-else class=\"gray\">--</span>\n\t\t\t\t</td>\n\t\t\t\t<td class=\"tdTime\">\n\t\t\t\t\t<span v-if=\"m.startTime!=''\">{{m.startTime}}</span>\n\t\t\t\t\t<span v-else class=\"gray\">--</span>\n\t\t\t\t</td>\n\t\t\t\t<td class=\"tdTeam\">\n                    <div class=\"team\" v-if=\"m.infohubMatchId\">\n\t\t\t\t\t\t<a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"teamVs\">\n\t\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t\t<span>VS</span>\n\t\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"team\" v-else>\n\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t<span class=\"gray\">VS</span>\n\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\n\t\t\t\t\t</div>\n\n\n\t\t\t\t</td>\n\t\t\t\t<td class=\"tdOption\">\n\t\t\t\t\t<div class=\"tdDiv\">\n\t\t\t\t\t\t<span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3</em></span>\n\t\t\t\t\t\t<span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n\t\t\t\t\t\t<span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n\t\t\t\t\t</div>\n\t\t\t\t</td>\n\t\t\t\t<td class=\"tdJc\">\n\t\t\t\t\t<div class=\"tdDiv\">\n\t\t\t\t\t\t<span>{{m.h?m.h:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.d?m.d:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.a?m.a:\"--\"}}</span>\n\t\t\t\t\t</div>\n\t\t\t\t</td>\n\t\t\t\t<td class=\"tdInfo\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=1&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">讯</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdData\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">析</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n\n\t\t\t</tr>\n\t\t\t<tr v-show=\"currentActive.indexOf(index) != -1\">\n\t\t\t\t<td colspan=\"8\" class=\"tdDataCon\">\n\t\t\t\t\t<div class=\"fs-14 gray\" v-if=\"details[index]==''\">抱歉，暂无比赛资讯</div>\n<table cellpadding=\"0\" cellspacing=\"0\" class=\"tdDataTab\" v-else>\n    <colgroup>\n        <col width=\"145\">\n        <col width=\"240\">\n        <col width=\"\">\n        <col width=\"240\">\n    </colgroup>\n    <tr v-if=\"details[index].his_data != {}\">\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].his_data.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].his_data.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].his_data.lose}}</em>&nbsp;场</td>\n    </tr>\n    <tr v-else>\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>--</em>&nbsp;场</td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[近期战绩]</th>\n        <td>\n            <span v-if=\"details[index].team_rec.h_rec==''\">--</span>\n            <template v-else v-for=\"dh in details[index].team_rec.h_rec\">\n                <span class=\"u-block bg-red\" v-if=\"dh=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"dh=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"dh=='lose'\">负</span>\n            </template>\n        </td>\n        <td></td>\n        <td>\n            <span v-if=\"details[index].team_rec.a_rec==''\">--</span>\n            <template v-else v-for=\"da in details[index].team_rec.a_rec\">\n                <span class=\"u-block bg-red\" v-if=\"da=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"da=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"da=='lose'\">负</span>\n            </template>\n        </td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[同奖回查]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].same_odds.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].same_odds.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].same_odds.lose}}</em>&nbsp;场\n            <a :href=\"'//info.sporttery.cn/jcw/football/info/fb_match_info.php?m='+m.m_id\" class=\"u-more f-fr blue\">查看更多></a>\n        </td>\n    </tr>\n</table>\t\t\t\t</td>\n\t\t\t</tr>\n\t\t</tbody>\n\t</table>\n<div class=\"m-czWin\" v-show=\"pricesVisble\" :style=\"{'top':topChange+'px'}\" @mouseover=\"pricesVisble=true\" @mouseout=\"hidePrices()\">\n    <div class=\"title\">奖金变化</div>\n    <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" class=\"m-tabTitle\">\n        <tr>\n            <th width=\"22%\">胜</th>\n            <th width=\"22%\">平</th>\n            <th width=\"22%\">负</th>\n            <th width=\"34%\">时间</th>\n        </tr>\n    </table>\n    <div class=\"m-czWin-con\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n        <colgroup>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"34%\"/>\n        </colgroup>\n        <tr v-for=\"bp in betPriceByMid\">\n            <td><span :class=\"upDownClass(bp.h_trend)\">{{bp.h}}</span><i v-if=\"bp.h_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.h_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.d_trend)\">{{bp.d}}</span><i v-if=\"bp.d_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.d_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.a_trend)\">{{bp.a}}</span><i v-if=\"bp.a_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.a_trend)\"></i></td>\n            <td>{{bp.date.substring(5)+' '+bp.time.substring(0,5)}}</td>\n        </tr>\n    </table></div>\n</div>\n</div>\t\t</template>\n\t</div>\n\t<!--胜负彩结束-->\n\t<!--任选9场-->\n\t<div class=\"m-r9L\" v-if=\"activeGame==91\">\n\t\t<div class=\"m-czNotice\">玩法提示：请选择9场比赛进行竞猜，每场比赛至少选择一个结果；比赛结果以90分钟（含伤停补时，不含加时赛）结果为准。</div>\n<div class=\"m-bonus\" v-if=\"JSON.stringify(lastPoolDrawRj) != '{}'\">\n    <div class=\"m-bonus-title\">\n            <div class=\"m-bonus-title-left\"></div>\n            <div class=\"m-bonus-title-center\" v-if=\"lastPoolDrawRj.lotteryDrawNum\"><span class=\"m-bonus-pad6\">{{lastPoolDrawRj.lotteryDrawNum}}期</span> 开奖信息</div>\n            <div class=\"m-bonus-title-right\"></div>\n    </div>\n    <div class=\"m-bonus-content\">\n<!--        <div class=\"m-bonus-sales\" v-if=\"lastPoolDrawRj.totalSaleAmount\"><span class=\"m-bonus-pad6\">销售额</span><span class=\"m-bonus-red\">{{lastPoolDrawRj.totalSaleAmount}}</span>元</div>-->\n<!--        <div class=\"m-bonus-line\"></div>-->\n        <template v-for=\"obj in lastPoolDrawRj.prizeLevelList\" v-if=\"lastPoolDrawRj.prizeLevelList\">\n            <div class=\"m-bonus-first\">\n                <div>{{obj.prizeLevel}} </div>\n                <div><span>中奖</span><span class=\"m-bonus-red\">{{obj.stakeCount}}</span>注 </div>\n                <div><span class=\"m-bonus-pad6\">单注奖金</span><span class=\"m-bonus-red\">{{obj.stakeAmount}}</span>元</div>\n            </div>\n            <div class=\"m-bonus-line\"></div>\n        </template>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDrawRj.poolBalanceAfterDraw\">\n            <div><span class=\"m-bonus-pad6\">奖池</span><span class=\"m-bonus-red\">{{lastPoolDrawRj.poolBalanceAfterDraw}}</span>元</div>\n        </div>\n        <div class=\"m-bonus-line\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\"></div>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\">\n            <div><span class=\"m-bonus-pad6\">派奖奖金滚存</span><span class=\"m-bonus-red\">{{lastPoolDraw.surplusAmount}}</span>元</div>\n        </div>\n    </div>\n</div><!--标题-->\n<div class=\"m-zstab\">\n    <ul>\n        <li :class=\"{'on': sellStatus==0}\" @click=\"changeStatus(0)\">在售奖期</li>\n        <li :class=\"{'on': sellStatus==1}\" @click=\"changeStatus(1)\">即将开售</li>\n    </ul>\n</div>\n<!--/标题结束-->\t\t<!--传足无赛事-->\n\t\t<nosellingmatch v-if=\"isNoSelling\"></nosellingmatch>\n\t\t<!--传足无赛事/结束-->\n\t\t<template v-else>\n<div class=\"m-czTime clear\">\n    <div class=\"m-czTime-l f-fl\">\n        <div class=\"m-czNums\">\n            <ul :style=\"{'margin-left':firstPeriodMargin+'px'}\">\n                <template v-for=\"sm in sellingPeriods\">\n                <li :class=\"{'on': activePeriod==sm}\" @click=\"changePeriod(sm)\">\n                    <span>{{sm}}</span>期\n                </li>\n                </template>\n            </ul>\n        </div>\n        <!--期次超6个后，箭头显示-->\n        <span class=\"u-arrowL\" v-if=\"isShowArrow==2 || isShowArrow==3\" @click=\"movePeriods(1)\"></span>\n        <span class=\"u-arrowR\" v-if=\"isShowArrow==2 || isShowArrow==1\" @click=\"movePeriods(2)\"></span>\n    </div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==0\">投注截止时间：{{matches.lotterySaleEndtime}}</div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==1\">开售时间：{{matches.lotterySaleBegintime}}</div>\n</div><div class=\"m-czBet\">\n    <table cellpadding=\"0\" cellspacing=\"0\" class=\"m-czTab\">\n        <colgroup>\n            <col width=\"45\" />\n\t\t\t<col width=\"83\"/>\n\t\t\t<col width=\"110\"/>\n\t\t\t<col/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"70\"/> \n\t\t\t<col width=\"70\"/>\n        </colgroup>\n        <thead>\n            <tr>\n                <th class=\"thNum\">场次</th>\n                <th class=\"thLs\">联赛</th>\n                <th class=\"thTime\">开赛日期</th>\n                <th class=\"thTeam\">\n                    <div class=\"team\">\n                        <span class=\"teamL\">主队</span>\n                        <em class=\"teamVs\">VS</em>\n                        <span class=\"teamR\">客队</span>\n                    </div>\n                </th>\n                <th class=\"thOption\">\n                    <strong>选项</strong>\n                    <div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n                </th>\n                <th class=\"thJc\">\n                    <strong>竞彩</strong>\n                    <div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n                </th>\n                <th class=\"thInfo\">资讯</th>\n                <th class=\"thData\">数据</th>\n            </tr>\n        </thead>\n        <tbody v-for=\"(m, index) in matches.matchList\" :key=\"index\">\n            <tr>\n                <td class=\"tdNum\">{{m.matchNum}}</td>\n                <td class=\"tdLs\">\n                    <span v-if=\"m.matchName!=''\">{{m.matchName}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTime\">\n                    <span v-if=\"m.startTime!=''\">{{m.startTime}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTeam\">\n                    <div class=\"team\" v-if=\"m.infohubMatchId\">\n\t\t\t\t\t\t<a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"teamVs\">\n\t\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t\t<span>VS</span>\n\t\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"team\" v-else>\n\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t<span class=\"gray\">VS</span>\n\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\n\t\t\t\t\t</div>\n                </td>\n                <td class=\"tdOption\">\n                    <div class=\"tdDiv\">\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n                    </div>\n                </td>\n                <td class=\"tdJc\" @mouseover=\"showPrices(index,m.m_id)\" @mouseout=\"hidePrices()\">\n                    <div class=\"tdDiv\">\n                        <span>{{m.h?m.h:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.d?m.d:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.a?m.a:\"--\"}}</span>\n                    </div>\n                </td>\n                <td class=\"tdInfo\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=1&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">讯</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdData\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">析</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n            </tr>\n            <tr v-show=\"currentActive.indexOf(index) != -1\">\n                <td colspan=\"8\" class=\"tdDataCon\">\n                    <div class=\"fs-14 gray\" v-if=\"details[index]==''\">抱歉，暂无比赛资讯</div>\n<table cellpadding=\"0\" cellspacing=\"0\" class=\"tdDataTab\" v-else>\n    <colgroup>\n        <col width=\"145\">\n        <col width=\"240\">\n        <col width=\"\">\n        <col width=\"240\">\n    </colgroup>\n    <tr v-if=\"details[index].his_data != {}\">\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].his_data.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].his_data.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].his_data.lose}}</em>&nbsp;场</td>\n    </tr>\n    <tr v-else>\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>--</em>&nbsp;场</td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[近期战绩]</th>\n        <td>\n            <span v-if=\"details[index].team_rec.h_rec==''\">--</span>\n            <template v-else v-for=\"dh in details[index].team_rec.h_rec\">\n                <span class=\"u-block bg-red\" v-if=\"dh=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"dh=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"dh=='lose'\">负</span>\n            </template>\n        </td>\n        <td></td>\n        <td>\n            <span v-if=\"details[index].team_rec.a_rec==''\">--</span>\n            <template v-else v-for=\"da in details[index].team_rec.a_rec\">\n                <span class=\"u-block bg-red\" v-if=\"da=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"da=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"da=='lose'\">负</span>\n            </template>\n        </td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[同奖回查]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].same_odds.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].same_odds.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].same_odds.lose}}</em>&nbsp;场\n            <a :href=\"'//info.sporttery.cn/jcw/football/info/fb_match_info.php?m='+m.m_id\" class=\"u-more f-fr blue\">查看更多></a>\n        </td>\n    </tr>\n</table>                </td>\n            </tr>\n        </tbody>\n    </table>\n<div class=\"m-czWin\" v-show=\"pricesVisble\" :style=\"{'top':topChange+'px'}\" @mouseover=\"pricesVisble=true\" @mouseout=\"hidePrices()\">\n    <div class=\"title\">奖金变化</div>\n    <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" class=\"m-tabTitle\">\n        <tr>\n            <th width=\"22%\">胜</th>\n            <th width=\"22%\">平</th>\n            <th width=\"22%\">负</th>\n            <th width=\"34%\">时间</th>\n        </tr>\n    </table>\n    <div class=\"m-czWin-con\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n        <colgroup>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"34%\"/>\n        </colgroup>\n        <tr v-for=\"bp in betPriceByMid\">\n            <td><span :class=\"upDownClass(bp.h_trend)\">{{bp.h}}</span><i v-if=\"bp.h_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.h_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.d_trend)\">{{bp.d}}</span><i v-if=\"bp.d_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.d_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.a_trend)\">{{bp.a}}</span><i v-if=\"bp.a_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.a_trend)\"></i></td>\n            <td>{{bp.date.substring(5)+' '+bp.time.substring(0,5)}}</td>\n        </tr>\n    </table></div>\n</div>\n</div>\t\t</template>\n\t</div>\n\t<!--任选9场结束-->\n\t<!--六场半全场-->\n\t<div class=\"m-bqcL\" v-if=\"activeGame==98\">\n\t\t<div class=\"m-czNotice\">玩法提示：请对以下6场比赛半场与全场的结果进行竞猜，全部猜中即中奖；比赛结果以90分钟（含伤停补时，不含加时赛）结果为准。</div>\n<div class=\"m-bonus\" v-if=\"JSON.stringify(lastPoolDraw) != '{}'\">\n    <div class=\"m-bonus-title\">\n            <div class=\"m-bonus-title-left\"></div>\n            <div class=\"m-bonus-title-center\" v-if=\"lastPoolDraw.lotteryDrawNum\"><span class=\"m-bonus-pad6\">{{lastPoolDraw.lotteryDrawNum}}期</span> 开奖信息</div>\n            <div class=\"m-bonus-title-right\"></div>\n    </div>\n    <div class=\"m-bonus-content\">\n<!--        <div class=\"m-bonus-sales\" v-if=\"lastPoolDraw.totalSaleAmount\"><span class=\"m-bonus-pad6\">销售额</span><span class=\"m-bonus-red\">{{lastPoolDraw.totalSaleAmount}}</span>元</div>-->\n<!--        <div class=\"m-bonus-line\"></div>-->\n        <template v-for=\"obj in lastPoolDraw.prizeLevelList\" v-if=\"lastPoolDraw.prizeLevelList\">\n            <div class=\"m-bonus-first\">\n                <div>{{obj.prizeLevel}} </div>\n                <div><span>中奖</span><span class=\"m-bonus-red\">{{obj.stakeCount}}</span>注 </div>\n                <div><span class=\"m-bonus-pad6\">单注奖金</span><span class=\"m-bonus-red\">{{obj.stakeAmount}}</span>元</div>\n            </div>\n            <div class=\"m-bonus-line\"></div>\n        </template>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.poolBalanceAfterDraw\">\n            <div><span class=\"m-bonus-pad6\">奖池</span><span class=\"m-bonus-red\">{{lastPoolDraw.poolBalanceAfterDraw}}</span>元</div>\n        </div>\n        <div class=\"m-bonus-line\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\"></div>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\">\n            <div><span class=\"m-bonus-pad6\">派奖奖金滚存</span><span class=\"m-bonus-red\">{{lastPoolDraw.surplusAmount}}</span>元</div>\n        </div>\n    </div>\n</div><!--标题-->\n<div class=\"m-zstab\">\n    <ul>\n        <li :class=\"{'on': sellStatus==0}\" @click=\"changeStatus(0)\">在售奖期</li>\n        <li :class=\"{'on': sellStatus==1}\" @click=\"changeStatus(1)\">即将开售</li>\n    </ul>\n</div>\n<!--/标题结束-->\t\t<!--传足无赛事-->\n\t\t<nosellingmatch v-if=\"isNoSelling\"></nosellingmatch>\n\t\t<!--传足无赛事/结束-->\n\t\t<template v-else>\n<div class=\"m-czTime clear\">\n    <div class=\"m-czTime-l f-fl\">\n        <div class=\"m-czNums\">\n            <ul :style=\"{'margin-left':firstPeriodMargin+'px'}\">\n                <template v-for=\"sm in sellingPeriods\">\n                <li :class=\"{'on': activePeriod==sm}\" @click=\"changePeriod(sm)\">\n                    <span>{{sm}}</span>期\n                </li>\n                </template>\n            </ul>\n        </div>\n        <!--期次超6个后，箭头显示-->\n        <span class=\"u-arrowL\" v-if=\"isShowArrow==2 || isShowArrow==3\" @click=\"movePeriods(1)\"></span>\n        <span class=\"u-arrowR\" v-if=\"isShowArrow==2 || isShowArrow==1\" @click=\"movePeriods(2)\"></span>\n    </div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==0\">投注截止时间：{{matches.lotterySaleEndtime}}</div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==1\">开售时间：{{matches.lotterySaleBegintime}}</div>\n</div><!--六场半全场-投注区域-->\n<div class=\"m-czBet\">\n    <table cellpadding=\"0\" cellspacing=\"0\" class=\"m-czTab m-czBqcTab\">\n        <colgroup>\n            <col width=\"45\" />\n\t\t\t<col width=\"83\"/>\n\t\t\t<col width=\"110\"/>\n            <col/>\n            <col width=\"70\"/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"190\"/> \n\t\t\t<col width=\"70\"/> \n\t\t\t<col width=\"70\"/>\n        </colgroup>\n        <thead>\n            <tr>\n                <th class=\"thNum\">场次</th>\n                <th class=\"thLs\">联赛</th>\n                <th class=\"thTime\">开赛日期</th>\n                <th class=\"thTeam\">\n                    <div class=\"team\">\n                        <span class=\"teamL\">主队</span>\n                        <em class=\"teamVs\">VS</em>\n                        <span class=\"teamR\">客队</span>\n                    </div>\n                </th>\n                <th class=\"thBqc\">半/全</th>\n                <th class=\"thOption\">\n                    <strong>选项</strong>\n                    <div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n                </th>\n                <th class=\"thJc\">\n                    <strong>竞彩</strong>\n                    <div class=\"thDiv\"><span>胜</span><span>平</span><span>负</span></div>\n                </th>\n                <th class=\"thInfo\">资讯</th>\n                <th class=\"thData\">数据</th>\n            </tr>\n        </thead>\n        <tbody v-for=\"(m, index) in matches.matchList\" :key=\"index\">\n            <tr>\n                <td class=\"tdNum\">{{m.matchNum}}</td>\n                <td class=\"tdLs\">\n                    <span v-if=\"m.matchName!=''\">{{m.matchName}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTime\">\n                    <span v-if=\"m.startTime!=''\">{{m.startTime}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTeam\">\n                    <div class=\"team\" v-if=\"m.infohubMatchId\">\n\t\t\t\t\t\t<a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"teamVs\">\n\t\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t\t<span>VS</span>\n\t\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"team\" v-else>\n\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t<span class=\"gray\">VS</span>\n\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\n\t\t\t\t\t</div>\n                </td>\n                <td class=\"tdBqc\">\n                    <span>半</span>\n                    <span>全</span>\n                </td>\n                <td class=\"tdOption\">\n                    <div class=\"tdDiv\">\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n                    </div>\n                    <div class=\"tdDiv\">\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n                    </div>\n                </td>\n                <td class=\"tdJc\" @mouseover=\"showPrices(index,m.m_id)\" @mouseout=\"hidePrices()\">\n                    <div class=\"tdDiv\">\n                        <span>{{m.h?m.h:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.d?m.d:\"--\"}}</span>\n\t\t\t\t\t\t<span>{{m.a?m.a:\"--\"}}</span>\n                    </div>\n                </td>\n                <td class=\"tdInfo\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=1&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">讯</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdData\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">析</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n            </tr>\n            <!--展开数据行-->\n            <tr v-show=\"currentActive.indexOf(index) != -1\">\n                <td colspan=\"9\" class=\"tdDataCon\">\n                    <div class=\"fs-14 gray\" v-if=\"details[index]==''\">抱歉，暂无比赛资讯</div>\n<table cellpadding=\"0\" cellspacing=\"0\" class=\"tdDataTab\" v-else>\n    <colgroup>\n        <col width=\"145\">\n        <col width=\"240\">\n        <col width=\"\">\n        <col width=\"240\">\n    </colgroup>\n    <tr v-if=\"details[index].his_data != {}\">\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].his_data.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].his_data.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].his_data.lose}}</em>&nbsp;场</td>\n    </tr>\n    <tr v-else>\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>--</em>&nbsp;场</td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[近期战绩]</th>\n        <td>\n            <span v-if=\"details[index].team_rec.h_rec==''\">--</span>\n            <template v-else v-for=\"dh in details[index].team_rec.h_rec\">\n                <span class=\"u-block bg-red\" v-if=\"dh=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"dh=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"dh=='lose'\">负</span>\n            </template>\n        </td>\n        <td></td>\n        <td>\n            <span v-if=\"details[index].team_rec.a_rec==''\">--</span>\n            <template v-else v-for=\"da in details[index].team_rec.a_rec\">\n                <span class=\"u-block bg-red\" v-if=\"da=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"da=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"da=='lose'\">负</span>\n            </template>\n        </td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[同奖回查]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].same_odds.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].same_odds.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].same_odds.lose}}</em>&nbsp;场\n            <a :href=\"'//info.sporttery.cn/jcw/football/info/fb_match_info.php?m='+m.m_id\" class=\"u-more f-fr blue\">查看更多></a>\n        </td>\n    </tr>\n</table>                </td>\n            </tr>\n            <!--展开数据行结束-->\n        </tbody>\n    </table>\n    <!--赔率弹窗-->\n<div class=\"m-czWin\" v-show=\"pricesVisble\" :style=\"{'top':topChange+'px'}\" @mouseover=\"pricesVisble=true\" @mouseout=\"hidePrices()\">\n    <div class=\"title\">奖金变化</div>\n    <table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" class=\"m-tabTitle\">\n        <tr>\n            <th width=\"22%\">胜</th>\n            <th width=\"22%\">平</th>\n            <th width=\"22%\">负</th>\n            <th width=\"34%\">时间</th>\n        </tr>\n    </table>\n    <div class=\"m-czWin-con\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n        <colgroup>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"22%\"/>\n            <col width=\"34%\"/>\n        </colgroup>\n        <tr v-for=\"bp in betPriceByMid\">\n            <td><span :class=\"upDownClass(bp.h_trend)\">{{bp.h}}</span><i v-if=\"bp.h_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.h_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.d_trend)\">{{bp.d}}</span><i v-if=\"bp.d_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.d_trend)\"></i></td>\n            <td><span :class=\"upDownClass(bp.a_trend)\">{{bp.a}}</span><i v-if=\"bp.a_trend != 'equal'\" class=\"u-arrow\" :class=\"upDownIconClass(bp.a_trend)\"></i></td>\n            <td>{{bp.date.substring(5)+' '+bp.time.substring(0,5)}}</td>\n        </tr>\n    </table></div>\n</div>\n    <!--赔率弹窗/结束-->\n</div>\n<!--六场半全场-投注区域/结束-->\t\t</template>\n\t</div>\n\t<!--六场半全场/结束-->\n\t<!--四场进球-->\n\t<div class=\"m-zjqL\" v-if=\"activeGame==94\">\n\t\t<div class=\"m-czNotice\">玩法提示：请对以下4场比赛主客队进球数进行竞猜，全部猜中即中奖；比赛结果以90分钟（含伤停补时，不含加时赛）结果为准。</div>\n<div class=\"m-bonus\" v-if=\"JSON.stringify(lastPoolDraw) != '{}'\">\n    <div class=\"m-bonus-title\">\n            <div class=\"m-bonus-title-left\"></div>\n            <div class=\"m-bonus-title-center\" v-if=\"lastPoolDraw.lotteryDrawNum\"><span class=\"m-bonus-pad6\">{{lastPoolDraw.lotteryDrawNum}}期</span> 开奖信息</div>\n            <div class=\"m-bonus-title-right\"></div>\n    </div>\n    <div class=\"m-bonus-content\">\n<!--        <div class=\"m-bonus-sales\" v-if=\"lastPoolDraw.totalSaleAmount\"><span class=\"m-bonus-pad6\">销售额</span><span class=\"m-bonus-red\">{{lastPoolDraw.totalSaleAmount}}</span>元</div>-->\n<!--        <div class=\"m-bonus-line\"></div>-->\n        <template v-for=\"obj in lastPoolDraw.prizeLevelList\" v-if=\"lastPoolDraw.prizeLevelList\">\n            <div class=\"m-bonus-first\">\n                <div>{{obj.prizeLevel}} </div>\n                <div><span>中奖</span><span class=\"m-bonus-red\">{{obj.stakeCount}}</span>注 </div>\n                <div><span class=\"m-bonus-pad6\">单注奖金</span><span class=\"m-bonus-red\">{{obj.stakeAmount}}</span>元</div>\n            </div>\n            <div class=\"m-bonus-line\"></div>\n        </template>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.poolBalanceAfterDraw\">\n            <div><span class=\"m-bonus-pad6\">奖池</span><span class=\"m-bonus-red\">{{lastPoolDraw.poolBalanceAfterDraw}}</span>元</div>\n        </div>\n        <div class=\"m-bonus-line\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\"></div>\n        <div class=\"m-bonus-next\" v-if=\"lastPoolDraw.lotteryPromotionFlag==1 && lastPoolDraw.surplusAmount !=''\">\n            <div><span class=\"m-bonus-pad6\">派奖奖金滚存</span><span class=\"m-bonus-red\">{{lastPoolDraw.surplusAmount}}</span>元</div>\n        </div>\n    </div>\n</div><!--标题-->\n<div class=\"m-zstab\">\n    <ul>\n        <li :class=\"{'on': sellStatus==0}\" @click=\"changeStatus(0)\">在售奖期</li>\n        <li :class=\"{'on': sellStatus==1}\" @click=\"changeStatus(1)\">即将开售</li>\n    </ul>\n</div>\n<!--/标题结束-->\t\t<!--传足无赛事-->\n\t\t<nosellingmatch v-if=\"isNoSelling\"></nosellingmatch>\n\t\t<!--传足无赛事/结束-->\n\t\t<template v-else>\n<div class=\"m-czTime clear\">\n    <div class=\"m-czTime-l f-fl\">\n        <div class=\"m-czNums\">\n            <ul :style=\"{'margin-left':firstPeriodMargin+'px'}\">\n                <template v-for=\"sm in sellingPeriods\">\n                <li :class=\"{'on': activePeriod==sm}\" @click=\"changePeriod(sm)\">\n                    <span>{{sm}}</span>期\n                </li>\n                </template>\n            </ul>\n        </div>\n        <!--期次超6个后，箭头显示-->\n        <span class=\"u-arrowL\" v-if=\"isShowArrow==2 || isShowArrow==3\" @click=\"movePeriods(1)\"></span>\n        <span class=\"u-arrowR\" v-if=\"isShowArrow==2 || isShowArrow==1\" @click=\"movePeriods(2)\"></span>\n    </div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==0\">投注截止时间：{{matches.lotterySaleEndtime}}</div>\n    <div class=\"m-czTime-r f-fr\" v-if=\"sellStatus==1\">开售时间：{{matches.lotterySaleBegintime}}</div>\n</div><!--四场进球-投注区域-->\n<div class=\"m-czBet\">\n    <table cellpadding=\"0\" cellspacing=\"0\" class=\"m-czTab m-czBqcTab m-czZjqTab\">\n        <colgroup>\n            <col width=\"45\" />\n\t\t\t<col width=\"83\"/>\n\t\t\t<col width=\"110\"/>\n            <col />\n            <col width=\"70\" />\n            <col width=\"180\" />\n            <col width=\"70\" />\n            <col width=\"70\" />\n        </colgroup>\n        <thead>\n            <tr>\n                <th class=\"thNum\">场次</th>\n                <th class=\"thLs\">联赛</th>\n                <th class=\"thTime\">开赛日期</th>\n                <th class=\"thTeam\">\n                    <div class=\"team\">\n                        <span class=\"teamL\">主队</span>\n                        <em class=\"teamVs\">VS</em>\n                        <span class=\"teamR\">客队</span>\n                    </div>\n                </th>\n                <th class=\"thBqc\">主/客</th>\n                <th class=\"thOption\">进球数</th>\n                <!--<th class=\"thJc\">最近三场进球数</th>-->\n                <th class=\"thInfo\">资讯</th>\n                <th class=\"thData\">数据</th>\n            </tr>\n        </thead>\n        <tbody v-for=\"(m, index) in matches.matchList\" :key=\"index\">\n            <tr>\n                <td class=\"tdNum\">{{m.matchNum}}</td>\n                <td class=\"tdLs\">\n\t\t\t\t\t<span v-if=\"m.matchName!=''\">{{m.matchName}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTime\">\n                    <span v-if=\"m.startTime!=''\">{{m.startTime}}</span>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdTeam\">\n                    <div class=\"team\" v-if=\"m.infohubMatchId\">\n\t\t\t\t\t\t<a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"teamVs\">\n\t\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t\t<span>VS</span>\n\t\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"team\" v-else>\n\t\t\t\t\t\t<span class=\"teamL\">{{m.masterTeamName}}</span>\n\t\t\t\t\t\t<span class=\"gray\">VS</span>\n\t\t\t\t\t\t<span class=\"teamR\">{{m.guestTeamName}}</span>\n\n\t\t\t\t\t</div>\n                </td>\n                <td class=\"tdBqc\">\n                    <span>主</span>\n                    <span>客</span>\n                </td>\n                <td class=\"tdOption\">\n                    <div class=\"tdDiv\">\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>2</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3+</em></span>\n                    </div>\n                    <div class=\"tdDiv\">\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>0</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>1</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>2</em></span>\n                        <span onclick=\"jcwCtzcBetsNums.selectBets(this)\"><em>3+</em></span>\n                    </div>\n                </td>\n               <!--\n                <td class=\"tdJc\">\n                    <span v-if=\"m.h_id_dc\">进{{m.h_goal}}球失{{m.h_lose}}球</span>\n                    <span v-else>--</span>\n                    <span v-if=\"m.a_id_dc\">进{{m.a_goal}}球失{{m.a_lose}}球</span>\n                    <span v-else>--</span>\n                </td>\n            -->\n                <td class=\"tdInfo\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=1&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">讯</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n                <td class=\"tdData\">\n                    <a :href=\"'//www.sporttery.cn/jc/zqdz/index.html?showType=2&mid='+m.infohubMatchId\" class=\"blue\"\n                        v-if=\"m.infohubMatchId\">析</a>\n                    <span v-else class=\"gray\">--</span>\n                </td>\n            </tr>\n            <!--展开数据-->\n            <tr v-show=\"currentActive.indexOf(index) != -1\">\n                <td colspan=\"9\" class=\"tdDataCon\">\n                    <div class=\"fs-14 gray\" v-if=\"details[index]==''\">抱歉，暂无比赛资讯</div>\n<table cellpadding=\"0\" cellspacing=\"0\" class=\"tdDataTab\" v-else>\n    <colgroup>\n        <col width=\"145\">\n        <col width=\"240\">\n        <col width=\"\">\n        <col width=\"240\">\n    </colgroup>\n    <tr v-if=\"details[index].his_data != {}\">\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].his_data.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].his_data.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].his_data.lose}}</em>&nbsp;场</td>\n    </tr>\n    <tr v-else>\n        <th>[历史交锋]</th>\n        <td class=\"red\">主胜&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>--</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>--</em>&nbsp;场</td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[近期战绩]</th>\n        <td>\n            <span v-if=\"details[index].team_rec.h_rec==''\">--</span>\n            <template v-else v-for=\"dh in details[index].team_rec.h_rec\">\n                <span class=\"u-block bg-red\" v-if=\"dh=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"dh=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"dh=='lose'\">负</span>\n            </template>\n        </td>\n        <td></td>\n        <td>\n            <span v-if=\"details[index].team_rec.a_rec==''\">--</span>\n            <template v-else v-for=\"da in details[index].team_rec.a_rec\">\n                <span class=\"u-block bg-red\" v-if=\"da=='win'\">胜</span>\n                <span class=\"u-block bg-blue\" v-if=\"da=='draw'\">平</span>\n                <span class=\"u-block bg-green\" v-if=\"da=='lose'\">负</span>\n            </template>\n        </td>\n    </tr>\n    <tr>\n        <th class=\"tdDataTabTitle\">[同奖回查]</th>\n        <td class=\"red\">主胜&nbsp;<em>{{details[index].same_odds.win}}</em>&nbsp;场</td>\n        <td class=\"blue\">平&nbsp;<em>{{details[index].same_odds.draw}}</em>&nbsp;场</td>\n        <td class=\"green\">主负&nbsp;<em>{{details[index].same_odds.lose}}</em>&nbsp;场\n            <a :href=\"'//info.sporttery.cn/jcw/football/info/fb_match_info.php?m='+m.m_id\" class=\"u-more f-fr blue\">查看更多></a>\n        </td>\n    </tr>\n</table>                </td>\n            </tr>\n            <!--/展开数据结束-->\n        </tbody>\n    </table>\n</div>\n<!--四场进球-投注区域/结束-->\t\t</template>\n\t</div>\n\t<!--四场进球/结束-->\n\t<!--漂浮栏-->\n\t<czcalculator v-if=\"!isNoSelling\"></czcalculator>\n\t<!--/漂浮栏结束-->\n</div>\n<div style=\"font-size: 14px; color: #666666; margin-top: 24px\">免责声明：以上内容仅供参考，以线下实际销售情况为准。</div>\n<!--传足无赛事-->\n<script type=\"text/template\" id=\"jsq_wsj\">\n<div class=\"m-czNo\"><img src=\"//static.sporttery.cn/res_1_0/jcw/images/ico_game_no.png\"/></div>\n</script>\n<!--传足无赛事/结束-->\n<!--漂浮栏-->\n<script type=\"text/template\" id=\"jsq_pfl\">\n<div class=\"m-czBox\"><!--此块默认居左侧底部显示，开始选号超出一屏后，固定在屏幕下方显示-->\n\t<span class=\"u-icon\" onclick=\"jcwCtzcBetsNums.clearAllBets(this)\"><em class=\"ico-12\">清空选项</em></span>\n\t<div class=\"u-multiple\">\n\t\t<span>投</span>\n\t\t<span class=\"m-inpt\">\n            <i class=\"u-sub\" :class=\"{'gray': betTimesNum <= 1}\" @click=\"changeBetTime(0)\">&ndash;</i>\n            <input type=\"number\" v-model=\"betTimesNum\" @input=\"handleInputTime\" @blur=\"handleInputBlur\" onKeypress=\"return (/[\\d]/.test(String.fromCharCode(event.keyCode)))\"/>\n            <i class=\"u-add\" :class=\"{'gray': betTimesNum >= 99}\" @click=\"changeBetTime(1)\">+</i>\n        </span>\n\t\t<span>倍</span>\n\t</div>\n\t<p>选了<em class=\"red\">0</em>注&nbsp;&nbsp;&nbsp;&nbsp;金额：<em class=\"red\">0</em>元</p>\n</div>\n</script>\n<!--/漂浮栏结束-->\n<style>\ninput[type=number] {  \n    -moz-appearance:textfield;  \n}  \ninput[type=number]::-webkit-inner-spin-button,  \ninput[type=number]::-webkit-outer-spin-button {  \n    -webkit-appearance: none;  \n    margin: 0;  \n}\n</style>\n<script src=\"//static.sporttery.cn/res_1_0/jcw/default/ctzc/czJsqVue.js\"></script>   