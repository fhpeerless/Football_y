            "text": ".g-cont{background:#f5f5f5;min-width:1212px;}\nul{padding:0;margin:0}\nli{list-style:none;}\np{margin-bottom:0}\n.u-red{color:#E01212!important;}\n.u-green{color:#008F4A!important;}\n.u-blue{color:#2372D9!important;}\n.u-black{color:#181818!important;}\n.u-black a{color:#181818!important;}\n.z-clear:after{clear:both;content:'';display:block;}\n.m-marBtm0{margin-bottom:0!important;}\n/* 对阵卡片 */\n.m-matchCard {width:1180px;height:192px;background:url(\"../images/fotBasbal_match/bg_zqc.png\") #022D43 no-repeat;background-size:100% 100%;display:flex;flex-direction:row;align-items:center;padding-left:54px;padding-right:54px;border-radius:10px;}\n.m-matchCard .u-detail {width:207px;color:#b2b2b2;font-size:14px;}\n.m-matchCard .u-detail p {margin-bottom:0;line-height:24px;}\n.m-matchCard .u-detail p span {color:#fff;}\n.m-matchCard .u-logo,.m-matchCard .u-logo img {height:88px;}\n.m-matchCard .u-logo img {vertical-align:top;}\n.m-matchCard-Lf,.m-matchCard-Rt {display:flex;flex-direction:row;align-items:center;margin-top:8px;}\n.m-matchCard-Rt .u-detail {text-align:right;}\n.m-matchCard-Cen {flex:1;margin-bottom:8px;text-align:center;color:#d8d8d8;}\n.m-matchCard-Cen .u-top {font-size:16px;line-height:22px;}\n.m-matchCard-Cen .u-top a{ color: #d8d8d8}\n.m-matchCard-Cen .u-top a.u-hover:hover{ color: #FFFFFF;  border-bottom:1px solid #ffffff; text-decoration: none}\n.m-matchCard-Cen .u-middle {display:flex;flex-direction:row;justify-content:center;align-items:center;height:82px;font-size:28px;color:#fff;}\n.m-matchCard-Cen .u-middle a { cursor: pointer; color: #ffffff}\n.m-matchCard-Cen .u-middle a:hover{text-decoration: underline; color: #ffffff }\n.m-matchCard-Cen .u-middleLf,.m-matchCard-Cen .u-middleRt {width:140px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;text-align:left;}\n.m-matchCard-Cen .u-middleLf {text-align:right;}\n.m-matchCard-Cen .u-middleMid {display:flex;flex-direction:row;justify-content:center;width:150px;font-family:Arial;}\n.m-matchCard-Cen .u-middleMid .num {width:48px;font-size:40px;}\n.m-matchCard-Cen .u-middleMid .colon {width:22px;font-size:34px;}\n.m-matchCard-Cen .u-middleMid .vs {font-size:32px;}\n.m-matchCard-Cen .u-btm {font-size:12px;line-height:16px;}\n/* tab标签 */\n.m-tabs {display:flex;flex-direction:row;margin:-16px auto 16px;width:fit-content;background:#ffffff;border-radius:4px 4px 10px 10px;box-shadow:0 0 10px 0 rgba(0,0,0,.16);overflow:hidden;}\n.m-tabs li {width:114px;height:36px;line-height:36px;font-size:16px;color:#666666;text-align:center;position:relative;cursor:pointer;}\n.m-tabs li:hover,.m-tabs li.on {background:#f2f2f4;color:#274b7e;}\n.m-tabs li:hover + li:after,.m-tabs li.on + li:after {display:none}\n.m-tabs li:not(:first-child):after {content:\"\";position:absolute;left:0;top:9px;width:1px;height:18px;background:#d8d8d8;}\n/* 内容和标题 */\n.m-mainCon{position: relative;min-height: 500px;}\n.m-box {width:1180px;background:#ffffff;border-radius:10px;margin-bottom:16px;padding:24px 16px;}\n.m-title{font-weight:bold; height:44px;line-height:44px;font-size:20px;color:#181818;margin-bottom:8px;}\n.m-sub-title{font-size: 16px;text-align: left;color: #999999;padding-left: 8px;font-weight: normal}\n.m-title em {width:4px;height:20px;background:#e01212;display:inline-block;vertical-align:top;margin-top:12px;margin-right:12px;margin-bottom:8px;}\n.m-titleRt{float:right;font-weight:normal;font-size:12px;color:#999;display:flex;flex-direction:row;}\n.m-titleRt .m-checkList{display:flex;flex-direction:row;align-items:center;height:32px;line-height:30px;margin-left:16px;margin-top:6px;border:1px solid #ececec;border-radius:16px;background:#f5f5f5;}\n.m-titleRt .m-checkList .u-check{padding:0 16px;margin-left:-1px;cursor: pointer;}\n.m-titleRt .m-checkList .u-check:last-child{margin-right:-1px;}\n.m-titleRt .m-checkList .active{color:#414141;border:1px solid #d8d8d8;border-radius:16px;background: linear-gradient(180deg,#ffffff, #fdfdfd 42%, #f5f5f5);}\n.m-title-sub{font-size: 16px;color: #414141;;margin-bottom:8px}\n/* 比赛信息页面 */\n.m-list{margin:0 16px;}\n.m-list li {margin-bottom:32px;}\n.m-listTitle {margin-bottom:8px;font-size:18px;line-height:26px;font-weight:bold;color:#181818;}\n.m-list li a{text-decoration:none;}\n.m-list li:hover .m-listTitle{color:#e01212;}\n.m-listCon {margin-bottom:16px;line-height:22px;font-size:14px;color:#666;}\n.m-listTime {line-height:20px;font-size:14px;color:#999;}\n.m-listNone {margin-bottom:24px;height:98px;line-height:98px;font-size:16px;color:#666;text-align:center;}\n.m-list1{margin:0 16px;}\n.m-list1 li {line-height:22px;margin-bottom:14px;display:flex;justify-content:space-between;}\n.m-list1 li:last-child{margin-bottom:0;}\n.m-list1 li a{display:flex;justify-content:space-between;width:100%;text-decoration:none;}\n.m-list1 .left {font-size:16px;color:#414141;max-width:800px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}\n.m-list1 li:hover .left{color:#e01212;}\n.m-list1 .right {font-size:12px;color:#999;}\n.m-matchInfo-none {height:446px;line-height:446px;text-align:center;font-size:16px;color:#666;}\n/* 固定奖金页面 */\n.m-table {margin-bottom:32px;width:100%;line-height:20px;border-collapse:separate;border-spacing:0;border:1px solid #ececec;border-radius:10px;background:#fff;text-align:center;overflow:hidden;}\n.m-table th {font-weight:normal;border-bottom:1px solid #d8d8d8;height:32px;font-size:12px;color:#666;background:#f5f5f5;}\n.m-table td {height:40px;font-size:14px;color:#181818;padding:10px 0;}\n.m-table td p:not(:last-child){padding-bottom:8px;}\n.m-table tr:not(:last-child) td {border-bottom:1px solid #d8d8d8;}\n.m-table .u-bgRed {padding:0 8px;margin:0 8px;height:20px;background:#f83d3d;color:#fff;border-radius:4px;display:inline-block;}\n.m-table .u-bgFa {border-bottom:none;background:#fafafa;}\n.m-table .u-bgWhite {background:#fff;border-right:1px solid #ececce;border-left:1px solid #ececec;border-bottom:none;}\n.m-table .u-batNum {padding:0 2px;}\n.m-table .u-batNum img {width:10px;height:10px;margin-right:-12px;margin-left:2px;vertical-align:top;margin-top:5px;}\n.m-table p {margin-bottom:2px;font-size:14px;}\n.m-table p:last-child {margin-bottom:0;}\n.m-table p.u-rq{color:#181818;}\n.m-table p.u-num{font-size:18px;color:#181818;line-height:24px;}\n.m-table-0 tr:nth-child(n+2) th {background:#fafafa;height:40px;}\n.m-table-0 tr:last-child th {border-bottom:none;}\n.m-table-0 td {border-left:1px solid #ececec;}\n.m-table-1 td:not(:last-child) {border-right:1px solid #ececce;}\n.m-table-2 {margin-bottom:0;}\n.m-table-2 .u-bgWhite1 {font-size:14px;background:#fff;border-right:1px solid #ececce;}\n.m-table-2 tr:nth-last-child(5) .u-bgWhite1 {border-bottom:none;}\n.m-table-2 .u-borLeft,.m-table-2 td:not(:first-child) {border-left:1px solid #ececec;}\n.m-table-2 .u-bgWhite1 + td {border-left:none;}\n.m-tableNone {border-bottom:none!important;color:#414141!important;}\n.m-tableNone1,.m-tableNone2{margin-bottom:32px;height:72px;line-height:72px;background:#f5f5f5;border-radius:4px;font-size:14px;color:#414141;text-align:center;}\n.m-tableNone2{margin-bottom:0;}\n.m-tips {font-size:12px;color:#999;line-height:16px;padding-bottom:16px;}\n.m-table-1 .u-oneLine td{height:80px;}\n.m-table .u-txtRight{text-align:right;padding-right:188px;}\n.m-table .u-txtRightSpf{text-align:right;padding-right:114px;}\n.m-table .u-txtRightSpf .u-img{width: 11px;display: inline-block;}\n.m-table .u-txtRightlqSpf{text-align:right;padding-right:176px;}\n.m-table .u-txtRightlqSpf .u-lqimg{width: 11px;display: inline-block;}\n/* 比赛数据 */\n.m-featureAnalysis{display:flex;flex-direction:row;}\n.m-featureAnalysis .m-left{flex:1;text-align:right;}\n.m-featureAnalysis .m-center{width:154px;text-align:center;font-size:18px;color:#181818;}\n.m-featureAnalysis .m-right{flex:1;text-align:left;}\n.m-featureAnalysis .u-tit{margin-bottom:20px;height:24px;line-height:24px;}\n.m-featureAnalysis .u-tit span{display:inline-block;padding:0 8px;background:#274B7E;color:#fff;font-size:16px;border-radius:4px;}\n.m-featureAnalysis .u-cont{height:28px;line-height:28px;margin-bottom:28px;}\n.m-featureAnalysis .u-cont:last-child{margin-bottom:8px;}\n.m-featureAnalysis .data{font-size:14px;color:#181818;}\n.m-featureAnalysis .chart{width:319px;height:12px;background:#f5f5f5;display:inline-block;vertical-align:top; margin-top:8px;}\n.m-featureAnalysis .m-left .chart{margin-left:18px;}\n.m-featureAnalysis .m-right .chart{margin-right:18px;}\n.m-featureAnalysis .u-bgRed,.m-featureAnalysis .u-bgGrey{background:#e01212;height:100%;display:inline-block;vertical-align:top;}\n.m-featureAnalysis .u-bgGrey{background:#999;}\n.m-tableBox{width:100%;border:1px solid #ececec;border-radius:4px;margin-bottom:32px;}\n.m-tableBox-1{width:570px;float:left;margin-right:8px;}\n.m-tableBox-1:last-child{margin-right:0;}\n.m-tableBox .m-tableTitle{padding:0 16px;height:48px;line-height:48px;font-size:16px;color:#d8d8d8;position:relative;z-index: 15}\n.m-tableBox .m-tableTitle .u-team{padding:0 8px;margin-right:12px;height: 24px;line-height:24px;color:#fff;border-radius:4px;background:#274B7E;display:inline-block;}\n.m-tableBox .m-tableTitle .u-tit{color:#181818;margin-right:12px;}\n.m-tableBox .m-tableTitle .u-tit1{color:#414141;margin-right:12px;}\n.m-tableBox .m-tableTitle .u-more{float:right;font-size:12px;color:#499BF4;}\n.m-tableBox .m-tableTitle-2{height:auto;line-height:30px;padding:10px 16px 6px;}\n.m-tableBox .m-tableTitle-2 .u-gray{font-size:14px;color:#999;}\n.m-tableData{border-collapse:separate;border-spacing:0;width:100%;text-align:center;font-size:12px;color:#666;}\n.m-tableData th{height:32px;border-top:1px solid #d8d8d8;border-bottom:1px solid #d8d8d8;background:#f5f5f5;font-weight:normal;}\n.m-tableData td{height:56px;border-right:1px solid #ececec;border-bottom:1px solid #d8d8d8;}\n.m-tableData td:last-child{border-right:none;}\n.m-tableData tr:last-child td{border-bottom:none;}\n.m-tableData tr:nth-child(odd) td{background:#fafafa;}\n.m-tableData-1 td{height:40px;}\n.m-tableData-2 td,.m-tableData-3 td{height:40px;color:#181818;}\n.m-tableData-2 th{height:48px;line-height:16px;}\n.m-tableData-3 th{height:32px}\n.m-tableData .u-date{font-size:14px;}\n.m-tableData .u-team .left,\n.m-tableData .u-team .right{font-size:16px;color:#181818;}\n.m-tableData .u-team-1 .left,\n.m-tableData .u-team-1 .right{font-size:14px;color:#666;}\n.m-tableData .u-team-1 .left a,\n.m-tableData .u-team-1 .right a{color:#666;}\n.m-tableData .u-team-1 .left a:hover,\n.m-tableData .u-team-1 .right a:hover{color:#e01212 !important;}\n.m-tableData .u-team .u-top{font-size:16px;color:#414141;}\n.m-tableData .u-team a{text-decoration:none;}\n.m-tableData .u-team a:hover .u-top{color:#e01212;}\n.m-tableData .u-team a:hover .hoverClass{color:#e01212 !important;}\n.m-tableData .u-team .u-btm{color: #999;}\n.m-tableData .u-trend{text-align:left;padding-left:32px;}\n.m-tableData .u-trendFlex{display:flex;flex-direction:row;align-items:center;}\n.m-tableData .u-trendFlex .u-redBox{height:8px;background:#e01212;margin-right:16px;}\n.m-tableData .u-trendFlex .u-num{font-size:16px;color:#414141;}\n.m-tableData .u-jfTit{color:#181818;font-size:14px;}\n.m-tableData .u-jfTit-zq{color:#181818;font-size:14px; text-align: left;padding-left: 16px;}\n.m-tableData .u-jfTit-zq span{color: #666666; font-size: 12px;}\n.m-tableData .u-player{text-align:left;padding-left:16px;}\n.m-tableData .u-player .number{color:#414141;}\n.m-tableData .u-player .name{font-size:14px;}\n.m-tableData .u-player .role{color:#666;margin-left:4px;}\n.m-tableData .u-player .wound{margin-left:8px;width:14px;height:14px;line-height:14px;color:#fff;text-align:center;background:#666;border-radius:4px;display:inline-block;}\n.m-tableData td a {text-decoration: none}\n.m-tableFlex{display:flex;flex-direction:row;align-items:center;}\n.m-tableFlex .left{flex:1;text-align:right;}\n.m-tableFlex .center{width:160px;}\n.m-tableFlex .center1{width:114px;}\n.m-tableFlex .center2{width:62px;}\n.m-tableFlex .right{flex:1;text-align:left;}\n/* 锚点定位 */\n.m-pointPosition{position:fixed;bottom:20px;left:50%;margin-left:614px;padding:8px;width:64px;background:#fff;border:1px solid #fff;border-radius:10px;text-align:center;}\n.m-pointPositionList{padding:8px 0;font-size:14px;color:#666;border-bottom:1px solid #d8d8d8;cursor:pointer; text-decoration: none}\n.m-pointPosition a {text-decoration: none;}\na .m-pointPositionList:hover, a .m-pointPositionList:active{color:#e01212 !important;}\n.m-pointPosition a:last-child .m-pointPositionList{border-bottom:none;}\n.m-pointPosition.m-point-bk{bottom: 170px;}\n/* 比赛直播 */\n.m-process {margin:0 auto 20px;width:1100px;background:url(\"../images/fotBasbal_match/bg_zbt.png\") no-repeat center top;display:flex;flex-direction:row;padding-top:10px;}\n.m-processAgainst {width:456px;}\n.m-processLf,.m-processRt,.m-processAgainst {flex:1;display:flex;flex-direction:row;text-align:center;}\n.m-processLf {justify-content:flex-end;}\n.m-processRt {justify-content:flex-start;}\n.m-processLf .u-list,.m-processRt .u-list {width:80px;}\n.m-processAgainst .u-width122 { width: 122px}\n.m-process .u-list p:first-child {margin-bottom:24px;height:24px;line-height:24px;font-size:14px;color:rgba(255,255,255,.6);}\n.m-process .u-list p:last-child {height:48px;line-height:48px;font-size:20px;color:#666;}\n.m-processAgainst .u-list {flex:1;}\n.m-processAgainst .u-list p:last-child {color:#181818;}\n.m-processAgainst .u-list p:first-child {color:#fff;}\n.m-processAgainst .u-time {flex:none;width:212px;}\n.m-processAgainst .u-time p:first-child {font-size:16px;color:#181818;}\n.m-processAgainst .u-time p:last-child {font-size:34px;}\n.m-process .active p:first-child {color:#fff;}\n.m-process .active p:last-child {color:#181818;}\n.m-timeLineTips {margin:0 auto;padding-left:8px;width:394px;height:24px;background:#fafafa;border-radius:4px;font-size:14px;color:#414141;display:flex;flex-direction:row;align-items:center;}\n.m-timeLineTips .u-icon {width:16px;height:16px;margin-left:12px;margin-right:2px;display:inline-block;}\n.m-timeLine {padding-top:26px;}\n.m-timeLine .u-whistle {height:16px;margin-bottom:8px;background:url(\"../images/fotBasbal_match/icon_bckc.png\") no-repeat center;}\n.m-timeLine .u-whistle1 {height:16px;margin-top:8px;background:url(\"../images/fotBasbal_match/icon_bcjs.png\") no-repeat center;}\n.m-timeLineList {position:relative;padding:16px 0;}\n.m-timeLineList:before {content:\"\";position:absolute;z-index:0;top:0;left:50%;width:1px;height:100%;background:#4F4F4F;}\n.m-timeLineList li {position:relative;z-index:1;display:flex;flex-direction:row;align-items:center;margin-bottom:12px;}\n.m-timeLineList .left {flex:1;text-align:right;display:flex;flex-direction:row;justify-content:flex-end;}\n.m-timeLineList .cont {width:463px;line-height:24px;font-size:14px;color:#181818;background:#ececec;border-radius:4px;padding:8px 32px;position:relative;display:flex;flex-direction:row;justify-content:space-between;align-items:center;}\n.m-timeLineList .cont .u-score {width:0px;color:#666;font-size:14px;}\n.m-timeLineList .cont .u-event {flex:1;}\n.m-timeLineList .cont .u-icon {width:24px;height:24px;margin-left:4px;}\n.m-timeLineList .left .cont:after {content:\"\";position:absolute;top:50%;right:-12px;margin-top:-7px;width:14px;height:14px;background:url(\"../images/fotBasbal_match/icon_lf.png\") no-repeat center;}\n.m-timeLineList .right .cont:after {content:\"\";position:absolute;top:50%;left:-12px;margin-top:-7px;width:14px;height:14px;background:url(\"../images/fotBasbal_match/icon_rt.png\") no-repeat center;}\n.m-timeLineList .right {flex:1;text-align:left;display:flex;flex-direction:row;justify-content:flex-start;}\n.m-timeLineList .center {width:94px;text-align:center;display:flex;flex-direction:row;justify-content:center;align-items:center;}\n.m-timeLineList .center .u-circle {width:44px;height:44px;background:#414141;border-radius:50%;font-size:13px;color:#ffffff;display:flex;flex-direction:row;align-items:center;justify-content:center;}\n.m-tableBox .m-tableTitle .u-lineUpIcon {float:right;font-size:14px;color:#666666;cursor:pointer;}\n.m-tableBox .m-tableTitle .u-lineUpIcon:hover {color:#fa5b57}\n.m-tableBox .m-tableTitle .u-lineUpIcon:hover + .m-lineUp {display:flex;}\n.m-tableTitle a:hover{ text-decoration: none}\n.m-lineUp {position:absolute;top:38px;right:3px;width:408px;height:264px;background:url(\"../images/fotBasbal_match/bg_fotbal.png\") no-repeat center;flex-direction:row;display:none}\n.m-lineUpLeft {flex:1;padding:20px 8px 20px 4px;display:flex;flex-direction:row;}\n.m-player {flex:1;display:flex;flex-direction:column;justify-content:center}\n.m-player ul {flex:1;display:flex;flex-direction:column;align-items:center;}\n.m-player-1 ul {justify-content:space-between;}\n.m-player-2 ul {justify-content:center;}\n.m-player-1 ul:before,.m-player-1 ul:after {content:'';display:block;}\n.m-player li {width:26px;height:26px;background:#fff;border:2px solid #57b174;border-radius:50%;line-height:22px;text-align:center;font-size:14px;font-weight:bold;color:#666;}\n.m-player-1 li {margin:-2px 0;}\n.m-player-2 li {margin:5px 0;}\n.m-lineUpRight {flex:1;padding:20px 4px 20px 8px;display:flex;flex-direction:row;}\n.m-lineUpRight .m-player ul li {color:#fff;background:#414141;}\n.u-lfBallName {position:absolute;top:4px;left:12px;line-height:16px;font-size:12px;color:#22452d;}\n.u-rtBallName {position:absolute;top:4px;right:12px;font-size:12px;line-height:16px;color:#22452d;}\n.u-lfLineUp {position:absolute;bottom:4px;left:12px;line-height:16px;font-size:12px;color:#fff;}\n.u-rtLineUp {position:absolute;bottom:4px;right:12px;line-height:16px;font-size:12px;color:#fff;}\n/* loading */\n.el-loading-mask {position:absolute;z-index:2000;background-color:hsla(0,0%,100%,.9);margin:0;top:0;right:0;bottom:0;left:0;transition:opacity .3s;}\n.el-loading-spinner {top:240px;width:100%;text-align:center;position:absolute;}\n.el-loading-spinner .circular {height:56px;width:56px;animation:loading-rotate 2s linear infinite;}\n.el-loading-spinner .path {animation:loading-dash 1.5s ease-in-out infinite;stroke-dasharray:90,150;stroke-dashoffset:0;stroke-width:2.5;stroke:#f83d3d;stroke-linecap:round;}\n@keyframes loading-rotate {\n    to {transform:rotate(1turn)}\n}\n@keyframes loading-dash {\n    0% {stroke-dasharray:1,200;stroke-dashoffset:0}\n    50% {stroke-dasharray:90,150;stroke-dashoffset:-40px}\n    to {stroke-dasharray:90,150;stroke-dashoffset:-120px}\n}\n.jc-on-selling { height: 496px; display: flex; align-items: center; justify-content: space-around; color: #666666; font-size: 16px}\n/* 篮球 */\n.m-matchCard-bas{background-image:url(\"../images/fotBasbal_match/bg_lqjc.png\");background-color:#512D0E;}\n.m-matchCard-Cen .u-middleMid-1{width:190px;}\n.m-matchCard-Cen .u-middleMid-1 .num {width:68px;}\n.m-tableMar .m-table:not(:last-child){margin-bottom:16px;}\n.m-table .u-borNone{border-bottom:none}\n.m-no-result {text-align: center; padding:20px 0 40px 0;}\n\n/*球队本场分析*/\n.u-red span.u-zj{color: #FFFFFF}\n.u-zj{width: 14px; background: #e01212; border-radius: 0 4px 4px 0; color: #FFFFFF !important; position: absolute;top:2px;left:0; display: block; font-size: 12px}\n.m-teamAnalysis {display: inline;}\n.m-teamAnalysis .m-left { flex: 1; text-align: right;}\n.m-teamAnalysis .m-right { flex: 1; text-align: left;}\n.m-teamAnalysis .m-left .data {display: inline-block; width: 56px; margin-left: 30px; text-align: center; font-size: 16px; font-weight: bold}\n.m-teamAnalysis .m-right .data {display: inline-block; width: 56px; margin-right: 30px; text-align: center; font-size: 16px; font-weight: bold}\n.m-teamAnalysis .u-tit { height: 60px}\n.m-teamAnalysis .u-tit img{ height: 56px}\n.m-teamAnalysis-title, .m-teamAnalysis-con {display: flex}\n.m-teamAnalysis .chart{width:360px;height:12px;background:#f5f5f5;display:inline-block;vertical-align:top; margin-top:8px;}\n.m-teamAnalysis .m-left .u-tit img{ margin-left: 30px}\n.m-teamAnalysis .m-right .u-tit img{ margin-right: 30px}\n.m-teamAnalysis .u-tit span{background: none; color: #000000;}\n.m-teamAnalysis .m-center .u-tit {font-size: 18px;color: #666666;line-height: 60px}\n.m-teamAnalysis .u-dot-pad {padding: 0 16px;}\n.m-teamAnalysis .m-center {color: #666666; font-size: 18px; width: 154px; text-align: center;}\n.m-timeLineList .cont .u-so-w {width: 200px; display: flex; flex-direction: row;  justify-content: flex-end}\n.m-timeLineList .cont .u-so-w-r .u-icon{margin-left: 0; margin-right: 4px; vertical-align:bottom}\n.m-timeLineList .cont .u-so-w-r {align-items: center; justify-content: flex-start; ;}\n.u-event-list { display: flex; flex-direction: row; align-items: center; justify-content: flex-end; }\n.u-event-list-r { display: flex; flex-direction: row; align-items: center; justify-content: flex-start; }\n.m-timeLineList .cont .u-unf { padding-top: 2px;}\n.m-teamAnalysis .u-cont{height:28px;line-height:28px;margin-bottom:28px;}\n.m-teamAnalysis .u-cont:last-child{margin-bottom:8px;}\n.m-teamAnalysis .u-bgRed,.m-teamAnalysis .u-bgGrey{background:#e01212;height:100%;display:inline-block;vertical-align:top;}\n.m-teamAnalysis .u-bgGrey{background:#999;}\n.u-dot-pad{ padding: 0 16px; display: inline-block}\n.m-teamAnalysis .m-center {color: #666666; font-size: 18px;}\n\n/*球队赛果赢分走势*/\n.m-charts {display: flex; border-bottom: 1px solid #ececec;border-top: 1px solid #ececec;}\n.m-charts .m-charts-left,.m-charts .m-charts-center,.m-charts .m-charts-right{ display: flex;}\n.m-charts-left{width: 98px; background: #fafafa;color:#666666;display: flex;\n    flex-direction: column;}\n.m-charts-left .div1 {height: 64px;display: flex;align-items: center;justify-content: space-evenly;border-bottom: 1px solid #ececec;}\n.m-charts-left .div2 {height: 40px;display: flex;align-items: center;justify-content: space-evenly;border-bottom: 1px solid #ececec;}\n.m-charts-left .div3 {height: 196px;display: flex;align-items: center;justify-content: space-evenly;}\n.m-charts-time{\n    flex: 1;\n    width:100%;\n    display: flex;\n    flex-direction: row;\n    border-bottom: 1px solid #ececec;\n    height: 64px;\n    align-items: center;justify-content: space-evenly;\n    background: #fafafa;\n}\n.m-charts-time div{\n    font-size: 14px;\n    height: 64px;\n    width: 100%;\n    text-align: center;\n    color: #999999;\n    background: #fafafa;\n    border: 1px solid #ececec;\n    line-height: 64px;\n}\n.m-charts-score{\n    flex: 1;\n    width:100%;\n    display: flex;\n    flex-direction: row;\n    border-bottom: 1px solid #ececec;\n    height: 40px;\n    align-items: center;justify-content: space-evenly;\n    background: #ffffff;\n}\n.m-charts-score div{\n    height: 40px;\n    width: 100%;\n    font-size: 14px;\n    text-align: center;\n    color: #666666;\n    line-height: 40px;\n    border: 1px solid #ececec;\n}\n.m-charts-data{\n    flex: 1;\n    display: flex;\n    flex-direction: row;\n    width: 100%;\n}\n.m-charts-right{\n    width: 100%;overflow: hidden; position: relative;\n    /*max-width: 6.5rem;*/\n}\n.m-charts-con {\n    /*overflow: auto;*/\n    position: absolute; top:0; left:0; width: 100%}\n.m-charts-data-title, .m-charts-data{\n    /*height: 2.8rem*/\n}\n.m-charts-width-normal{\n    /*width: 6.5rem;*/\n    justify-content: space-around;\n}\n.m-charts-width {\n    width: 100%;\n}\n#main::before {\n    content: \"\";\n    position: absolute;\n    top: 5%;\n    left: 0.28rem;\n    width: 0;\n    height: 90%;\n    border-right: 0.01rem dashed #d8d8d8;\n}\n#main {\n    position: relative;\n    height: 196px;\n}\n#main::after {\n    width: 20px;\n    height: 196px;\n    position: absolute;\n    left: 3px;\n    top: 3px;\n    content: \"\";\n    display: block;\n    background: url(../images/multiline_sale/chart_left.png) no-repeat center;\n    background-size: 100%;\n}\n.u-cir-black{width:10px;height:10px;background:#414141;border-radius:50%;display: inline-block; vertical-align: middle;}\n.u-cir-gray{width:10px;height:10px