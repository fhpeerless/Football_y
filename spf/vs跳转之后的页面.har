              "value": "TencentEdgeOne"
            }
          ],
          "cookies": [],
          "content": {
            "size": 52103,
            "mimeType": "application/javascript",
            "text": "export const ZqbsComponent= {\n    // 组件的名称足球比赛数据\n    name: 'ZqbsComponent',\n    props: {\n        mid:{\n              type: String,\n              required:true\n          },\n        gm:{\n            type: String,\n            required:true\n        },\n        showjfb:{\n            type:Boolean,\n            default:true\n        },\n        showshooter:{\n            type:Boolean,\n            default:true\n        },\n        showinjury:{\n            type:Boolean,\n            default:true\n        }\n    },\n    data() {\n        return {\n            httpURl: jsCommonDataV1.webApi, //调用域名\n            midStr:'',\n            historyOk:false, //选择是否可选   历史交锋\n            tournamentFlag:0,//同赛制 为1生效 历史交锋\n            homeAwayFlag:0,//同主客 为1生效 历史交锋\n            limit:10,      // 历史交锋\n            limitR:10,      // 比赛近况\n            tournamentFlagR:0,//同赛制 为1生效 比赛近况\n            homeAwayFlagR:0,//同主客 为1生效 比赛近况\n            matchTablesOK:false, // 选择是否可选 比赛近况\n            matchTablesIndex:['total','home','away'],\n            matchTablesName:{'total':'总','home':'主','away':'客'},\n            featureSort1 :['last','sameHomeAway','eachHomeAway','eachSameHomeAway'],\n            matchResult:{},\n            futureMatches:{},\n            matchPlayer:{},\n            injurySuspensioneature:{},\n            historyData:{},\n            matchTables:{},\n            matchFeature:{},\n            maxGoalNum:0,\n            matchTablesArr:[{cn:'总',en:'total'},{cn:'主',en:'home'},{cn:'客',en:'away'}],\n            topH :470, // 特征分析距离顶部高度\n            bottomH:190, // footer高度\n            paddingMargin:56,\n            marginB:32\n        }\n    },\n    created() {\n        if(this.mid == ''){\n            this.midStr = 'matchId='+this.gm\n        }else{\n            this.midStr = 'sportteryMatchId='+this.mid\n        }\n        this.getDataBssj();\n        this.getResultHistoryV1();\n        if(this.showjfb) {\n            this.getMatchTablesV1();\n        }\n        // 比赛近况\n        this.getMatchResultV1();\n        // 查询未来赛事\n        this.getFutureMatchesV1();\n        if(this.showshooter){\n            // 比赛数据射手信息接口\n            this.getMatchPlayerV1();\n        }\n        if(this.showinjury) {\n            //查询比赛数据伤停信息\n            this.getInjurySuspensionV1();\n        }\n    },\n    async mounted(){\n        window.addEventListener('scroll', this.getRightSlider);\n\n    },\n    methods:{\n        // 未来赛事时间展示\n        getFutureTime(d){\n            if(d === undefined || d===''){\n                return ''\n            }\n\n            return d.split(' ')[0]\n        },\n        setValue(val){\n            if(val ==='' || val === undefined){\n                return \"-\"\n            }else{\n                return val\n            }\n        },\n        getRightSlider(){\n            if(document.getElementById('tz') === undefined || document.getElementById('tz') == null ){\n                window.removeEventListener('scroll',this.scrollToTop)\n                return\n            }\n            let bodyTop = document.querySelector(\"body, html\").scrollTop\n            if(bodyTop <=16){\n                document.querySelector('.m-pointPosition').style.bottom =\"auto\";\n                document.querySelector('.m-pointPosition').style.top ='200px'\n            }else{\n                document.querySelector('.m-pointPosition').style.bottom =\"170px\";\n                document.querySelector('.m-pointPosition').style.top ='auto'\n            }\n        },\n        scrollToTop () {\n            if(document.getElementById('tz') === undefined || document.getElementById('tz') == null ){\n                window.removeEventListener('scroll',this.scrollToTop)\n                return\n            }\n            let bodyH = document.querySelector(\"body, html\").offsetHeight\n            let bodyTop = document.querySelector(\"body, html\").scrollTop\n            let tzH = document.getElementById('tz').offsetHeight;\n            let lsH =  document.getElementById('ls').offsetHeight;\n            let target ='#tz'\n            if(bodyTop > this.topH && bodyTop < (this.topH + tzH)){\n                target = '#tz'\n            }else if(bodyTop >= (this.topH + tzH)){\n                let lsMH = document.getElementById('lsM').offsetHeight\n                let jfbH = document.getElementById('jfb').offsetHeight\n                let bsjkH = document.getElementById('bsjk').offsetHeight\n                let wlssH =document.getElementById('wlss').offsetHeight\n                let ssxxH =document.getElementById('ssxx').offsetHeight\n                let stylH =document.getElementById('styl').offsetHeight\n                let curH = this.topH + tzH + lsMH +this.paddingMargin\n                if(bodyTop <curH){\n                    target ='#ls'\n                }else  if(bodyTop >=curH && bodyTop <(curH +jfbH + this.marginB)) {\n                    target ='#jfb'\n                }else if(bodyTop >=(curH+jfbH + this.marginB) && bodyTop <(curH +jfbH +bsjkH + this.marginB )) {\n                    target ='#bsjk'\n                }else if(bodyTop >=(curH +jfbH +bsjkH + this.marginB ) && bodyTop <(curH +jfbH +bsjkH +wlssH+ this.marginB)){\n                    target ='#wlss'\n                }else if(bodyTop >=(curH +jfbH +bsjkH +wlssH+ this.marginB) && bodyTop <(curH +jfbH +bsjkH +wlssH +ssxxH+ this.marginB)){\n                    target ='#ssxx'\n                }else if(bodyTop >=(curH +jfbH +bsjkH +wlssH +ssxxH+ this.marginB) && bodyTop <(curH +jfbH +bsjkH +wlssH +ssxxH +stylH+ this.marginB)){\n                    target ='#stylH'\n                }else{\n                    target =''\n                }\n            }else if(bodyTop <= this.topH){\n                target =''\n            }\n            this.getPosition(target)\n        },\n        getPosition(_target) {\n            let nodeList = document.querySelectorAll('.m-pointPosition a')\n            nodeList.forEach(value => {\n                value.childNodes[0].setAttribute('style', 'color:#666')\n            })\n            if (_target != '') {\n                document.querySelector('a[href=\"' + _target + '\"] .m-pointPositionList').setAttribute('style', 'color:#E01212')\n            }\n        },\n        setZBTrackEvent(eventName, data={}){\n            try{\n                dc.trackEvent(eventName, {'desc':JSON.stringify(data)})\n            }catch(error){\n\n            }\n        },\n        // 显示比例条颜色\n        ratioColor(v1,v2){\n            let a =parseFloat(v1)\n            let b =parseFloat(v2)\n            if(a===0 && b===0){\n                return''\n            }else if(a>b){\n                return 'u-bgRed';\n            }else if(a === b){\n                return 'u-bgGrey';\n            }else if(a<b){\n                return 'u-bgGrey';\n            }else{\n                return ''\n            }\n        },\n        //查询比赛数据伤停信息\n        async getInjurySuspensionV1(){\n            try{\n                let sendUrl = this.httpURl+'/gateway/uniform/football/getInjurySuspensionV1.qry?'+this.midStr;\n                let res = await axios.get(sendUrl);\n                this.injurySuspensioneature = {}\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}' && res.data.value!=null) {\n                    this.injurySuspensioneature = res.data.value\n                }\n            } catch (err) {\n                console.log(err);\n            }\n        },\n        // 比赛数据射手信息接口\n        async getMatchPlayerV1(){\n            try{\n                let sendUrl = this.httpURl+'/gateway/uniform/football/getMatchPlayerV1.qry?'+this.midStr+'&termLimits=3';\n                let res = await axios.get(sendUrl);\n                this.matchPlayer = {}\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.matchPlayer = res.data.value\n                }\n            }catch(err){\n                console.log(err);\n            }\n        },\n\n        // 查询未来赛事\n        async getFutureMatchesV1(){\n\n            try{\n                let sendUrl = this.httpURl+'/gateway/uniform/football/getFutureMatchesV1.qry?'+this.midStr+'&termLimits=4';\n                let res = await axios.get(sendUrl);\n\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.futureMatches = res.data.value\n\n                }\n            } catch (err) {\n                console.log(err);\n            }\n        },\n        // 比赛近况参数选择\n        matchSelect(varName,val,statName){\n            if(this[varName] == val){\n                return\n            }\n            this[varName] = val\n            this.getMatchResultV1()\n            if(varName==='tournamentFlagR'){\n                let optionValue = 'allLeague'\n                if(val==1){\n                    optionValue ='sameLeague'\n                }\n                this.setZBTrackEvent('click_matchDetail_leagueChoose',{'dataType':'recentGames','option':optionValue})\n            }else if(varName==='homeAwayFlagR'){\n                let optionValue = 'allHomeAway'\n                if(val==1){\n                    optionValue ='sameHomeAway'\n                }\n                this.setZBTrackEvent('click_matchDetail_homeAwayChoose',{'dataType':'recentGames','option':optionValue})\n            }else if(varName === 'limitR'){\n                let clickName ='click_matchDetail_last10'\n                let optionValue = 'allHomeAway'\n                if(val==20){\n                    clickName ='click_matchDetail_last20'\n                    optionValue ='sameHomeAway'\n                }\n                this.setZBTrackEvent(clickName,{'dataType':'recentGames'})\n            }\n        },\n        // 比赛近况\n        async getMatchResultV1(){\n            this.matchTablesOK =false\n            try{\n                let sendUrl =this.httpURl +'/gateway/uniform/football/getMatchResultV1.qry?'+this.midStr\n                    +'&termLimits='+this.limitR+'&tournamentFlag='+this.tournamentFlagR+'&homeAwayFlag='+this.homeAwayFlagR;\n                let res = await axios.get(sendUrl);\n                this.matchResult = {}\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.matchResult = res.data.value\n                }\n                this.matchTablesOK =true\n            } catch (err) {\n                this.matchTablesOK =true\n                console.log(err);\n            }\n        },\n        // 积分榜\n        async getMatchTablesV1(){\n            let temGm =''\n            if(this.mid == ''){\n                temGm = 'wbsjMatchId='+this.gm\n            }else{\n                temGm = 'gmMatchId='+this.mid\n            }\n            try{\n                let sendUrl =this.httpURl +'/gateway/uniform/football/getMatchTablesV2.qry?' + temGm\n                let res = await axios.get(sendUrl);\n                this.matchTables = {}\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.matchTables = res.data.value\n                }\n            }catch(err){\n                console.log(err);\n            }\n        },\n        // 历史交锋参数选择\n        historySelect(varName,val){\n            if(this.historyOk == false || this[varName] == val){\n                return\n            }\n            this[varName] = val\n            this.getResultHistoryV1()\n            if(varName==='tournamentFlag'){\n                let optionValue = 'allLeague'\n                if(val==1){\n                    optionValue ='sameLeague'\n                }\n                this.setZBTrackEvent('click_matchDetail_leagueChoose',{'dataType':'historical','option':optionValue})\n            }else if(varName==='homeAwayFlag'){\n                let optionValue = 'allHomeAway'\n                if(val==1){\n                    optionValue ='sameHomeAway'\n                }\n                this.setZBTrackEvent('click_matchDetail_homeAwayChoose',{'dataType':'historical','option':optionValue})\n            }else if(varName === 'limitR'){\n                let clickName ='click_matchDetail_last10'\n                let optionValue = 'allHomeAway'\n                if(val==20){\n                    clickName ='click_matchDetail_last20'\n                }\n                this.setZBTrackEvent(clickName,{'dataType':'historical'})\n            }\n        },\n        // 历史交锋\n        async getResultHistoryV1(){\n            this.historyOk = false\n            try{\n                let sendUrl =this.httpURl +'/gateway/uniform/football/getResultHistoryV1.qry?' + this.midStr + '&termLimits='\n                    + this.limit + '&tournamentFlag=' + this.tournamentFlag + '&homeAwayFlag=' + this.homeAwayFlag\n                let res = await axios.get(sendUrl);\n                this.historyData = {}\n\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.historyData = res.data.value\n                    if(this.historyData.matchList && this.historyData.matchList.length>0){\n                        for (const resKey in this.historyData.matchList) {\n                            if(this.historyData.matchList[resKey].totalTeamFullCourtGoalCnt>this.maxGoalNum){\n                                this.maxGoalNum=this.historyData.matchList[resKey].totalTeamFullCourtGoalCnt\n                            }\n                        }\n                    }\n\n                }\n\n            }catch (err) {\n                // console.log('11111',err)\n                this.historyOk = true\n            }\n            this.historyOk = true\n\n        },\n        // 特征分析\n        async getDataBssj(){\n            try {\n                let sendUrl = this.httpURl + '/gateway/uniform/football/getMatchFeatureV1.qry?termLimits=10&'+this.midStr\n                let res = await  axios.get(sendUrl);\n                if ( res.status == 200 && res.data.errorCode == \"0\" && JSON.stringify(res.data.value) !== '{}') {\n                    this.matchFeature = res.data.value;\n                }\n            } catch (err) {\n                console.log(err);\n            }\n            this.$emit('changeloadlshow',false)\n        },\n        getURL(url,mid,gm){\n            if(mid!=\"\" && mid >0){\n                return url+'&mid='+ mid\n            }else if(gm!=\"\" && gm > 0){\n                return url+'&gm='+gm\n            }\n            return '###'\n\n        },\n        linkToLeague(info, tab){\n            if(info){\n                let tabStr =''\n                if(tab != undefined){\n                    tabStr = '&showType='+tab\n                }\n                return '/zqlszl/?tournamentId='+info.tournamentId +tabStr;\n            }else {\n                return 'javascript:void(0)'\n            }\n        },\n        linkToTeam(tid){\n            if(tid !='' || tid !=0){\n                return '/zqlszl/qdzl/?tid='+tid\n            }\n            return 'javascript:void(0)'\n        }\n    },\n    template:`\n<div style=\"position: relative; z-index: 12;\">\n<div class=\"m-box\" id=\"tz\">\n<!-- 特征分析 -->\n<div >\n<div class=\"m-title\"><em></em>特征分析</div>\n<div class=\"m-featureAnalysis\" v-if=\"matchFeature !=undefined && Object.keys(matchFeature).length >0\">\n    <div class=\"m-left\">\n        <div class=\"u-tit\">\n            <span>{{matchFeature.homeTeamShortName}} (主)</span>\n        </div>\n        <div class=\"u-cont\" v-for=\"item in featureSort1\">\n            <span class=\"data\">{{matchFeature[item].homeWinGoalMatchCnt}}胜/{{matchFeature[item].homeDrawMatchCnt}}平/{{matchFeature[item].homeLossGoalMatchCnt}}负</span>\n            <span class=\"chart\">\n            <span :class=\"ratioColor(matchFeature[item].homeScoreRatio,matchFeature[item].awayScoreRatio)\"\n                      :style=\"{'width':matchFeature[item].homeScoreRatio+'%'}\"></span>\n            </span>\n        </div>\n\n        <div class=\"u-cont\">\n            <span class=\"data\">{{matchFeature.goalAvg.homeGoalAvgCnt}}个</span>\n            <span class=\"chart\">\n                <span :class=\"ratioColor(matchFeature.goalAvg.homeGoalAvgCntRatio,matchFeature.goalAvg.awayGoalAvgCntRatio)\"\n                      :style=\"{'width':matchFeature.goalAvg.homeGoalAvgCntRatio+'%'}\">\n                </span>\n            </span>\n        </div>\n        <div class=\"u-cont\">\n            <span class=\"data\">{{matchFeature.lossGoalAvg.homeLossGoalAvgCnt}}个</span>\n            <span class=\"chart\">\n                <span :class=\"ratioColor(matchFeature.lossGoalAvg.homeLossGoalAvgCntRatio,matchFeature.lossGoalAvg.awayLossGoalAvgCntRatio)\"\n                      :style=\"{'width':matchFeature.lossGoalAvg.homeLossGoalAvgCntRatio+'%'}\">\n                </span>\n            </span>\n        </div>\n    </div>\n    <div class=\"m-center\">\n        <div class=\"u-tit\"></div>\n        <div class=\"u-cont\">近{{matchFeature.last.totalLegCnt}}场交锋</div>\n        <div class=\"u-cont\">同主客交锋</div>\n        <div class=\"u-cont\">近{{matchFeature.eachHomeAway.totalLegCnt}}场战况</div>\n        <div class=\"u-cont\">同主客战况</div>\n        <div class=\"u-cont\">场均进球</div>\n        <div class=\"u-cont\">场均失球</div>\n    </div>\n    <div class=\"m-right\">\n        <div class=\"u-tit\">\n            <span>{{matchFeature.awayTeamShortName}} (客)</span>\n        </div>\n        <div class=\"u-cont\" v-for=\"item in featureSort1\">\n        <span class=\"chart\">\n         <span :class=\"ratioColor(matchFeature[item].awayScoreRatio,matchFeature[item].homeScoreRatio)\"\n                               :style=\"{'width':matchFeature[item].awayScoreRatio+'%'}\">\n                        </span>\n        </span>\n            <span class=\"data\">\n            {{matchFeature[item].awayWinGoalMatchCnt}}胜/{{matchFeature[item].awayDrawMatchCnt}}平/{{matchFeature[item].awayLossGoalMatchCnt}}负\n            </span>\n        </div>\n\n        <div class=\"u-cont\">\n        <span class=\"chart\">\n                <span :class=\"ratioColor(matchFeature.goalAvg.awayGoalAvgCntRatio,matchFeature.goalAvg.homeGoalAvgCntRatio)\"\n                      :style=\"{'width':matchFeature.goalAvg.awayGoalAvgCntRatio+'%'}\">\n                </span>\n        </span>\n        <span class=\"data\">{{matchFeature.goalAvg.awayGoalAvgCnt}}个</span>\n        </div>\n        <div class=\"u-cont\">\n        <span class=\"chart\">\n                <span :class=\"ratioColor(matchFeature.lossGoalAvg.awayLossGoalAvgCntRatio,matchFeature.lossGoalAvg.homeLossGoalAvgCntRatio)\"\n                      :style=\"{'width':matchFeature.lossGoalAvg.awayLossGoalAvgCntRatio+'%'}\">\n                </span>\n        </span>\n            <span class=\"data\">{{matchFeature.lossGoalAvg.awayLossGoalAvgCnt}}个</span>\n        </div>\n    </div>\n</div>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n\n</div>\n</div>\n<!-- 锚点定位 -->\n<div class=\"m-pointPosition\">\n    <a href=\"#tz\" target=\"_self\"><div class=\"m-pointPositionList\">特征<br/>分析</div></a>\n    <a href=\"#ls\"  target=\"_self\"><div class=\"m-pointPositionList\">历史<br/>交锋</div></a>\n    <a href=\"#jfb\"  target=\"_self\"><div class=\"m-pointPositionList\">积分<br/>榜</div></a>\n    <a href=\"#bsjk\"  target=\"_self\"><div class=\"m-pointPositionList\">比赛<br/>近况</div></a>\n    <a href=\"#wlss\"  target=\"_self\"><div class=\"m-pointPositionList\">未来<br/>赛事</div></a>\n    <a href=\"#ssxx\"  target=\"_self\"><div class=\"m-pointPositionList\">射手<br/>信息</div></a>\n    <a href=\"#styl\"  target=\"_self\"><div class=\"m-pointPositionList\">伤停<br/>一览</div></a>\n    <a href=\"#sy_735\"  target=\"_self\"><div class=\"m-pointPositionList\">返回<br/>顶部</div></a>\n</div>\n<div class=\"m-box\"  id=\"ls\">\n<!-- 历史交锋 -->\n<div id=\"lsM\">\n<div class=\"m-title\"><em></em>历史交锋\n    <div class=\"m-titleRt\" >\n        <div class=\"m-checkList\" :style=\"{'opacity': historyOk?1:0.5}\">\n            <div :class=\"tournamentFlag==0?'u-check active':'u-check'\" @click=\"historySelect('tournamentFlag',0)\"><span>全部赛制</span></div>\n            <div :class=\"tournamentFlag==1?'u-check active':'u-check'\"  @click=\"historySelect('tournamentFlag',1)\">相同赛制</div>\n        </div>\n        <div class=\"m-checkList\" :style=\"{'opacity': historyOk?1:0.5}\">\n            <div :class=\"homeAwayFlag==0?'u-check active':'u-check'\" @click=\"historySelect('homeAwayFlag',0)\">不区分主客场</div>\n            <div :class=\"homeAwayFlag==1?'u-check active':'u-check'\" @click=\"historySelect('homeAwayFlag',1)\">相同主客场</div>\n        </div>\n        <div class=\"m-checkList\" :style=\"{'opacity': historyOk?1:0.5}\">\n            <div :class=\"limit==10?'u-check active':'u-check'\" @click=\"historySelect('limit',10)\">近10场</div>\n            <div :class=\"limit==20?'u-check active':'u-check'\" @click=\"historySelect('limit',20)\">近20场</div>\n        </div>\n    </div>\n</div>\n\n<div class=\"m-tableBox\" v-if=\"JSON.stringify(historyData)!='{}'  \">\n    <div class=\"m-tableTitle\" v-if=\"historyData.statistics && JSON.stringify(historyData.statistics)!='{}'>0\" >\n        <span class=\"u-tit\">近{{historyData.statistics.totalLegCnt}}场</span><span class=\"u-team\">{{historyData.statistics.teamShortName}}</span>\n        <span class=\"u-red\">{{historyData.statistics.winGoalMatchCnt}}胜 ({{historyData.statistics.winProbability}})</span> |\n        <span class=\"u-green\">{{historyData.statistics.drawMatchCnt}}平 ({{historyData.statistics.drawProbability}})</span> |\n        <span class=\"u-blue\">{{historyData.statistics.lossGoalMatchCnt}}负 ({{historyData.statistics.lossProbability}})</span>\n    </div>\n    <table class=\"m-tableData\" v-if=\"historyData.matchList && historyData.matchList.length>0\">\n            <tr>\n                <th width=\"110\">比赛日期</th>\n                <th width=\"108\">赛制</th>\n                <th width=\"482\">\n                    <div class=\"m-tableFlex\">\n                        <div class=\"left\">主队</div>\n                        <div class=\"center\">VS</div>\n                        <div class=\"right\">客队</div>\n                    </div>\n                </th>\n                <th>总进球走势</th>\n            </tr>\n            <tr v-for=\"item in historyData.matchList\">\n            \n                <td class=\"u-date\">{{item.matchDate}}</td>\n                <td><a :href=\"linkToLeague(item)\" target=\"_blank\">{{item.tournamentShortName}}</a></td>\n                <td class=\"u-team\">\n                <template v-if=\"(item.sportteryMatchId && item.sportteryMatchId!='') || ((item.matchId && item.matchId!='') )\">\n                <a :href=\"getURL('/jc/zqdz/index.html?showType=2',item.sportteryMatchId,item.matchId)\">\n                    <div class=\"m-tableFlex\">\n                        <template v-if=\"item.homeTeamShortName == historyData.statistics.teamShortName\">\n                            <div v-if=\"item.homeMatchResult=='home'\" class=\"left u-red hoverClass\">{{item.homeTeamShortName}}</div>\n                            <div v-else-if=\"item.homeMatchResult=='draw'\" class=\"left u-green hoverClass\">{{item.homeTeamShortName}}</div>\n                            <div v-else-if=\"item.homeMatchResult=='away'\" class=\"left u-blue hoverClass\">{{item.homeTeamShortName}}</div>\n                        </template>\n                        <div class=\"left hoverClass\" v-else>{{item.homeTeamShortName}}</div>\n                        <div class=\"center\">\n                                <p class=\"u-top\">{{item.fullCourtGoal}}</p>\n                                <p class=\"u-btm hoverClass\">（半 {{item.halfTimeGoal}}）</p>\n                        </div>\n                        <template v-if=\"item.awayTeamShortName == historyData.statistics.teamShortName\">\n                        <div v-if=\"item.homeMatchResult=='home'\" class=\"right u-red hoverClass\">{{item.awayTeamShortName}}</div>\n                        <div v-else-if=\"item.homeMatchResult=='draw'\" class=\"right u-green hoverClass\">{{item.awayTeamShortName}}</div>\n                        <div v-else-if=\"item.homeMatchResult=='away'\" class=\"right u-blue hoverClass\">{{item.awayTeamShortName}}</div>\n                        </template>\n                        <div class=\"right hoverClass\" v-else>{{item.awayTeamShortName}}</div>\n                    </div>\n                  </a>\n                 </template>\n                  <div class=\"m-tableFlex\" v-else>\n                        <template v-if=\"item.homeTeamShortName == historyData.statistics.teamShortName\">\n                            <div v-if=\"item.homeMatchResult=='home'\" class=\"left u-red\">{{item.homeTeamShortName}}</div>\n                            <div v-else-if=\"item.homeMatchResult=='draw'\" class=\"left u-green\">{{item.homeTeamShortName}}</div>\n                            <div v-else-if=\"item.homeMatchResult=='away'\" class=\"left u-blue\">{{item.homeTeamShortName}}</div>\n                        </template>\n                        <div class=\"left\" v-else>{{item.homeTeamShortName}}</div>\n                        <div class=\"center\">\n                                <p class=\"u-top\">{{item.fullCourtGoal}}</p>\n                                <p class=\"u-btm\">（半 {{item.halfTimeGoal}}）</p>\n                        </div>\n                        <template v-if=\"item.awayTeamShortName == historyData.statistics.teamShortName\">\n                        <div v-if=\"item.homeMatchResult=='home'\" class=\"right u-red\">{{item.awayTeamShortName}}</div>\n                        <div v-else-if=\"item.homeMatchResult=='draw'\" class=\"right u-green\">{{item.awayTeamShortName}}</div>\n                        <div v-else-if=\"item.homeMatchResult=='away'\" class=\"right u-blue\">{{item.awayTeamShortName}}</div>\n                        </template>\n                        <div class=\"right\" v-else>{{item.awayTeamShortName}}</div>\n                    </div>\n                </td>\n                <td class=\"u-trend\">\n                    <div class=\"u-trendFlex\">\n                        <template v-if=\"maxGoalNum<1 || item.totalTeamFullCourtGoalCnt==0\">\n                        <div  class=\"u-redBox\" style=\"width:0\"></div><div class=\"u-num\"></div>\n                        </template>\n                        <template v-else>\n                        <div  class=\"u-redBox\" :style=\"{'width':parseInt(item.totalTeamFullCourtGoalCnt/maxGoalNum*350)+'px'}\"></div>\n                        <div class=\"u-num\">{{item.totalTeamFullCourtGoalCnt}}</div>\n                        </template>\n                    </div>\n                </td>\n            </tr>\n    \n        </table>\n        <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</div>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</div>\n\n<!-- 积分榜 -->\n<div class=\"z-clear\" id=\"jfb\">\n<div class=\"m-title\"><em></em>积分榜\n<span class=\"m-sub-title\">{{matchTables.leagueShortName}}</span><span class=\"m-sub-title\">{{matchTables.seasonName}}</span>\n</div>\n<template v-if=\"JSON.stringify(matchTables)!='{}'\">\n<template v-if=\"JSON.stringify(matchTables.homeTables)=='{}' && JSON.stringify(matchTables.awayTables)=='{}'\">\n <div class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</template>\n<template v-else>\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"JSON.stringify(matchTables.homeTables)!='{}'\">\n    <div class=\"m-tableTitle\" v-if=\"matchTables.homeTables && matchTables.homeTables.total \">\n     <template v-if=\"matchTables.homeTables.total\">\n        <span class=\"u-team\" >{{matchTables.homeTables.total.teamShortName}}</span>\n         <span class=\"u-tit1\">    \n            <template v-if=\"matchTables.homeTables.total.groupName\"> \n            {{matchTables.homeTables.total.groupName}} \n            </template>\n            <template v-else-if=\"matchTables.homeTables.total.phaseName\">\n            {{matchTables.homeTables.total.phaseName}} \n            </template>\n            第{{setValue(matchTables.homeTables.total.ranking)}}名\n         </span>\n    </template>\n    \n        <a :href=\"linkToLeague(matchTables, 2)\" target=\"_blank\" class=\"u-more\">查看更多></a>\n        </div>\n    <table class=\"m-tableData m-tableData-1\"  v-if=\"matchTables.homeTables\">\n        <tr>\n            <th width=\"56\"></th>\n            <th width=\"72\">场次</th>\n            <th width=\"96\">胜/平/负</th>\n            <th width=\"64\">胜率</th>\n            <th width=\"80\">进球/失球</th>\n            <th width=\"64\">净进球</th>\n            <th width=\"64\">积分</th>\n            <th>排名</th>\n        </tr>\n        <template v-for=\"item in matchTablesArr\">\n        <tr v-if=\"matchTables.homeTables[item.en]\">\n            <td class=\"u-jfTit\">{{item.cn}}</td>\n            <td>{{matchTables.homeTables[item.en].totalLegCnt}}</td>\n            <td>{{matchTables.homeTables[item.en].winGoalMatchCnt}}/{{matchTables.homeTables[item.en].drawMatchCnt}}/{{matchTables.homeTables[item.en].lossGoalMatchCnt}}</td>\n            <td>{{matchTables.homeTables[item.en].winProbability}}</td>\n            <td>{{matchTables.homeTables[item.en].goalCnt}}/{{matchTables.homeTables[item.en].lossGoalCnt}}</td>\n            <td>{{matchTables.homeTables[item.en].netGoal}}</td>\n            <td>{{matchTables.homeTables[item.en].points}}</td>\n            <td class=\"u-red\">{{matchTables.homeTables[item.en].ranking}}</td>\n        </tr>\n       </template>\n       \n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\" v-else>\n<div  class=\"m-listNone\" style=\"background: rgb(255, 255, 255);height: 200px\" >暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\"  v-if=\"matchTables.awayTables && JSON.stringify(matchTables.awayTables)!='{}'\">\n    <div class=\"m-tableTitle\">\n     <template v-if=\"matchTables.awayTables.total\">\n        <span class=\"u-team\" >{{matchTables.awayTables.total.teamShortName}}</span> \n         <span class=\"u-tit1\">    \n            <template v-if=\"matchTables.awayTables.total.groupName\"> \n            {{matchTables.awayTables.total.groupName}} \n            </template>\n            <template v-else-if=\"matchTables.awayTables.total.phaseName\">\n            {{matchTables.awayTables.total.phaseName}} \n            </template>\n            第{{setValue(matchTables.awayTables.total.ranking)}}名\n\n         </span>\n    </template>\n<a :href=\"linkToLeague(matchTables, 2)\" target=\"_blank\" class=\"u-more\">查看更多></a>\n    </div>\n    <table class=\"m-tableData m-tableData-1\" v-if=\"matchTables.awayTables\">\n        <tr>\n            <th width=\"56\"></th>\n            <th width=\"72\">场次</th>\n            <th width=\"96\">胜/平/负</th>\n            <th width=\"64\">胜率</th>\n            <th width=\"80\">进球/失球</th>\n            <th width=\"64\">净进球</th>\n            <th width=\"64\">积分</th>\n            <th>排名</th>\n        </tr>\n        <template v-for=\"item in matchTablesArr\">\n        <tr v-if=\"matchTables.awayTables[item.en]\">\n            <td class=\"u-jfTit\">{{item.cn}}</td>\n            <td>{{matchTables.awayTables[item.en].totalLegCnt}}</td>\n            <td>{{matchTables.awayTables[item.en].winGoalMatchCnt}}/{{matchTables.awayTables[item.en].drawMatchCnt}}/{{matchTables.awayTables[item.en].lossGoalMatchCnt}}</td>\n            <td>{{matchTables.awayTables[item.en].winProbability}}</td>\n            <td>{{matchTables.awayTables[item.en].goalCnt}}/{{matchTables.awayTables[item.en].lossGoalCnt}}</td>\n            <td>{{matchTables.awayTables[item.en].netGoal}}</td>\n            <td>{{matchTables.awayTables[item.en].points}}</td>\n            <td class=\"u-red\">{{matchTables.awayTables[item.en].ranking}}</td>\n        </tr>\n        </template>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\" v-else>\n<div  class=\"m-listNone\" style=\"background: rgb(255, 255, 255);height: 200px\" >暂无数据</div>\n</div>\n\n</template>\n\n</template>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\" >暂无数据</div>\n</div>\n<!-- 比赛近况 -->\n<div class=\"z-clear\" id=\"bsjk\">\n<div class=\"m-title\"><em></em>比赛近况\n    <div class=\"m-titleRt\">\n        <div class=\"m-checkList\" :style=\"{'opacity': matchTablesOK?1:0.5}\">\n            <div :class=\"tournamentFlagR==0?'u-check active':'u-check'\" @click=\"matchSelect('tournamentFlagR',0)\">全部赛制</div>\n            <div :class=\"tournamentFlagR==1?'u-check active':'u-check'\" @click=\"matchSelect('tournamentFlagR',1)\">相同赛制</div>\n        </div>\n        <div class=\"m-checkList\" :style=\"{'opacity': matchTablesOK?1:0.5}\">\n            <div :class=\"homeAwayFlagR==0?'u-check active':'u-check'\" @click=\"matchSelect('homeAwayFlagR',0)\">不区分主客场</div>\n            <div :class=\"homeAwayFlagR==1?'u-check active':'u-check'\" @click=\"matchSelect('homeAwayFlagR',1)\">相同主客场</div>\n        </div>\n        <div class=\"m-checkList\" :style=\"{'opacity': matchTablesOK?1:0.5}\">\n            <div :class=\"limitR==10?'u-check active':'u-check'\" @click=\"matchSelect('limitR',10)\">近10场</div>\n            <div :class=\"limitR==20?'u-check active':'u-check'\" @click=\"matchSelect('limitR',20)\">近20场</div>\n        </div>\n    </div>\n</div>\n<template v-if=\"JSON.stringify(matchResult)!='{}'\">\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"matchResult.home\">\n    <div class=\"m-tableTitle m-tableTitle-2\">\n        <span class=\"u-team\">{{matchResult.home.statistics.teamShortName}}</span>\n        <span class=\"u-tit1\">近{{matchResult.home.statistics.totalLegCnt}}场</span>\n        <span class=\"u-red\">{{matchResult.home.statistics.winGoalMatchCnt}}胜 ({{matchResult.home.statistics.winProbability?matchResult.home.statistics.winProbability:'0%'}})</span>\n        | <span class=\"u-green\">{{matchResult.home.statistics.drawMatchCnt}}平 ({{matchResult.home.statistics.drawProbability?matchResult.home.statistics.drawProbability:'0%'}})</span>\n        | <span class=\"u-blue\">{{matchResult.home.statistics.lossGoalMatchCnt}}负 ({{matchResult.home.statistics.lossProbability?matchResult.home.statistics.lossProbability:'0%'}})</span>\n        <div class=\"u-gray\">进{{matchResult.home.statistics.goalCnt}}球，失{{matchResult.home.statistics.lossGoalCnt}}球，净进{{matchResult.home.statistics.netGoal}}球</div>\n    </div>\n    <table class=\"m-tableData\" v-if=\"matchResult.home && matchResult.home.matchList && matchResult.home.matchList.length>0\">\n        <tr>\n            <th width=\"98\">比赛日期</th>\n            <th width=\"80\">赛制</th>\n            <th width=\"322\">\n                <div class=\"m-tableFlex\">\n                    <div class=\"left\">主队</div>\n                    <div class=\"center1\">VS</div>\n                    <div class=\"right\">客队</div>\n                </div>\n            </th>\n            <th>本队赛果</th>\n        </tr>\n        <tr v-for=\"item in matchResult.home.matchList\">\n            <td>{{item.matchDate}}</td>\n            <td><a :href=\"linkToLeague(item)\" target=\"_blank\">{{item.tournamentShortName}}</a></td>\n            <td class=\"u-team u-team-1\">\n                <template v-if=\"(item.sportteryMatchId && item.sportteryMatchId!='') || ((item.matchId && item.matchId!='') )\">\n                <a :href=\"getURL('/jc/zqdz/index.html?showType=2',item.sportteryMatchId,item.matchId)\">\n                <div class=\"m-tableFlex\">\n                    <div :class=\"matchResult.home.statistics.teamShortName == item.homeTeamShortName? 'left u-black hoverClass':'left hoverClass'\">{{item.homeTeamShortName}}</div>\n                    <div class=\"center1\" >\n                            <p class=\"u-top hoverClass\">{{item.homeTeamFullCourtGoalCnt}} : {{item.awayTeamFullCourtGoalCnt}}</p>\n                            <p class=\"u-btm hoverClass\">（半 {{item.halfTimeGoal}}）</p>\n                    </div>\n                    <div :class=\"matchResult.home.statistics.teamShortName == item.awayTeamShortName? 'right u-black hoverClass':'right hoverClass'\">{{item.awayTeamShortName}}</div>\n                </div>\n                 </a>\n                </template>\n                <div class=\"m-tableFlex\" v-else>\n                    <div :class=\"matchResult.home.statistics.teamShortName == item.homeTeamShortName? 'left u-black':'left'\">{{item.homeTeamShortName}}</div>\n                    <div class=\"center1\"  v-if=\"item.homeTeamFullCourtGoalCnt && tem.awayTeamFullCourtGoalCnt\">\n                            <p class=\"u-top\">{{item.homeTeamFullCourtGoalCnt}} : {{item.awayTeamFullCourtGoalCnt}}</p>\n                            <p class=\"u-btm\">（半 {{item.halfTimeGoal}}）</p>\n                    </div>\n                    <div :class=\"matchResult.home.statistics.teamShortName == item.awayTeamShortName? 'right u-black':'right'\">{{item.awayTeamShortName}}</div>\n                </div>\n                \n            \n            </td>\n            <td class=\"u-red\" v-if=\"item.teamMatchResult=='home'\">胜</td>\n            <td class=\"u-green\" v-else-if=\"item.teamMatchResult=='draw'\">平</td>\n            <td class=\"u-blue\" v-else>负</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\">\n    <div class=\"m-tableTitle m-tableTitle-2\" v-if=\"matchResult.away\">\n        <span class=\"u-team\">{{matchResult.away.statistics.teamShortName}}</span>\n        <span class=\"u-tit1\">近{{matchResult.away.statistics.totalLegCnt}}场</span>\n        <span class=\"u-red\">{{matchResult.away.statistics.winGoalMatchCnt}}胜 ({{matchResult.away.statistics.winProbability?matchResult.away.statistics.winProbability:'0%'}})</span>\n        | <span class=\"u-green\">{{matchResult.away.statistics.drawMatchCnt}}平 ({{matchResult.away.statistics.drawProbability?matchResult.away.statistics.drawProbability:'0%'}})</span>\n        | <span class=\"u-blue\">{{matchResult.away.statistics.lossGoalMatchCnt}}负 ({{matchResult.away.statistics.lossProbability?matchResult.away.statistics.lossProbability:'0%'}})</span>\n        <div class=\"u-gray\">进{{matchResult.away.statistics.goalCnt}}球，失{{matchResult.away.statistics.lossGoalCnt}}球，净进{{matchResult.away.statistics.netGoal}}球</div>\n    </div>\n    <table class=\"m-tableData\" v-if=\"matchResult.away && matchResult.away.matchList && matchResult.away.matchList.length>0\">\n        <tr>\n            <th width=\"98\">比赛日期</th>\n            <th width=\"80\">赛制</th>\n            <th width=\"322\">\n                <div class=\"m-tableFlex\">\n                    <div class=\"left\">主队</div>\n                    <div class=\"center1\">VS</div>\n                    <div class=\"right\">客队</div>\n                </div>\n            </th>\n            <th>本队赛果</th>\n        </tr>\n        <tr v-for=\"item in matchResult.away.matchList\">\n            <td>{{item.matchDate}}</td>\n            <td><a :href=\"linkToLeague(item)\" target=\"_blank\">{{item.tournamentShortName}}</a></td>\n            <td class=\"u-team u-team-1\">\n                <template v-if=\"(item.sportteryMatchId && item.sportteryMatchId!='') || ((item.matchId && item.matchId!='') )\">\n                <a :href=\"getURL('/jc/zqdz/index.html?showType=2',item.sportteryMatchId,item.matchId)\">\n                <div class=\"m-tableFlex\">\n                    <div :class=\"matchResult.away.statistics.teamShortName == item.homeTeamShortName? 'left u-black hoverClass':'left hoverClass'\">{{item.homeTeamShortName}}</div>\n                    <div class=\"center1\" >\n                            <p class=\"u-top hoverClass\">{{item.homeTeamFullCourtGoalCnt}} : {{item.awayTeamFullCourtGoalCnt}}</p>\n                            <p class=\"u-btm hoverClass\">（半 {{item.halfTimeGoal}}）</p>\n                    </div>\n                    <div :class=\"matchResult.away.statistics.teamShortName == item.awayTeamShortName? 'right u-black hoverClass':'right hoverClass'\">{{item.awayTeamShortName}}</div>\n                </div>\n                 </a>\n                </template>\n                <div class=\"m-tableFlex\" v-else>\n                    <div :class=\"matchResult.away.statistics.teamShortName == item.homeTeamShortName? 'left u-black':'left'\">{{item.homeTeamShortName}}</div>\n                    <div class=\"center1\"  v-if=\"item.homeTeamFullCourtGoalCnt && tem.awayTeamFullCourtGoalCnt\">\n                            <p class=\"u-top\">{{item.homeTeamFullCourtGoalCnt}} : {{item.awayTeamFullCourtGoalCnt}}</p>\n                            <p class=\"u-btm\">（半 {{item.halfTimeGoal}}）</p>\n                    </div>\n                    <div :class=\"matchResult.away.statistics.teamShortName == item.awayTeamShortName? 'right u-black':'right'\">{{item.awayTeamShortName}}</div>\n                </div>\n            </td>\n            <td class=\"u-red\" v-if=\"item.teamMatchResult=='home'\">胜</td>\n            <td class=\"u-green\" v-else-if=\"item.teamMatchResult=='draw'\">平</td>\n            <td class=\"u-blue\" v-else>负</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n</template>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<!-- 未来赛事 -->\n<div class=\"z-clear\" id=\"wlss\">\n<div class=\"m-title\"><em></em>未来赛事</div>\n<template v-if=\"JSON.stringify(futureMatches)!='{}'\">\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"futureMatches.home\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{futureMatches.home.teamShortName}}</span>\n<!--    <a href=\"#\" class=\"u-more\">查看更多></a>-->\n    </div>\n    <table class=\"m-tableData m-tableData-1\" v-if=\"futureMatches.home.matchList.length>0\">\n        <tr>\n            <th width=\"98\">比赛日期</th>\n            <th width=\"80\">赛制</th>\n            <th width=\"271\">\n                <div class=\"m-tableFlex\">\n                    <div class=\"left\">主队</div>\n                    <div class=\"center2\">VS</div>\n                    <div class=\"right\">客队</div>\n                </div>\n            </th>\n            <th>轮次</th>\n        </tr>\n        <tr v-for=\"item in futureMatches.home.matchList\">\n            <td class=\"u-black\">{{getFutureTime(item.matchDateTime)}}</td>\n            <td><a :href=\"linkToLeague(item)\" target=\"_blank\">{{item.tournamentShortName}}</a></td>\n            <td class=\"u-team u-team-1\">\n                <div class=\"m-tableFlex\">\n                    <div :class=\"futureMatches.home.teamShortName==item.homeTeamShortName?'left u-black':'left'\"><a :href=\"linkToTeam(item.uniformHomeTeamId)\" target=\"_blank\">{{item.homeTeamShortName}}</a></div>\n                    <div class=\"center2\">VS</div>\n                    <div :class=\"futureMatches.home.teamShortName==item.awayTeamShortName?'right u-black':'right'\"><a :href=\"linkToTeam(item.uniformAwayTeamId)\" target=\"_blank\">{{item.awayTeamShortName}}</a></div>\n                </div>\n            </td>\n            <td>{{item.phaseName?item.phaseName+' ':''}}{{item.groupName?item.groupName+' ':''}} {{item.gameweek?'第'+item.gameweek+'轮':''}}</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"futureMatches.away\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{futureMatches.away.teamShortName}}</span>\n<!--    <a href=\"#\" class=\"u-more\">查看更多></a>-->\n    </div>\n    <table class=\"m-tableData m-tableData-1\" v-if=\"futureMatches.away.matchList.length>0\">\n        <tr>\n            <th width=\"98\">比赛日期</th>\n            <th width=\"80\">赛制</th>\n            <th width=\"271\">\n                <div class=\"m-tableFlex\">\n                    <div class=\"left\">主队</div>\n                    <div class=\"center2\">VS</div>\n                    <div class=\"right\">客队</div>\n                </div>\n            </th>\n            <th>轮次</th>\n        </tr>\n        <tr v-for=\"item in futureMatches.away.matchList\">\n            <td class=\"u-black\">{{getFutureTime(item.matchDateTime)}}</td>\n            <td><a :href=\"linkToLeague(item)\" target=\"_blank\">{{item.tournamentShortName}}</a></td>\n            <td class=\"u-team u-team-1\">\n                <div class=\"m-tableFlex\">\n                    <div :class=\"futureMatches.away.teamShortName==item.homeTeamShortName?'left u-black':'left'\"><a :href=\"linkToTeam(item.uniformHomeTeamId)\" target=\"_blank\">{{item.homeTeamShortName}}</a></div>\n                    <div class=\"center2\">VS</div>\n                    <div :class=\"futureMatches.away.teamShortName==item.awayTeamShortName?'right u-black':'right'\"><a :href=\"linkToTeam(item.uniformAwayTeamId)\" target=\"_blank\">{{item.awayTeamShortName}}</a></div>\n                </div>\n            </td>\n            <td>{{item.phaseName?item.phaseName+' ':''}}{{item.groupName?item.groupName+' ':''}} {{item.gameweek?'第'+item.gameweek+'轮':''}}</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n</template>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<!-- 射手信息 -->\n<div class=\"z-clear\" id=\"ssxx\">\n<div class=\"m-title\"><em></em>射手信息\n<span class=\"m-sub-title\">{{matchPlayer.tournamentShortName}}</span><span class=\"m-sub-title\">{{matchPlayer.seasonName}}</span>\n</div>\n<template v-if=\"JSON.stringify(matchPlayer)!='{}'\">\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"matchPlayer.home\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{matchPlayer.home.teamShortName}}</span>\n<!--    <a href=\"#\" class=\"u-more\">查看更多></a>-->\n    </div>\n    <table class=\"m-tableData m-tableData-2\" v-if=\"matchPlayer.home  && matchPlayer.home.playerList.length >0\">\n        <tr>\n            <th width=\"242\" class=\"u-player\">号码-球员(位置)</th>\n            <th width=\"87\">总<br/>(首/替)</th>\n            <th width=\"80\">进球<br/>(本队占比)</th>\n            <th width=\"80\">助攻<br/>(本队占比)</th>\n            <th>场均<br/>进球/助攻</th>\n        </tr>\n        <tr v-for=\"item in matchPlayer.home.playerList\">\n            <td class=\"u-player\"><span class=\"number\" v-if=\"item.uniformNo !='' && item.uniformNo !='0'\">{{item.uniformNo}}-</span>\n                <span class=\"name\">{{item.personName}}</span>\n                <span class=\"role\" v-if=\"item.playerPositionDesc !=''\">({{item.playerPositionDesc}})</span>\n                <span class=\"wound\" v-if=\"item.injuryFlag==1\">伤</span>\n                <span class=\"wound\" v-if=\"item.suspensionFlag==1\">停</span>\n            </td>\n            <td>{{item.appearanceCnt}} ({{item.startedMatchCnt}}/{{item.substituteMatchCnt}})</td>\n            <td>{{item.goalCnt}} ({{item.goalProbability}})</td>\n            <td>{{item.assistCnt}} ({{item.assistProbability}})</td>\n            <td>{{item.goalAvgCnt}}/{{item.assistAvgCnt}}</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<div class=\"m-tableBox m-tableBox-1\" v-if=\"matchPlayer.away\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{matchPlayer.away.teamShortName}}</span>\n<!--    <a href=\"#\" class=\"u-more\">查看更多></a>-->\n    </div>\n    <table class=\"m-tableData m-tableData-2\" v-if=\"matchPlayer.away  && matchPlayer.away.playerList.length >0\">\n        <tr>\n            <th width=\"242\" class=\"u-player\">号码-球员(位置)</th>\n            <th width=\"87\">总<br/>(首/替)</th>\n            <th width=\"80\">进球<br/>(本队占比)</th>\n            <th width=\"80\">助攻<br/>(本队占比)</th>\n            <th>场均<br/>进球/助攻</th>\n        </tr>\n        <tr v-for=\"item in matchPlayer.away.playerList\">\n            <td class=\"u-player\">\n                <span class=\"number\" v-if=\"item.uniformNo !='' && item.uniformNo !='0'\">{{item.uniformNo}}-</span>\n                <span class=\"name\">{{item.personName}}</span>\n                <span class=\"role\" v-if=\"item.playerPositionDesc !='' \">({{item.playerPositionDesc}})</span>\n                <span class=\"wound\" v-if=\"item.injuryFlag==1\">伤</span>\n                <span class=\"wound\" v-if=\"item.suspensionFlag==1\">停</span>\n            </td>\n            <td>{{item.appearanceCnt}} ({{item.startedMatchCnt}}/{{item.substituteMatchCnt}})</td>\n            <td>{{item.goalCnt}} ({{item.goalProbability}})</td>\n            <td>{{item.assistCnt}} ({{item.assistProbability}})</td>\n            <td>{{item.goalAvgCnt}}/{{item.assistAvgCnt}}</td>\n        </tr>\n    </table>\n    <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n</template>\n<div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n</div>\n<!-- 伤停一览 -->\n<div class=\"z-clear\" id=\"styl\">\n<div class=\"m-title\"><em></em>伤停一览</div>\n<template v-if=\"JSON.stringify(injurySuspensioneature)!='{}'\">\n<div class=\"m-tableBox m-tableBox-1 m-marBtm0\" v-if=\"injurySuspensioneature && injurySuspensioneature.home\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{injurySuspensioneature.home.teamShortName}}</span></div>\n    <div class=\"m-listNone\" style=\"background: #fff;\" v-if=\"injurySuspensioneature.home.injuriesAndSuspensionsList.length==0\" >暂无数据</div>\n    <table class=\"m-tableData m-tableData-3\" v-else>\n        <tr>\n            <th width=\"242\" class=\"u-player\">号码-球员(位置)</th>\n            <th width=\"93\">总出场</th>\n            <th width=\"85\">首发出场</th>\n            <th width=\"85\">替补出场</th>\n            <th>状态</th>\n        </tr>\n        <tr v-for=\"item in injurySuspensioneature.home.injuriesAndSuspensionsList\">\n            <td class=\"u-player\">\n                <span class=\"number\" v-if=\"item.uniformNo !='' && item.uniformNo !='0'\">{{item.uniformNo}}-</span>\n                <span class=\"name\">{{item.personName}}</span\n                ><span class=\"role\" v-if=\"item.playerPositionDesc!=''\">({{item.playerPositionDesc}})</span></td>\n            <td>{{item.appearanceCnt}}</td>\n            <td>{{item.startedMatchCnt}}</td>\n            <td>{{item.substituteMatchCnt}}</td>\n            <td class=\"u-red\">{{item.suspensionFlag=='1'?'停': item.injuryFlag=='1'?'伤':''}}</td>\n        </tr>\n    </table>\n</div>\n<div class=\"m-tableBox m-tableBox-1 m-marBtm0\" v-if=\"injurySuspensioneature && injurySuspensioneature.away\">\n    <div class=\"m-tableTitle\"><span class=\"u-team\">{{injurySuspensioneature.away.teamShortName}}</span></div>\n    <div class=\"m-listNone\"  style=\"background: #fff;\" v-if=\"injurySuspensioneature.away.injuriesAndSuspensionsList.length==0\" >暂无数据</div>\n    <table class=\"m-tableData m-tableData-3\" v-else>\n        <tr>\n            <th width=\"242\" class=\"u-player\">号码-球员(位置)</th>\n            <th width=\"93\">总出场</th>\n            <th width=\"85\">首发出场</th>\n            <th width=\"85\">替补出场</th>\n            <th>状态</th>\n        </tr>\n        <tr v-for=\"item in injurySuspensioneature.away.injuriesAndSuspensionsList\">\n            <td class=\"u-player\">\n                <span class=\"number\" v-if=\"item.uniformNo !='' && item.uniformNo 