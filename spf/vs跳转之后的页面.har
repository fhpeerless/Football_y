          "content": {
            "size": 37957,
            "mimeType": "text/html",
            "text": "<!doctype html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge,chrome=1\">\n    <meta name=\"viewport\" content=\"width=1212, maximum-scale=1.0, user-scalable=no\" />\n    <base target=\"_blank\">\n    <meta name=\"applicable-device\" content=\"pc\">\n    <meta http-equiv=\"keywords\" content=\"\" />\n    <meta http-equiv=\"description\" content=\"\" />\n    <title>足球对阵详情</title>\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/css/bootstrap.min.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/common/reset_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/menu_1_0.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/footer.css\">\n    <link rel=\"stylesheet\" href=\"//static.sporttery.cn/res_1_0/jcw/css/fotbal_match.css\">\n<script>\n  function domainPreV1(tid){try{var temDomain=document.domain.split(\".\");if(tid==1){if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return temDomain[0]}else{return\"www\"}}else{if(temDomain&&temDomain[0]&&temDomain[0]!=\"www\"){return 'mgray'}else{return\"m\"}}}catch(e){if(tid==1){return\"www\"}else{return\"m\"}}};\n   var jsCommonDataV1={\n            advUrl:\"/htmlfrag\",\n            webApi: \"//webapi.sporttery.cn\",\n            resDomain: \"//static.sporttery.cn\",\n            res: \"//static.sporttery.cn/res_1_0/jcw/default\",\n            env: \"prd\",\n            domain1:\"www.lottery.gov.cn\"\n            ,domain2:\"www.sporttery.cn\"\n            ,domain3:\"m.lottery.gov.cn\"\n            ,domain4:\"m.sporttery.cn\"\n            ,domain5:domainPreV1(1)+\".lottery.gov.cn\"\n            ,domain6:domainPreV1(1)+\".sporttery.cn\"\n            ,domain7:domainPreV1(2)+\".lottery.gov.cn\"\n            ,domain8:domainPreV1(2)+\".sporttery.cn\"\n        };\n</script>    <script src=\"//static.sporttery.cn/res_1_0/common/js/commonV1.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/jquery-3.4.1.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/js/bootstrap.bundle.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/bootstrap-4.4.1-dist/js/bootstrap.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/common/js/axios.min.js\"></script>\n    <script src=\"//static.sporttery.cn/res_1_0/jcwm/default/common/vant4/vue@3.js\"></script>\n</head>\n<body>\n<!--topBar-->\n<div id=\"sy_735\">\n</div>\n<!--menu-->\n<div class=\"g-menu bg-red\" id=\"sy_736\">\n</div>\n<!--内容-->\n<div class=\"g-position\" id=\"sy_895\"></div>\n<div class=\"g-cont\" id=\"app\">\n    <div v-if=\"showType !=4\" style=\"text-align:center; padding:10px 0 10px 0; background: #f5f5f5;\"><div style=\"width:1176px; margin:0 auto; color:#666666; line-height:22px; font-size:14px\">特别提醒：本页面部分数据来源于第三方，仅供参考</div></div>\n    <div v-else style=\"text-align:center; padding:10px 0 10px 0; background: #f5f5f5;\"><div style=\"width:1176px; margin:0 auto; color:#666666; line-height:22px; font-size:14px\">特别提醒：本页面部分数据来源于第三方，仅供参考，不作为正式开奖结果。</div></div>\n    <div class=\"container\" v-cloak id=\"top\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"m-crumbs\"> <a class=\"color-999\" href=\"/\">竞彩网</a><span> &gt; </span>\n                    <a class=\"color-999\" href=\"/jczx/index.html\">竞彩足球</a>\n                    <template v-if=\"Object.keys(pageTitle).length > 0\">\n                    <span> &gt; </span>\n                   {{pageTitle.homeTeamShortName}} vs {{pageTitle.awayTeamShortName}}\n                    </template>\n                </div>\n            </div>\n        </div>\n        <!-- 对阵卡片 -->\n        <div class=\"row\">\n<!--            <template v-if='pageType ==1' >-->\n            <div class=\"col-12\" v-if=\"Object.keys(pageTitle).length==0\">\n                <div class=\"m-matchCard\">\n                    <!-- 左边 -->\n                    <div class=\"m-matchCard-Lf\">\n                        <div class=\"u-detail\">\n                        </div>\n                        <div class=\"u-logo\" v-if='pageType ==1'><img alt=\"\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_zd.png\" /></div>\n                    </div>\n                    <!-- 中间 -->\n                    <div class=\"m-matchCard-Cen\">\n                        <div class=\"u-top\"></div>\n                        <div class=\"u-middle\">\n                            <div class=\"u-middleLf\"></div>\n                            <div class=\"u-middleMid\">\n                                <div class=\"vs\" v-if='pageType ==1'>VS</div>\n                            </div>\n                            <div class=\"u-middleRt\"></div>\n                        </div>\n                        <div class=\"u-btm\"></div>\n                    </div>\n                    <!-- 右边 -->\n                    <div class=\"m-matchCard-Rt\">\n                        <div class=\"u-logo\" v-if='pageType ==1'><img alt=\"\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_kd.png\" /></div>\n                        <div class=\"u-detail\">\n\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12\" v-else>\n                <div class=\"m-matchCard\">\n                    <!-- 左边 -->\n                    <div class=\"m-matchCard-Lf\">\n                        <div class=\"u-detail\">\n                            <template v-if=\"pageTitle.wbsjStats && pageTitle.wbsjStats.home\">\n                            <p>排名: {{pageTitle.wbsjStats.home.groupName?pageTitle.wbsjStats.home.groupName:pageTitle.wbsjStats.home.phaseName}}\n                                第<span>{{pageTitle.wbsjStats.home.ranking!=''?pageTitle.wbsjStats.home.ranking :'-'}}</span>名\n                            </p>\n                            <p>赛季总成绩: <span>{{pageTitle.wbsjStats.home.sWinGoalMatchCnt!==''?pageTitle.wbsjStats.home.sWinGoalMatchCnt:'-'}}</span>胜 <span>{{pageTitle.wbsjStats.home.sDrawMatchCnt!==''?pageTitle.wbsjStats.home.sDrawMatchCnt:'-'}}</span>平 <span>{{pageTitle.wbsjStats.home.sLossGoalMatchCnt!==''?pageTitle.wbsjStats.home.sLossGoalMatchCnt:'-'}}</span>负</p>\n                            <p>赛季主场成绩: <span>{{pageTitle.wbsjStats.home.sHomeWinGoalMatchCnt!==''?pageTitle.wbsjStats.home.sHomeWinGoalMatchCnt:'-'}}</span>胜 <span>{{pageTitle.wbsjStats.home.sHomeDrawMatchCnt!==''?pageTitle.wbsjStats.home.sHomeDrawMatchCnt:'-'}}</span>平 <span>{{pageTitle.wbsjStats.home.sHomeLossGoalMatchCnt!==''?pageTitle.wbsjStats.home.sHomeLossGoalMatchCnt:'-'}}</span>负</p>\n                            </template>\n                        </div>\n                        <div class=\"u-logo\" >\n                            <img v-if=\"!pageTitle.homeTeamLogoPath\" alt=\"\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_zd.png\" />\n                            <img v-else alt=\"\" :src=\"pageTitle.homeTeamLogoPath\" onerror=\"javascript:this.src='https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_zd.png'\"/>\n                        </div>\n                    </div>\n                    <!-- 中间 -->\n                    <div class=\"m-matchCard-Cen\">\n                        <div class=\"u-top\">{{pageTitle.matchNum}}\n                            <a :href=\"linkToLeague(pageTitle)\" v-if=\"pageTitle.tournamentCnShortName !=''\" class=\"u-hover\">{{pageTitle.tournamentCnShortName}}></a>\n                            <span v-else>{{pageTitle.tournamentCnShortName}}</span>\n                        </div>\n                        <div class=\"u-middle\">\n                            <div class=\"u-middleLf\"><a :href=\"linkToTeam(pageTitle.uniformHomeTeamId)\" target=\"_blank\">{{pageTitle.homeTeamShortName}}</a></div>\n                            <div class=\"u-middleMid\" v-if=\"pageTitle.fullCourtGoal && pageTitle.fullCourtGoal!='' && pageTitle.fullCourtGoal!='-1:-1'\">\n                                <div class=\"num\">{{pageTitle.fullCourtGoal.split(\":\")[0]}}</div>\n                                <div class=\"colon\">:</div>\n                                <div class=\"num\">{{pageTitle.fullCourtGoal.split(\":\")[1]}}</div>\n                            </div>\n                            <div class=\"u-middleMid\" v-else>\n                                <div class=\"vs\">VS</div>\n                            </div>\n                            <div class=\"u-middleRt\"><a :href=\"linkToTeam(pageTitle.uniformAwayTeamId)\" target=\"_blank\">{{pageTitle.awayTeamShortName}}</a></div>\n                        </div>\n                        <div class=\"u-btm\">\n                            {{pageTitle.seasonName}}\n                            {{pageTitle.phaseName}}\n                            {{pageTitle.groupName?' '+pageTitle.groupName:''}}\n                            {{pageTitle.gameweek?' 第'+pageTitle.gameweek+'轮':''}}\n                            {{pageTitle.matchDateTime.substring(0,16)}}\n                        </div>\n                    </div>\n                    <!-- 右边 -->\n                    <div class=\"m-matchCard-Rt\">\n                        <div class=\"u-logo\">\n                            <img v-if=\"pageTitle.awayTeamLogoPath==''\" alt=\"\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_kd.png\" />\n                            <img v-else alt=\"\" :src=\"pageTitle.awayTeamLogoPath\" onerror=\"javascript:this.src='https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_kd.png'\"/>\n                        </div>\n                        <div class=\"u-detail\">\n                            <template v-if=\"pageTitle.wbsjStats && pageTitle.wbsjStats.away\">\n                                <p>排名: {{pageTitle.wbsjStats.away.groupName?pageTitle.wbsjStats.away.groupName:pageTitle.wbsjStats.away.phaseName}}\n                                    第<span>{{pageTitle.wbsjStats.away.ranking!=''?pageTitle.wbsjStats.away.ranking :'-'}}</span>名\n                                </p>\n                                <p>赛季总成绩: <span>{{pageTitle.wbsjStats.away.sWinGoalMatchCnt!==''?pageTitle.wbsjStats.away.sWinGoalMatchCnt:'-'}}</span>胜 <span>{{pageTitle.wbsjStats.away.sDrawMatchCnt!==''?pageTitle.wbsjStats.away.sDrawMatchCnt:'-'}}</span>平 <span>{{pageTitle.wbsjStats.away.sLossGoalMatchCnt!==''?pageTitle.wbsjStats.away.sLossGoalMatchCnt:'-'}}</span>负</p>\n                                <p>赛季客场成绩: <span>{{pageTitle.wbsjStats.away.sAwayWinGoalMatchCnt!==''?pageTitle.wbsjStats.away.sAwayWinGoalMatchCnt:'-'}}</span>胜 <span>{{pageTitle.wbsjStats.away.sAwayDrawMatchCnt!==''?pageTitle.wbsjStats.away.sAwayDrawMatchCnt:'-'}}</span>平 <span>{{pageTitle.wbsjStats.away.sAwayLossGoalMatchCnt!==''?pageTitle.wbsjStats.away.sAwayLossGoalMatchCnt:'-'}}</span>负</p>\n                            </template>\n                        </div>\n                    </div>\n                </div>\n            </div>\n<!--            </template>-->\n        </div>\n        <!--  tab标签 -->\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <ul class=\"m-tabs\">\n                    <li :class=\"showType==1? 'on' :'' \" @click=\"tabClick(1)\"><a>赛事资讯</a></li>\n                    <li :class=\"showType==2? 'on' :'' \" @click=\"tabClick(2)\"><a>赛事前瞻</a></li>\n                    <li v-if=\"mid !=''\" :class=\"showType==3? 'on' :'' \" @click=\"tabClick(3)\"><a>固定奖金</a></li>\n                    <li v-if=\"mid !=''\" :class=\"showType==4? 'on' :'' \" @click=\"tabClick(4)\"><a>比分直播</a></li>\n                </ul>\n            </div>\n        </div>\n        <!-- 内容 -->\n        <div class=\"row m-mainCon\">\n            <div class=\"el-loading-mask\" v-show=\"loadShow\">\n                <div class=\"el-loading-spinner\">\n                    <svg viewBox=\"25 25 50 50\" class=\"circular\"><circle cx=\"50\" cy=\"50\" r=\"20\" fill=\"none\" class=\"path\"></circle></svg>\n                </div>\n            </div>\n            <!-- 比赛信息 -->\n            <div class=\"col-12\" v-if=\"showType ==1 && loadShow ==false \">\n                <div class=\"m-box\">\n                    <!-- 比赛解析 -->\n<!--                   <template v-if=\"relatedNews.length>0 || contList.length>0\">-->\n                    <div>\n                        <div class=\"m-title\"><em></em>比赛解析</div>\n                        <ul class=\"m-list\" v-if=\"contList.length>0\">\n                            <li v-for=\"obj in contList\">\n                                <a :href=\"obj.contPath\">\n                                <div class=\"m-listTitle\">{{obj.title}}</div>\n                                <div class=\"m-listCon\">{{obj.description}}</div>\n                                <div class=\"m-listTime\">{{getYMDStr(obj.releaseDate)}}</div>\n                                </a>\n                            </li>\n                        </ul>\n                        <!-- 暂无数据 -->\n                        <div class=\"m-listNone\" v-else>暂无数据</div>\n                    </div>\n                    <!-- 最新新闻 -->\n                    <div>\n                        <div class=\"m-title\"><em></em>相关新闻</div>\n                        <ul class=\"m-list1\" v-if=\"relatedNews.length>0\">\n                            <li v-for=\"obj in relatedNews\">\n                                <a :href=\"obj.contPath\">\n                                <div class=\"left\">{{obj.title}}</div>\n                                <div class=\"right\">{{getMDStr(obj.releaseDate)}}</div>\n                                </a>\n                            </li>\n                        </ul>\n                        <div class=\"m-listNone\" v-else>暂无数据</div>\n                    </div>\n<!--                   </template>-->\n                    <!-- 无数据 -->\n<!--                    <div class=\"m-matchInfo-none\" v-else>暂无数据方案</div>-->\n                </div>\n            </div>\n            <!-- 比赛数据 -->\n            <div class=\"col-12\" v-if=\"showType ==2\">\n                <template v-if=\"mid==''&& gm ==''\">\n                    <div class=\"m-box\"><div class=\"jc-on-selling\">暂无数据</div></div>\n                </template>\n                <template v-else>\n                    <zqbs-component :mid=\"mid\" :gm=\"gm\" @changeloadlshow=\"changeLoadShow\" :showjfb=\"isShowJfb\" :showshooter=\"isShowShooter\" :showinjury=\"isShowInjury\"></zqbs-component>\n                </template>\n            </div>\n            <!-- 固定奖金 -->\n            <div class=\"col-12\"  v-if=\"showType ==3 && loadShow ==false\">\n                <div class=\"m-box\" v-if=\"mid !='' && FBonus.sectionsNo999 != '-2' && FBonus.isCancel != 1\">\n                    <!-- 开奖结果 -->\n                    <div>\n                        <div class=\"m-title\"><em></em>开奖结果</div>\n                        <table class=\"m-table m-table-0\" v-if=\"FBonus.sectionsNo999!='' && FBonus.sectionsNo999!='-1:-1' && FBonus.sectionsNo999!='无效场次' && FBonus.matchResultList && FBonus.matchResultList.length > 0\">\n                            <tr>\n                                <th width=\"306\">游戏</th>\n                                <th width=\"420\">开奖结果</th>\n                                <th width=\"420\">奖金</th>\n                            </tr>\n                            <tr >\n                                <th>胜平负</th>\n                                <td class=\"u-txtRight\"><span class=\"u-bgRed\">{{FBonus.matchResultByKey.had.combinationDesc?FBonus.matchResultByKey.had.combinationDesc:'--'}}</span></td>\n                                <td>{{FBonus.matchResultByKey.had.odds?FBonus.matchResultByKey.had.odds:'--'}}</td>\n                            </tr>\n                            <tr>\n                                <th>\n                                    让球胜平负\n                                    <p v-if=\"FBonus.matchResultByKey.hhad.combinationDesc==''\">({{FBonus.matchResultByKey.hhad.goalLine}})</p>\n                                </th>\n                                <td class=\"u-txtRight\"><span class=\"u-bgRed\">{{FBonus.matchResultByKey.hhad.combinationDesc?FBonus.matchResultByKey.hhad.combinationDesc:'--'}}</span></td>\n                                <td>{{FBonus.matchResultByKey.hhad.odds?FBonus.matchResultByKey.hhad.odds:'--'}}</td>\n                            </tr>\n                            <tr>\n                                <th>比分</th>\n                                <td class=\"u-txtRight\"><span class=\"u-bgRed\">{{FBonus.matchResultByKey.crs.combinationDesc?FBonus.matchResultByKey.crs.combinationDesc:'--'}}</span></td>\n                                <td>{{FBonus.matchResultByKey.crs.odds?FBonus.matchResultByKey.crs.odds:'--'}}</td>\n                            </tr>\n                            <tr>\n                                <th>总进球</th>\n                                <td class=\"u-txtRight\"><span class=\"u-bgRed\">{{FBonus.matchResultByKey.ttg.combinationDesc?FBonus.matchResultByKey.ttg.combinationDesc:'--'}}</span></td>\n                                <td>{{FBonus.matchResultByKey.ttg.odds?FBonus.matchResultByKey.ttg.odds:'--'}}</td>\n                            </tr>\n                            <tr>\n                                <th>半全场胜平负</th>\n                                <td class=\"u-txtRight\"><span class=\"u-bgRed\">{{FBonus.matchResultByKey.hafu.combinationDesc?FBonus.matchResultByKey.hafu.combinationDesc:'--'}}</span></td>\n                                <td>{{FBonus.matchResultByKey.hafu.odds?FBonus.matchResultByKey.hafu.odds:'--'}}</td>\n                            </tr>\n                        </table>\n                        <table class=\"m-table m-table-0\" v-else>\n             