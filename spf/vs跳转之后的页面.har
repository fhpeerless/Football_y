uments[2] : 'link';\n    var action = arguments.length > 3 && arguments[3] !== undefined ? arguments[3] : 'click';\n    if(opt_desc == '') opt_desc = '点击';\n    dc.trackEvent({\"eventName\": opt_label},{\"category\":category,\"platForm\":action,\"desc\":opt_desc});\n  }catch(e){    \n  }\n}\n"
