              "value": "0805ed7661a799b4fec143750cb4d3b2-b5c6817ef6387851c407567b38b095df"
            }
          ],
          "cookies": [],
          "content": {
            "size": 39171,
            "mimeType": "application/javascript",
            "text": "export const ZqzbComponent= {\n    // 组件的名称\n    name: 'ZqzbComponent',\n    props: {\n      mid:{\n          type: String,\n          required:true\n      }\n    },\n    data() {\n        return {\n            httpURl: jsCommonDataV1.webApi, //调用域名\n            midStr:'gmMatchId='+this.mid,\n            statsTc:'pointsScored,fieldGoalsMade,3PointMade,freeThrowsMade,blocks',\n            curMatchInfo:{},   //赛事信息\n            curTeamsInfo:{},   // 赛事球员信息\n            curMatchStatus:'', // 当前赛事状态\n            isCurLoadShow:true, // 父页面加载数据标志\n            // 数据来源：官方 + 外部数据\n            // 4未开播 5直播中 6直播结束 7直播暂停 8直播推迟 9直播取消\n            matchStatusLive:['4','5','6','7','8','9'], //比分直播\n            matchSections:{},//比赛比分\n            sectionsTxt:['','半场','全场','加时','点球'],\n            sectionsVal:['-1','1','2','3','4'],\n            matchStatusLiveTxt:{\n                '4':'即将开播',\n                '5':'直播中',\n                '6':'直播结束',\n                '7':'直播暂停',\n                '8':'直播推迟',\n                '9':'直播取消',\n                '11':'直播结束'\n            },\n            intervalId:0,\n            homePlayerStats:{},\n            awayPlayerStats:{},\n            eventList:{},\n            playerData:{},\n            hGoalkeeper:{},\n            aGoalkeeper:{},\n            awayNoData:[],\n            homeNoData:[],\n            homePos:{'Defender':[],'Wing Back':[],'Defensive Midfielder':[],'Midfielder':[],'Attacking Midfielder':[],'Striker':[]},\n            awayPos:{'Striker':[],'Attacking Midfielder':[],'Midfielder':[],'Defensive Midfielder':[],'Wing Back':[],'Defender':[]},\n            homeOrder:[\"Left\",\"Left/Centre\",\"Centre\",\"Centre/Right\",\"Right\"],\n            awayOrder:[\"Right\",\"Centre/Right\",\"Centre\",\"Left/Centre\",\"Left\"],\n            posx:['Defender','Wing Back','Defensive Midfielder','Midfielder','Attacking Midfielder','Striker'],\n            doNotShowMap:0,\n            baseEventList:[] //点球事件列表\n        }\n    },\n    created() {\n        this.getMatchGeneral();\n        this.getTeamStatis();\n        this.getMatchEvent();\n        this.getPlayerStatisV1();\n    },\n    mounted(){\n    },\n    methods:{\n        callZBTrackEvent(){\n            try{\n                dc.trackEvent('click_matchDetail_formation', {'desc':'{}'})\n            }catch(error){\n\n            }\n        },\n        setScore(score, num){\n            if(score == undefined || score.indexOf(\":\")<0 ) return ''\n            let scoreAry = score.split(\":\")\n            return scoreAry[num]\n        },\n        // 头部显示比赛结果\n        showTimeStr()\n        {\n            if(this.matchSections.matchPhaseTc=='10'){\n                return '中场休息'\n            }else if(this.matchSections.matchPhaseTc=='11' ||\n                this.matchSections.matchPhaseTc=='13' ||\n                this.matchSections.matchPhaseTc=='14' ||\n                this.matchSections.matchPhaseTc=='16'\n            ){\n                return '直播中'\n            }else if(this.matchSections.matchPhaseTc=='3' ||\n                this.matchSections.matchPhaseTc=='4' ||\n                this.matchSections.matchPhaseTc=='12'\n            ){\n                return '加时中'\n            }else if(this.matchSections.matchPhaseTc=='5'){\n                return '点球决胜'\n            }else if(this.matchSections.matchPhaseTc=='1'){\n                if(this.matchSections.matchMinute!=''){\n                    return (parseInt(this.matchSections.matchMinute) >45 ? '45+': this.matchSections.matchMinute+\"'\")\n                }else{\n                    return '直播中'\n                }\n            }else if(this.matchSections.matchPhaseTc=='2'){\n                if(this.matchSections.matchMinute!=''){\n                    return (parseInt(this.matchSections.matchMinute) >90 ? '90+': this.matchSections.matchMinute+\"'\")\n                }else{\n                    return '直播中'\n                }\n            }\n            return \"\"\n        },\n        // 头部样式点亮判断\n        showLight(sectionNo){\n            if(this.matchSections.matchStatus == 5){\n                // 加时\n                if(sectionNo == '3' &&\n                    (this.matchSections.matchPhaseTc=='3'\n                        ||this.matchSections.matchPhaseTc=='4'\n                        ||this.matchSections.matchPhaseTc=='12')){\n                    return 'u-list active'\n                }else if(sectionNo == '4' && this.matchSections.matchPhaseTc == 5){\n                    return 'u-list active'\n                }else {\n                    return 'u-list'\n                }\n            }else {\n                return 'u-list'\n            }\n        },\n        async getPlayerStatisV1(){\n            try{\n                let sendUrl = this.httpURl+'/gateway/uniform/football/matchlive/getPlayerStatisV1.qry?gmMatchId='+this.mid;\n                let res = await axios.get(sendUrl);\n                if ( res.status == 200 && res.data.errorCode == \"0\") {\n                    if (JSON.stringify(res.data.value) !== '{}') {\n                        this.playerData = res.data.value\n                    }\n                    this.homePos={'Defender':[],'Wing Back':[],'Defensive Midfielder':[],'Midfielder':[],'Attacking Midfielder':[],'Striker':[]}\n                    this.playerData.homeFormationList.forEach(item=>{\n                        if(this.posx.indexOf(item.playerFormationPosition)<0){\n                            this.doNotShowMap =1\n                        }else if(this.homeOrder.indexOf(item.playerRegionPosition)<0){\n                            this.doNotShowMap =1\n                        }\n                        if(item.playerFormationPosition === 'Goalkeeper'){\n                            this.hGoalkeeper = item\n                        }else{\n                            this.homePos[item.playerFormationPosition][item.playerRegionPosition] = item.uniformNo\n                        }\n                    })\n                    // if(this.playerData.homeTeamFormation && this.playerData.homeTeamFormation!=='' && this.playerData.homeTeamFormation.split('-').length>1){\n                    //     this.homeNoData = this.playerData.homeTeamFormation.split('-')\n                    // }\n                    this.awayPos={'Striker':[],'Attacking Midfielder':[],'Midfielder':[],'Defensive Midfielder':[],'Wing Back':[],'Defender':[]}\n                    this.playerData.awayFormationList.forEach(item=>{\n                        if(this.posx.indexOf(item.playerFormationPosition)<0){\n                            this.doNotShowMap =1\n                        }else if(this.homeOrder.indexOf(item.playerRegionPosition)<0){\n                            this.doNotShowMap =1\n                        }\n                        if(item.playerFormationPosition === 'Goalkeeper'){\n                            this.aGoalkeeper = item\n                        }else{\n                            this.awayPos[item.playerFormationPosition][item.playerRegionPosition] = item.uniformNo\n                        }\n                    })\n                    // if(this.playerData.awayTeamFormation && this.playerData.awayTeamFormation!=='' && this.playerData.awayTeamFormation.split('-').length>1){\n                    //     this.awayNoData = this.playerData.awayTeamFormation.split('-')\n                    // }\n                }\n            } catch (err) {\n                console.log(err)\n                //处理接口返回错误\n            }\n        },\n        async getTeamStatis(){\n            try{\n                 let sendUrl = this.httpURl+'/gateway/uniform/football/matchlive/getTeamStatisV1.qry?gmMatchId='+this.mid;\n                let res = await axios.get(sendUrl);\n                if ( res.status == 200 && res.data.errorCode == \"0\") {\n                    if (JSON.stringify(res.data.value) !== '{}') {\n                        this.curMatchInfo = res.data.value\n                    }\n\n                }\n            } catch (err) {\n                //处理接口返回错误\n            }\n        },\n        // 获取直播比分数据\n        async getMatchGeneral(mid){\n            try{\n                let sendUrl = this.httpURl+'/gateway/uniform/fb/getMatchScoreV1.qry?matchId='+this.mid;\n                let res = await axios.get(sendUrl);\n                if ( res.status == 200 && res.data.errorCode == \"0\") {\n                    if (JSON.stringify(res.data.value) !== '{}') {\n                        this.matchSections = res.data.value\n                        this.curMatchStatus = res.data.value.matchStatus\n                    }\n                }\n            } catch (err) {\n                //处理接口返回错误\n            }\n            this.$emit('changeloadlshow',false)\n            if(document.querySelector('#bszb') ==null || this.curMatchStatus != '5'){\n                return;\n            }\n            let _this = this\n            setTimeout(function (){\n                _this.getMatchGeneral()\n                _this.getTeamStatis()\n                _this.getPlayerStatisV1()\n                _this.getMatchEvent()\n            },30000)\n\n        },\n\n        //获取事件\n        async getMatchEvent(){\n\n            try{\n                let sendUrl =this.httpURl+'/gateway/uniform/fb/getMatchEventV1.qry?matchId='+this.mid\n                let res = await axios.get(sendUrl);\n                let list = {}\n                if ( res.status === 200 && res.data.errorCode === \"0\") {\n                    this.eventList = {}\n                    if (JSON.stringify(res.data.value) !== '{}' && res.data.value.eventList) {\n                        list = res.data.value.eventList\n                    }\n                    this.getMatchEventShow(list)\n                }else{\n                    this.eventList = {}\n                }\n            } catch (err) {\n                //处理接口返回错误\n                this.eventList = {}\n            }\n        },\n        //处理事件\n        getMatchEventShow(data){\n            if(Object.keys(data).length ===0 ) return\n            data.forEach((element,index) => {\n                let sortStr=element.matchMinute+' '\n                /*\n                *   1:上半场;\n                    2:下半场;\n                    3:上半场加时赛 ;\n                    4:下半场加时赛 ;\n                    5:点球决胜 ;\n                * */\n                if(element.matchPhaseTc == '1' && element.matchMinute >45){\n                    sortStr = '45+ '\n                }else if(element.matchPhaseTc == '2' && element.matchMinute >90){\n                    sortStr = '90+ '\n                }else if(element.matchPhaseTc == '3' && element.matchMinute >105){\n                    sortStr = '105+ '\n                }else if(element.matchPhaseTc == '4' && element.matchMinute >120){\n                    sortStr = '120+ '\n                }else if(element.matchPhaseTc == '5'){\n                    sortStr = sortStr+\"_d\"\n                }\n                if(this.eventList[sortStr] === undefined){\n                    this.eventList[sortStr] ={}\n                }\n                if(this.eventList[sortStr]['home'] ===undefined){\n                    this.eventList[sortStr]['home'] = {}\n                }\n                if(this.eventList[sortStr]['away'] ===undefined){\n                    this.eventList[sortStr]['away'] ={}\n                }\n\n                if(element.eventTc ==='substitutions' ) {\n                    if(this.eventList[sortStr]['home'][element.eventTc] === undefined){\n                        this.eventList[sortStr]['home'][element.eventTc] = {}\n                    }\n                    if(this.eventList[sortStr]['away'][element.eventTc] === undefined){\n                        this.eventList[sortStr]['away'][element.eventTc] = {}\n                    }\n                }else{\n                    if(this.eventList[sortStr]['home'][element.eventTc] === undefined){\n                        this.eventList[sortStr]['home'][element.eventTc] =[]\n                    }\n                    if(this.eventList[sortStr]['away'][element.eventTc] === undefined){\n                        this.eventList[sortStr]['away'][element.eventTc] =[]\n                    }\n                }\n                if(element.eventTc ==='substitutions' ){\n                    if( this.eventList[sortStr][element.teamType][element.eventTc][element.relationEventId+'r'] === undefined){\n                        this.eventList[sortStr][element.teamType][element.eventTc][element.relationEventId+'r'] = {}\n                    }\n                    this.eventList[sortStr][element.teamType][element.eventTc][element.relationEventId+'r'][element.eventCode] = element\n                }else{\n                    this.eventList[sortStr][element.teamType][element.eventTc].push(element)\n                }\n                if(element.matchPhaseTc == '5' || element.eventTc ==='penalty_shootout'){\n                    this.baseEventList.push(element)\n                }\n            })\n        },\n        //返回球队是否有数据，返回home或away\n        getMatchTeamsNum(data){\n            let isInfo = false\n            let keysAry = Object.keys(data)\n            if(keysAry.length>0){\n                keysAry.forEach((element,index) => {\n                    if( JSON.stringify(data[element]) !== \"{}\" && JSON.stringify(data[element]) !== \"[]\" ){\n                        isInfo = true\n                    }else{\n                    }\n                })\n            }\n            return isInfo\n        },\n        getMatchTeamHtml(data, teamType){\n            let str =''\n            if(JSON.stringify(data)!=='{}' && JSON.stringify(data)!=='[]'){\n                let keyAry =  Object.keys(data)\n                if(keyAry.length>0){\n                    keyAry.forEach((element,index) => {\n                        if(JSON.stringify(data[element]) !== \"{}\"){\n                            if(element ==='substitutions'){\n                                str += this.getEventInfoSub(data[element], element, teamType)\n                            }else{\n                                str+= this.getEventInfo(data[element], element, teamType)\n                            }\n                        }\n                    })\n                }\n            }\n            return str\n        },\n        getEventInfo(event, eventTc, teamType) {\n            let str =''\n            let keyAry = Object.keys(event)\n            if (keyAry.length > 0) {\n                keyAry.forEach((element, index) => {\n                    if(teamType === 'home'){\n                        str +='<p class=\"u-event-list\">'\n                    }else{\n                        str +='<p class=\"u-event-list-r\">'\n                    }\n\n                    if(teamType === 'home'){\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].uniformNo !=='' && event[element].uniformNo !='0') {\n                            str += event[element].uniformNo+'-'\n                        }\n                        str += event[element].personEnName\n                        str += '</span>'\n                        str += this.getEventIcon(event[element].eventCode)\n                    }else{\n                        str += '<span class=\"u-so-w-r\">'\n                        str += this.getEventIcon(event[element].eventCode)\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].uniformNo !=='' && event[element].uniformNo !='0') {\n                            str += event[element].uniformNo+'-'\n                        }\n                        str += event[element].personEnName\n                        str += '</span>'\n                        str += '</span>'\n                    }\n                    str +='</p>'\n                })\n            }\n            return str\n        },\n        getEventInfoSub(event, eventTc, teamType) {\n            let str =''\n            let keyAry = Object.keys(event)\n            if (keyAry.length > 0) {\n                keyAry.forEach((element, index) => {\n                    if(teamType === 'home'){\n                        str +='<p class=\"u-event-list\">'\n                    }else{\n                        str +='<p class=\"u-event-list-r\">'\n                    }\n\n                    if(teamType === 'home') {\n                        str += ' <span class=\"u-so-w\">'\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].SO.uniformNo !=='' && event[element].SO.uniformNo !='0'){\n                            str +=  event[element].SO.uniformNo + '-'\n                        }\n                        str +=  event[element].SO.personEnName\n                        str += '</span>'\n                        str += this.getEventIcon(event[element].SO.eventCode)\n                        str += '</span>'\n                        str += ' <span class=\"u-so-w\">'\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].SI.uniformNo !=='' && event[element].SI.uniformNo !='0'){\n                            str +=  event[element].SI.uniformNo + '-'\n                        }\n                        str +=  event[element].SI.personEnName\n                        str += '</span>'\n                        str += this.getEventIcon(event[element].SI.eventCode)\n                        str +='</span>'\n                    }else{\n\n                        str += '<span class=\"u-so-w u-so-w-r\">'\n                        str += this.getEventIcon(event[element].SI.eventCode)\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].SI.uniformNo !=='' && event[element].SI.uniformNo !='0'){\n                            str += event[element].SI.uniformNo + '-'\n                        }\n                        str +=  event[element].SI.personEnName\n                        str += '</span>'\n                        str += '</span>'\n                        str += ' <span class=\"u-so-w u-so-w-r\">'\n                        str += this.getEventIcon(event[element].SO.eventCode)\n                        str += '<span class=\"u-unf\">'\n                        if(event[element].SO.uniformNo !=='' && event[element].SO.uniformNo !='0'){\n                            str += event[element].SO.uniformNo + '-'\n                        }\n                        str += event[element].SO.personEnName\n                        str += '</span>'\n                        str += '</span>'\n                    }\n                    str +='</p>'\n                })\n            }\n            return str\n        },\n        getEventIcon(eventCode){\n            let yc = '<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hp.png\" alt=\"\"/>'\n            let rc = '<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hp-1.png\" alt=\"\"/>'\n            let og = '<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_wl.png\" alt=\"\"/>'\n            let g = '<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_jq.png\" alt=\"\"/>'\n            let so='<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hx.png\" alt=\"\"/>'\n            let si='<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hs.png\" alt=\"\"/>'\n            let y2c  = '<img class=\"u-icon\" src=\"//static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_y2c.png\" alt=\"\"/>'\n            let curIcon = ''\n            switch (eventCode.toUpperCase()){\n                case 'YC':\n                    curIcon =  yc;\n                    break;\n                case 'RC':\n                    curIcon =  rc;\n                    break;\n                case 'OG':\n                    curIcon =  og;\n                    break;\n                case 'G':\n                case 'PG':\n                case 'PSG':\n                    curIcon =  g;\n                    break;\n                case 'SO':\n                    curIcon =  so;\n                    break;\n                case 'SI':\n                    curIcon =  si;\n                    break;\n                case 'Y2C':\n                    curIcon = y2c\n                    break;\n                default:\n                    curIcon =''\n                    break;\n            }\n            return curIcon\n        },\n        getGoalByMinute(minute, timeCon){\n            let txtString = minute.replace(' ', '').replace('_d','') + \"'\"\n            this.baseEventList.forEach((element, index) => {\n                if (minute.indexOf('_d')>-1 || ((timeCon['home'] && timeCon['home'].penalty_shootout && timeCon['home'].penalty_shootout.length>0) || (timeCon['home'] && timeCon['home'].penalty_shootout && timeCon['away'].penalty_shootout.length>0))) {\n                    txtString = '点'\n                }\n            })\n            return txtString\n        }\n    },\n    template:`\n<div id=\"bszb\">\n    <div class=\"m-box\">\n<!--        比赛状态-->\n        <div class=\"m-process\">\n            <div class=\"m-processLf\">\n                <template v-if=\"matchSections.sectionsNos\">\n                    <div :class=\"showLight(matchSections.sectionsNos[key].sectionNo)\"\n                         v-for=\"key in Object.keys(matchSections.sectionsNos).reverse()\">\n                         <template v-if=\"matchSections.sectionsNos[key].sectionNo == 2 && (matchSections.matchPhaseTc == '2' || matchSections.matchPhaseTc == '1' || matchSections.matchPhaseTc == '10' )\">\n                         </template>\n                         <template v-else>\n                        <p>{{sectionsTxt[matchSections.sectionsNos[key].sectionNo]}}</p>\n                        <p>{{setScore(matchSections.sectionsNos[key].score, 0)}}</p>\n                       </template>\n                    </div>\n                </template>\n            </div>\n            <div class=\"m-processAgainst\">\n                <div class=\"u-list active u-width122\">\n                    <p>主队</p>\n                    <p>{{matchSections.homeTeamAbbName}}</p>\n                </div>\n                <div class=\"u-list u-time\">\n                    <p v-if=\"matchSections.matchStatus == '5'\">\n                        {{showTimeStr()}}\n                    </p>\n                    <p v-else>{{matchSections.matchStatusName}}</p>\n                    <p v-if=\"matchSections.sectionsNo999!=undefined && matchSections.sectionsNo999!='' && matchSections.sectionsNo999.indexOf(':')>-1\">\n                        {{matchSections.sectionsNo999.split(':')[0]}} : {{matchSections.sectionsNo999.split(':')[1]}}\n                    </p>\n                    <p v-else>VS</p>\n                </div>\n                <div class=\"u-list u-width122\">\n                    <p>客队</p>\n                    <p>{{matchSections.awayTeamAbbName}}</p>\n                </div>\n            </div>\n            <div class=\"m-processRt\">\n\n                <template v-if=\"matchSections.sectionsNos\">\n                    <div :class=\"showLight(item.sectionNo)\"\n                         v-for=\"(item, key) in matchSections.sectionsNos\" >\n                         \n                         <template v-if=\"!(item.sectionNo == 2 && (matchSections.matchPhaseTc == '2' || matchSections.matchPhaseTc == '1' || matchSections.matchPhaseTc == '10' ))\">\n                        <p>{{sectionsTxt[item.sectionNo]}}</p>\n                        <p>{{setScore(item.score, 1)}}</p>\n                        </template>\n                    </div>\n                </template>\n            </div>\n        </div>\n<!--        比赛事件-->\n        <div class=\"m-timeLineTips\">\n            <img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hp.png\" alt=\"\"/>黄牌<img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hp-1.png\" alt=\"\"/>红牌<img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_jq.png\" alt=\"\"/>进球<img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_wl.png\" alt=\"\"/>乌龙球<img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hs.png\" alt=\"\"/>换上<img class=\"u-icon\" src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_hx.png\" alt=\"\"/>换下\n        </div>\n        <div class=\"m-timeLine\">\n            <div class=\"u-whistle\"></div>\n            <ul class=\"m-timeLineList\">\n                <li v-for=\"(timeCon, timeKey) in eventList\">\n                    <div class=\"left\" v-if=\"getMatchTeamsNum(timeCon['home'])\">\n                        <div class=\"cont\">\n                            <div class=\"u-score\">&nbsp;</div>\n                            <div v-html=\"getMatchTeamHtml(timeCon['home'], 'home')\">\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"left\" v-else></div>\n                    <div class=\"center\">\n                        <div class=\"u-circle\">{{getGoalByMinute(timeKey,timeCon)}}</div>\n                    </div>\n                    <div class=\"right\" v-if=\"getMatchTeamsNum(timeCon['away'])\">\n                        <div class=\"u-score\">&nbsp;</div>\n                        <div class=\"cont\">\n                            <div v-html=\"getMatchTeamHtml(timeCon['away'], 'away')\">\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"right\" v-else></div>\n\n                </li>\n\n            </ul>\n            <div class=\"u-whistle1\"></div>\n        </div>\n    </div>\n<!--球队本场分析-->\n    <div class=\"m-box\" >\n        <div>\n            <div class=\"m-title\"><em></em>球队本场分析</div>\n            <div class=\"m-teamAnalysis\" v-if=\"Object.keys(curMatchInfo).length>0 && curMatchInfo.stats && curMatchInfo.stats.length>0\">\n                <div class=\"m-teamAnalysis-title\">\n                    <div class=\"m-left\">\n                     <div class=\"u-tit\">\n                     <span>{{curMatchInfo.homeTeamShortName}}</span>\n                             <img :src=\"curMatchInfo.homeTeamLogoPath\"\n                         onerror=\"javascript:this.src='https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_zd.png'\">\n                                \n                     </div>\n                    </div>\n                    <div class=\"m-center\">\n                        <div class=\"u-tit\">VS</div>\n                    </div>\n                    <div class=\"m-right\">\n                       <div class=\"u-tit\">\n                            \n                            <img :src=\"curMatchInfo.awayTeamLogoPath\"\n                     onerror=\"javascript:this.src='https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/icon_kd.png'\">\n                          <span>{{curMatchInfo.awayTeamShortName}}</span>  \n                     </div>\n                    </div>\n                </div>\n                <div class=\"m-teamAnalysis-con\" v-for=\"(item, key) in curMatchInfo.stats\">\n                <div class=\"m-left\">\n                    <div class=\"u-cont\">\n                        <span class=\"chart\">\n                            <span class=\"u-bgRed\" :style=\"{width:item.homeStatsDataRatio+'%', background:'#'+item.homeColor}\"></span>\n                        </span>\n                        <span class=\"data\">{{item.homeStatsData}}</span>\n                    </div>\n                </div>\n                <div class=\"m-center\"><div class=\"u-cont\">{{item.statsTcDesc}}</div></div>\n                <div class=\"m-right\">\n                    <div class=\"u-cont\"><span class=\"data\">{{item.awayStatsData}}</span>\n                        <span class=\"chart\">\n                            <span class=\"u-bgGrey\" :style=\"{width:item.awayStatsDataRatio+'%', background:'#'+item.awayColor}\"></span>\n                        </span>                        \n                    </div>\n                </div>\n                </div>\n            </div>\n           <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n        </div>\n        \n    </div>\n<!--    球员本场分析-->\n<div style=\"display: none\"><img src=\"https://static.sporttery.cn/res_1_0/jcw/images/fotBasbal_match/bg_fotbal.png\" width=\"0px\" height=\"0px\"></div>\n    <div class=\"m-box\">\n        <div class=\"m-title\"><em></em>球员本场分析</div>\n        <template v-if=\"playerData.homePlayerStats && playerData.homePlayerStats.length==0 && playerData.awayPlayerStats && playerData.awayPlayerStats.length==0\">\n       <div class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n        </template>\n        <template v-else>\n            <div class=\"m-tableBox\" >\n<!--            <div class=\"m-tableTitle\">-->\n<!--                <span class=\"u-team\">{{playerData.homeTeamShortName}}</span>-->\n<!--            </div>-->\n            <div class=\"m-tableTitle\">\n                <span class=\"u-team\" v-if=\"playerData.homeTeamShortName\">{{playerData.homeTeamShortName}}</span>\n                <span class=\"u-lineUpIcon\" v-if=\"playerData.homeTeamFormation && playerData.homeTeamFormation!=''\" @mouseenter=\"callZBTrackEvent\">阵容：{{playerData.homeTeamFormation}}</span>\n                <div class=\"m-lineUp\">\n                    <div class=\"u-lfBallName\">{{playerData.homeTeamShortName}}</div>\n                    <div class=\"u-rtBallName\">{{playerData.awayTeamShortName}}</div>\n                    <div class=\"u-lfLineUp\">{{playerData.homeTeamFormation}}</div>\n                    <div class=\"u-rtLineUp\">{{playerData.awayTeamFormation}}</div>\n                    <!-- 左侧场景1>6 -->\n                    <!-- 左侧场景2 -->\n                    <div class=\"m-lineUpLeft\" v-if=\"playerData.homeFormationList && playerData.homeFormationList.length>0\">\n                        <div class=\"m-player m-player-2\">\n                            <ul>\n                                <li v-if=\"hGoalkeeper.uniformNo !='' && hGoalkeeper.uniformNo !='0'\">{{hGoalkeeper.uniformNo}}</li>\n                                <li v-else></li>\n                            </ul>\n                        </div>        \n                       <template v-for=\"(item,key) in homePos\">\n                        <div class=\"m-player m-player-2\" v-if=\"Object.keys(item).length>0\">\n                            <ul>\n                             <template v-for=\"itemsub in homeOrder\">\n                                <li v-if=\"item[itemsub] && item[itemsub] !='0'\">{{item[itemsub]}}</li>\n                                <li v-else-if=\"item[itemsub] =='0'\"></li>\n                             </template>\n                            </ul>\n                        </div>\n                        </template> \n                    </div>\n                    <div class=\"m-lineUpLeft\" v-else>\n                    </div>\n                    <!-- 右侧场景2 -->\n                    <div class=\"m-lineUpRight\" v-if=\"playerData.awayFormationList && playerData.awayFormationList.length>0\">\n                        <template v-for=\"(item,key) in awayPos\">\n                         <div class=\"m-player m-player-2\" v-if=\"Object.keys(item).length>0\">\n                            <ul>\n                             <template v-for=\"itemsub in awayOrder\">\n                                <li v-if=\"item[itemsub] && item[itemsub] !='0'\" class=\"m-hidden\">{{item[itemsub]}}</li>\n                                <li v-else-if=\"item[itemsub] =='0'\" class=\"m-hidden\"></li>\n                             </template>\n                            </ul>\n                        </div>\n                        </template>          \n                        <div class=\"m-player m-player-2\">\n                            <ul>\n                                <li class=\"m-hidden\" v-if=\"aGoalkeeper.uniformNo !='' && aGoalkeeper.uniformNo !='0'\">{{aGoalkeeper.uniformNo}}</li>\n                                <li v-else class=\"m-hidden\"></li>\n                            </ul>\n                        </div>\n                    </div>\n                    <div class=\"m-lineUpRight\" v-else>\n                       \n                    </div>\n                </div>\n            </div>\n            <table class=\"m-tableData m-tableData-1\" v-if=\"playerData.homePlayerStats && playerData.homePlayerStats.length>0\">\n                <tr>\n                    <th width=\"272\" class=\"u-jfTit-zq\">号码-球员 (位置)</th>\n                    <th width=\"108\">首发</th>\n                    <th width=\"128\">进球</th>\n                    <th width=\"128\">乌龙球</th>\n                    <th width=\"128\">黄牌</th>\n                    <th width=\"128\">红牌</th>\n                    <th width=\"128\">换上</th>\n                    <th width=\"128\">换下</th>\n                </tr>\n                <tr v-for=\"(item, key) in playerData.homePlayerStats\">\n                    <td class=\"u-jfTit-zq\" >\n                    <span v-if=\"item.uniformNo !='' && item.uniformNo !='0'\">{{item.uniformNo}}-</span>{{item.personName}}<span v-if=\"item.playerPositionDesc !='' && item.playerPositionDesc !=undefined\" style=\"color: #666;font-size: 12px;\">（{{item.playerPositionDesc}}）</span></td>\n                    <td>\n                    <span v-if=\"item.starterFlag ==1\" class=\"u-cir-black\">&nbsp;</span>\n                    <span v-else class=\"u-cir-gray\">&nbsp;</span>\n                    </td>\n                    <td>{{item.goalCnt?item.goalCnt:'-'}}</td>\n                    <td>{{item.ownGoalCnt?item.ownGoalCnt:'-'}}</td>\n                    <td>{{item.yellowCardCnt?item.yellowCardCnt:'-'}}</td>\n                    <td>{{item.redCardCnt?item.redCardCnt:'-'}}</td>\n                    <td>{{item.substituteInMatchCnt?item.substituteInMatchCnt:'-'}}</td>\n                    <td>{{item.substituteOutMatchCnt?item.substituteOutMatchCnt:'-'}}</td>\n\n                </tr>\n            </table>\n            <div v-else class=\"m-listNone\">暂无数据</div>\n        </div>\n            <div class=\"m-tableBox\" >\n            <div class=\"m-tableTitle\">\n                <span class=\"u-team\" v-if=\"playerData.awayTeamShortName\">{{playerData.awayTeamShortName}}</span>\n                     <span class=\"u-lineUpIcon\" v-if=\"playerData.awayTeamFormation && playerData.awayTeamFormation!=''\" @mouseenter=\"callZBTrackEvent\">阵容：{{playerData.awayTeamFormation}}</span>\n                <div class=\"m-lineUp\">\n                    <div class=\"u-lfBallName\">{{playerData.homeTeamShortName}}</div>\n                    <div class=\"u-rtBallName\">{{playerData.awayTeamShortName}}</div>\n                    <div class=\"u-lfLineUp\">{{playerData.homeTeamFormation}}</div>\n                    <div class=\"u-rtLineUp\">{{playerData.awayTeamFormation}}</div>\n                    <div class=\"m-lineUpLeft\" v-if=\"playerData.homeFormationList && playerData.homeFormationList.length>0\">\n                        <div class=\"m-player m-player-2\">\n                            <ul>\n                                <li class=\"m-hidden\" v-if=\"hGoalkeeper.uniformNo !='' && hGoalkeeper.uniformNo !='0'\">{{hGoalkeeper.uniformNo}}</li>\n                                <li v-else class=\"m-hidden\"></li>\n                            </ul>\n                        </div>        \n                       <template v-for=\"(item,key) in homePos\">\n                        <div class=\"m-player m-player-2\" v-if=\"Object.keys(item).length>0\">\n                            <ul>\n                             <template v-for=\"itemsub in homeOrder\">\n                                <li v-if=\"item[itemsub] && item[itemsub] !='0'\" class=\"m-hidden\">{{item[itemsub]}}</li>\n                                <li v-else-if=\"item[itemsub] =='0'\" class=\"m-hidden\"></li>\n                             </template>\n                            </ul>\n                        </div>\n                        </template> \n                    </div>\n                    <div class=\"m-lineUpLeft\" v-else>\n                    </div>\n                    <!-- 右侧场景2 -->\n                    <div class=\"m-lineUpRight\" v-if=\"playerData.awayFormationList && playerData.awayFormationList.length>0\">\n                        <template v-for=\"(item,key) in awayPos\">\n                         <div class=\"m-player m-player-2\" v-if=\"Object.keys(item).length>0\">\n                            <ul>\n                             <template v-for=\"itemsub in awayOrder\">\n                                <li v-if=\"item[itemsub] && item[itemsub] !='0'\" >{{item[itemsub]}}</li>\n                                <li v-else-if=\"item[itemsub] =='0'\"></li>\n                             </template>\n                            </ul>\n                        </div>\n                        </template>          \n                        <div class=\"m-player m-player-2\">\n                            <ul>\n                                <li v-if=\"aGoalkeeper.uniformNo !='' && aGoalkeeper.uniformNo !='0'\">{{aGoalkeeper.uniformNo}}</li>\n                                <li v-else></li>\n                            </ul>\n                        </div>\n                    </div>\n                    <div class=\"m-lineUpRight\" v-else>\n                    </div>\n                </div>\n            </div>\n            <table class=\"m-tableData m-tableData-1\" v-if=\"playerData.awayPlayerStats && playerData.awayPlayerStats.length>0\">\n                <tr>\n            <th width=\"272\" class=\"u-jfTit-zq\">号码-球员 (位置)</th>\n            <th width=\"108\">首发</th>\n            <th width=\"128\">进球</th>\n            <th width=\"128\">乌龙球</th>\n            <th width=\"128\">黄牌</th>\n            <th width=\"128\">红牌</th>\n            <th width=\"128\">换上</th>\n            <th width=\"128\">换下</th>\n        </tr>\n                <tr v-for=\"(item, key) in playerData.awayPlayerStats\">\n            <td class=\"u-jfTit-zq\" >\n            <span v-if=\"item.uniformNo !='' && item.uniformNo !='0'\">{{item.uniformNo}}-</span>{{item.personName}}<span v-if=\"item.playerPositionDesc !='' && item.playerPositionDesc !=undefined\" style=\"color: #666;font-size: 12px;\">（{{item.playerPositionDesc}}）</span></td>\n            <td>\n            <span v-if=\"item.starterFlag ==1\" class=\"u-cir-black\">&nbsp;</span>\n            <span v-else class=\"u-cir-gray\">&nbsp;</span>\n            </td>\n            <td>{{item.goalCnt?item.goalCnt:'-'}}</td>\n            <td>{{item.ownGoalCnt?item.ownGoalCnt:'-'}}</td>\n            <td>{{item.yellowCardCnt?item.yellowCardCnt:'-'}}</td>\n            <td>{{item.redCardCnt?item.redCardCnt:'-'}}</td>\n            <td>{{item.substituteInMatchCnt?item.substituteInMatchCnt:'-'}}</td>\n            <td>{{item.substituteOutMatchCnt?item.substituteOutMatchCnt:'-'}}</td>\n        </tr>\n            </table>\n            <div v-else class=\"m-listNone\" style=\"background: rgb(255, 255, 255);\">暂无数据</div>\n        </div>\n        </template>\n        </div>\n        <div class=\"m-tips\" style=\"padding-left: 16px;\">注：部分统计数据可能有延迟，请耐心等待~</div>\n</div>\n`\n}\n"
