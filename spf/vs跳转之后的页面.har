0;\n        color: #181818;\n    }\n\n    .lottery-qr-codes {\n        display: flex;\n        justify-content: center;\n        gap: 60px;\n        margin-top: 14px;\n    }\n\n    .qr-code-item {\n        text-align: center;\n        width: 160px;\n    }\n\n    .qr-code {\n        width: 120px;\n        height: 120px;\n        margin: 0 auto 15px;\n        border: 1px solid #e1e1e1;\n        box-shadow: 0 3px 3px rgba(49, 34, 0, 0.16);\n        background-color: #fff;\n    }\n\n    .qr-code-img {\n        width: 100%;\n        height: 100%;\n        object-fit: contain;\n    }\n\n    .qr-code-text {\n        font-size: 14px;\n        color: #414141;\n        margin: 0;\n        line-height: 20px;\n    }\n\n    .lottery-win-check-close {\n        position: absolute;\n        top: 8px;\n        right: 10px;\n        width: 16px;\n        height: 16px;\n        cursor: pointer;\n        z-index: 10;\n        opacity: 0.6;\n        transition: opacity 0.3s ease;\n        background: transparent;\n        border: none;\n        padding: 0;\n    }\n\n    .lottery-win-check-close:hover {\n        opacity: 1;\n    }\n\n    .lottery-win-check-close img {\n        width: 100%;\n        height: 100%;\n        display: block;\n    }`;const html=`<div class=\"lottery-win-check\">\n        <span class=\"lottery-win-check-close\">\n            <img src=\"https://static.sporttery.cn/res_1_0/jcw/images/login/closeBtn.png\" alt=\"关闭\">\n        </span>\n        <div class=\"lottery-win-check-content\">\n            <div class=\"lottery-win-check-h3\">无需对比赛果，使用中国体育彩票 APP 或小程序【扫一扫】扫描彩票下方二维码即可知晓彩票中奖情况</div>\n            <div class=\"lottery-qr-codes\">\n                <div class=\"qr-code-item\">\n                    <div class=\"qr-code\">\n                        <img src=\"https://static.sporttery.cn/res_1_0/tcw/upload/202102/03015359ehlv.png\" alt=\"中国体育彩票 APP\" class=\"qr-code-img\">\n                    </div>\n                    <p class=\"qr-code-text\">扫描上方二维码下载<br>中国体育彩票 AP